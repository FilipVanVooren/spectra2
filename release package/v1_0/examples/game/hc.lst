  72b 6C7C 69D4  
  73b 6C7E 6C92         DATA  COINC
  74b 6C80 06A0         BL    @CPYM2V
  74b 6C82 610A  
  75b 6C84 0380         DATA  >0380,COLORS,16       ; Load color table into VDP        
  75b 6C86 709A  
