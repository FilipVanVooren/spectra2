  27b           *//////////////////////////////////////////////////////////////
  28b           *                       RUNLIB MEMORY SETUP
  29b           *//////////////////////////////////////////////////////////////
  30b           
  31b           * Equates and Memory setup ..:
  32b           ***************************************************************
  33b           * >8300 - >833A     Scratchpad memory layout
  34b           ********@*****@*********************@**************************
  35b 0000 8300 WS1     EQU   >8300                 ; 32 - Primary workspace
  36b 0000 8320 MCLOOP  EQU   >8320                 ; 08 - Machine code for loop & speech
  37b 0000 8328 WBASE   EQU   >8328                 ; 02 - PNT base address
  38b 0000 832A WYX     EQU   >832A                 ; 02 - Cursor YX position
  39b 0000 832C WTITAB  EQU   >832C                 ; 02 - Timers: Address of timer table
  40b 0000 832E WTIUSR  EQU   >832E                 ; 02 - Timers: Address of user hook
  41b 0000 8330 WTITMP  EQU   >8330                 ; 02 - Timers: Internal use
  42b 0000 8332 WVRTKB  EQU   >8332                 ; 02 - Virtual keyboard flags
  43b 0000 8334 WSDLST  EQU   >8334                 ; 02 - Sound player: Tune address
  44b 0000 8336 WSDTMP  EQU   >8336                 ; 02 - Sound player: Temporary use
  45b 0000 8338 WSPEAK  EQU   >8338                 ; 02 - Speech player: Address of LPC data
  46b 0000 833A WSEED   EQU   >833A                 ; 02 - Seed for random subroutine
  47b 0000 833C WCOLMN  EQU   >833C                 ; 02 - Screen size, columns per row
  48b 0000 833E WASCKB  EQU   >833E                 ; 02 - Real keyboard: ASCII value of key
  49b           ***************************************************************
  50b 0000 832A BY      EQU   WYX                   ;      Cursor Y position
  51b 0000 832B BX      EQU   WYX+1                 ;      Cursor X position
  52b 0000 8322 MCSPRD  EQU   MCLOOP+2              ;      Speech read routine
  53b           ***************************************************************
  54b           * Register usage
  55b           * R0-R3   General purpose registers
  56b           * R4-R8   Temporary registers
  57b           * R9      Stack pointer
  58b           * R10     Highest slot in use + Timer counter
  59b           * R11     Subroutine return address
  60b           * R12     Configuration register
  61b           * R13     Copy of VDP status byte and counter for sound player
  62b           * R14     Copy of VDP register #0 and VDP register #1 bytes
  63b           * R15     VDP read/write address
  64b           ***************************************************************
  65b           * Workspace and register equates
  66b           ********@*****@*********************@**************************
  67b 0000 0000 R0      EQU   0
  68b 0000 0001 R1      EQU   1
  69b 0000 0002 R2      EQU   2
  70b 0000 0003 R3      EQU   3
  71b 0000 0004 R4      EQU   4
  72b 0000 0005 R5      EQU   5
  73b 0000 0006 R6      EQU   6
  74b 0000 0007 R7      EQU   7
  75b 0000 0008 R8      EQU   8
  76b 0000 0009 R9      EQU   9
  77b 0000 000A R10     EQU   10
  78b 0000 000B R11     EQU   11
  79b 0000 000C R12     EQU   12
  80b 0000 000D R13     EQU   13
  81b 0000 000E R14     EQU   14
  82b 0000 000F R15     EQU   15
  83b 0000 8300 R0HB    EQU   WS1                   ; HI byte R0
  84b 0000 8301 R0LB    EQU   WS1+1                 ; LO byte R0
  85b 0000 8302 R1HB    EQU   WS1+2                 ; HI byte R1
  86b 0000 8303 R1LB    EQU   WS1+3                 ; LO byte R1
  87b 0000 8304 R2HB    EQU   WS1+4                 ; HI byte R2
  88b 0000 8305 R2LB    EQU   WS1+5                 ; LO byte R2
  89b 0000 8306 R3HB    EQU   WS1+6                 ; HI byte R3
  90b 0000 8307 R3LB    EQU   WS1+7                 ; LO byte R3
  91b 0000 8308 R4HB    EQU   WS1+8                 ; HI byte R4
  92b 0000 8309 R4LB    EQU   WS1+9                 ; LO byte R4
  93b 0000 830A R5HB    EQU   WS1+10                ; HI byte R5
  94b 0000 830B R5LB    EQU   WS1+11                ; LO byte R5
  95b 0000 830C R6HB    EQU   WS1+12                ; HI byte R6
  96b 0000 830D R6LB    EQU   WS1+13                ; LO byte R6
  97b 0000 830E R7HB    EQU   WS1+14                ; HI byte R7
  98b 0000 830F R7LB    EQU   WS1+15                ; LO byte R7
  99b 0000 8310 R8HB    EQU   WS1+16                ; HI byte R8
 100b 0000 8311 R8LB    EQU   WS1+17                ; LO byte R8
 101b 0000 8312 R9HB    EQU   WS1+18                ; HI byte R9
 102b 0000 8313 R9LB    EQU   WS1+19                ; LO byte R9
 103b 0000 8314 R10HB   EQU   WS1+20                ; HI byte R10
 104b 0000 8315 R10LB   EQU   WS1+21                ; LO byte R10
 105b 0000 8316 R11HB   EQU   WS1+22                ; HI byte R11
 106b 0000 8317 R11LB   EQU   WS1+23                ; LO byte R11
 107b 0000 8318 R12HB   EQU   WS1+24                ; HI byte R12
 108b 0000 8319 R12LB   EQU   WS1+25                ; LO byte R12
 109b 0000 831A R13HB   EQU   WS1+26                ; HI byte R13
 110b 0000 831B R13LB   EQU   WS1+27                ; LO byte R13
 111b 0000 831C R14HB   EQU   WS1+28                ; HI byte R14
 112b 0000 831D R14LB   EQU   WS1+29                ; LO byte R14
 113b 0000 831E R15HB   EQU   WS1+30                ; HI byte R15
 114b 0000 831F R15LB   EQU   WS1+31                ; LO byte R15
 115b 0000 0004 TMP0    EQU   R4                    ; Temp register 0
 116b 0000 0005 TMP1    EQU   R5                    ; Temp register 1
 117b 0000 0006 TMP2    EQU   R6                    ; Temp register 2
 118b 0000 0007 TMP3    EQU   R7                    ; Temp register 3
 119b 0000 0008 TMP4    EQU   R8                    ; Temp register 4
 120b 0000 0009 TMP5    EQU   R9                    ; Temp register 5
 121b 0000 000F TMP6    EQU   R15                   ; Temp register 6
 122b 0000 8308 TMP0HB  EQU   WS1+8                 ; HI byte R4
 123b 0000 8309 TMP0LB  EQU   WS1+9                 ; LO byte R4
 124b 0000 830A TMP1HB  EQU   WS1+10                ; HI byte R5
 125b 0000 830B TMP1LB  EQU   WS1+11                ; LO byte R5
 126b 0000 830C TMP2HB  EQU   WS1+12                ; HI byte R6
 127b 0000 830D TMP2LB  EQU   WS1+13                ; LO byte R6
 128b 0000 830E TMP3HB  EQU   WS1+14                ; HI byte R7
 129b 0000 830F TMP3LB  EQU   WS1+15                ; LO byte R7
 130b 0000 8310 TMP4HB  EQU   WS1+16                ; HI byte R8
 131b 0000 8311 TMP4LB  EQU   WS1+17                ; LO byte R8
 132b 0000 8310 TMP5HB  EQU   WS1+16                ; HI byte R8
 133b 0000 8311 TMP5LB  EQU   WS1+17                ; LO byte R8
 134b 0000 831E TMP6HB  EQU   WS1+30                ; HI byte R15
 135b 0000 831F TMP6LB  EQU   WS1+31                ; LO byte R15
 136b           ***************************************************************
 137b           * Equates for VDP, GROM, SOUND, SPEECH ports
 138b           ********@*****@*********************@**************************
 139b 0000 8400 SOUND   EQU   >8400                 ; Sound generator address
 140b 0000 8800 VDPR    EQU   >8800                 ; VDP read data window address
 141b 0000 8C00 VDPW    EQU   >8C00                 ; VDP write data window address
 142b 0000 8802 VDPS    EQU   >8802                 ; VDP status register
 143b 0000 8C02 VDPA    EQU   >8C02                 ; VDP address register
 144b 0000 9C02 GRMWA   EQU   >9C02                 ; GROM set write address
 145b 0000 9802 GRMRA   EQU   >9802                 ; GROM set read address
 146b 0000 9800 GRMRD   EQU   >9800                 ; GROM read byte
 147b 0000 9C00 GRMWD   EQU   >9C00                 ; GROM write byte
 148b 0000 9000 SPCHRD  EQU   >9000                 ; Address of speech synth Read Data Register
 149b 0000 9400 SPCHWT  EQU   >9400                 ; Address of speech synth Write Data Register
 150b           ***************************************************************
 151b           * Equates for registers
 152b           ********@*****@*********************@**************************
 153b 0000 0009 STACK   EQU   R9                    ; Stack pointer
 154b 0000 8314 BTIHI   EQU   WS1+20                ; Highest slot in use (HI byte R10)
 155b 0000 000C CONFIG  EQU   R12                   ; SPECTRA configuration register
 156b 0000 831A BVDPST  EQU   WS1+26                ; Copy of VDP status register (HI byte R13)
 157b 0000 000E VDPR01  EQU   R14                   ; Copy of VDP#0 and VDP#1 bytes
 158b 0000 831C VDPR0   EQU   WS1+28                ; High byte of R14. Is VDP#0 byte
 159b 0000 831D VDPR1   EQU   WS1+29                ; Low byte  of R14. Is VDP#1 byte
 160b 0000 000F VDPRW   EQU   R15                   ; Contains VDP read/write address
 161b           ***************************************************************
 162b           * Equates for memory locations
 163b           ********@*****@*********************@**************************
 164b 0000 832E WRAMF   EQU   >832E                 ; Memory location F
 165b 0000 8338 WRAMK   EQU   >8338                 ; Memory location K
 166b 0000 833A WRAML   EQU   >833A                 ; Memory location L
 167b           ***************************************************************
 168b           * The config register equates
 169b           *--------------------------------------------------------------
 170b           * Configuration flags
 171b           * ===================
 172b           * 
 173b           * ; 15  Sound player: tune source       1=ROM/RAM      0=VDP MEMORY
 174b           * ; 14  Sound player: repeat tune       1=yes          0=no
 175b           * ; 13  Sound player: enabled           1=yes          0=no (or pause)
 176b           * ; 12  Keyboard: mode                  1=real         0=virtual
 177b           * ; 11  Keyboard: ANY key pressed       1=yes          0=no
 178b           * ; 10  TI-99/4A v2.2 OS                1=yes          0=no
 179b           * ; 09  Timer: Kernel thread enabled    1=yes          0=no
 180b           * ; 08  Timer: Block kernel thread      1=yes          0=no     
 181b           * ; 07  Timer: User hook enabled        1=yes          0=no     
 182b           * ; 06  Timer: Block user hook          1=yes          0=no
 183b           * ; 05  speech player: external voice   1=yes          0=no
 184b           * ; 04  Speech player: busy             1=yes          0=no
 185b           * ; 03  Speech player: enabled          1=yes          0=no
 186b           * ; 02  VDP9918 PAL version             1=yes(50)      0=no(60)
 187b           * ; 01  Subroutine state flag 1         1=on           0=off
 188b           * ; 00  Subroutine state flag 0         1=on           0=off
 189b           ********@*****@*********************@**************************
 190b 0000 2000 PALON   EQU   >2000                 ; bit 2=1   (VDP9918 PAL version)
 191b 0000 0100 ENUSR   EQU   >0100                 ; bit 7=1   (Enable user hook)
 192b 0000 0040 ENKNL   EQU   >0040                 ; bit 9=1   (Enable kernel thread)
 193b 0000 0020 V22OS   EQU   >0020                 ; bit 10=1  (TI-99/4A V2.2 OS)
 194b           ***************************************************************
 195b           * Subroutine parameter equates
 196b           ***************************************************************
 197b 0000 FFFF EOL     EQU   >FFFF                 ; End-Of-List
 198b 0000 FFFF NOFONT  EQU   >FFFF                 ; Skip loading font in RUNLIB
 199b 0000 3030 NUM1    EQU   >3030                 ; MKNUM  => ASCII 0-9, leading 0's 
 200b 0000 3020 NUM2    EQU   >3020                 ; MKNUM  => ASCII 0-9, leading spaces
 201b 0000 0007 SDOPT1  EQU   7                     ; SDPLAY => 111 (Player on, repeat, tune in CPU memory)
 202b 0000 0005 SDOPT2  EQU   5                     ; SDPLAY => 101 (Player on, no repeat, tune in CPU memory)
 203b 0000 0006 SDOPT3  EQU   6                     ; SDPLAY => 110 (Player on, repeat, tune in VRAM)
 204b 0000 0004 SDOPT4  EQU   4                     ; SDPLAY => 100 (Player on, no repeat, tune in VRAM)
 205b 0000 0000 FNOPT1  EQU   >0000                 ; LDFNT  => Load TI title screen font
 206b 0000 0006 FNOPT2  EQU   >0006                 ; LDFNT  => Load upper case font
 207b 0000 000C FNOPT3  EQU   >000C                 ; LDFNT  => Load upper/lower case font
 208b 0000 0012 FNOPT4  EQU   >0012                 ; LDFNT  => Load lower case font
 209b 0000 8000 FNOPT5  EQU   >8000                 ; LDFNT  => Load TI title screen font  & make bold
 210b 0000 8006 FNOPT6  EQU   >8006                 ; LDFNT  => Load upper case font       & make bold
 211b 0000 800C FNOPT7  EQU   >800C                 ; LDFNT  => Load upper/lower case font & make bold
 212b 0000 8012 FNOPT8  EQU   >8012                 ; LDFNT  => Load lower case font       & make bold
 213b           *--------------------------------------------------------------
 214b           *   Speech player
 215b           *--------------------------------------------------------------
 216b 0000 1400 SPOPT1  EQU   >1400                 ; 0001010000000000 (Player on, external voice)
 217b 0000 1000 SPOPT2  EQU   >1000                 ; 0001000000000000 (Player on, resident voice)
 218b 0000 0060 TALKON  EQU   >60                   ; 'start talking' command code for speech synth
 219b 0000 00FF TALKOF  EQU   >FF                   ; 'stop talking' command code for speech synth
 220b 0000 6000 SPKON   EQU   >6000                 ; 'start talking' command code for speech synth
 221b 0000 FF00 SPKOFF  EQU   >FF00                 ; 'stop talking' command code for speech synth
 222b           ***************************************************************
 223b           * Virtual keyboard equates
 224b           ***************************************************************
 225b           * ; bit  0: ALPHA LOCK down             0=no  1=yes
 226b           * ; bit  1: ENTER                       0=no  1=yes
 227b           * ; bit  2: REDO                        0=no  1=yes
 228b           * ; bit  3: BACK                        0=no  1=yes
 229b           * ; bit  4: Pause                       0=no  1=yes
 230b           * ; bit  5: *free*                      0=no  1=yes
 231b           * ; bit  6: P1 Left                     0=no  1=yes
 232b           * ; bit  7: P1 Right                    0=no  1=yes
 233b           * ; bit  8: P1 Up                       0=no  1=yes
 234b           * ; bit  9: P1 Down                     0=no  1=yes
 235b           * ; bit 10: P1 Space / fire / Q         0=no  1=yes
 236b           * ; bit 11: P2 Left                     0=no  1=yes
 237b           * ; bit 12: P2 Right                    0=no  1=yes
 238b           * ; bit 13: P2 Up                       0=no  1=yes
 239b           * ; bit 14: P2 Down                     0=no  1=yes
 240b           * ; bit 15: P2 Space / fire / Q         0=no  1=yes
 241b           ***************************************************************
 242b 0000 8000 KALPHA  EQU   >8000                 ; Virtual key alpha lock
 243b 0000 4000 KENTER  EQU   >4000                 ; Virtual key enter
 244b 0000 2000 KREDO   EQU   >2000                 ; Virtual key REDO
 245b 0000 1000 KBACK   EQU   >1000                 ; Virtual key BACK
 246b 0000 0800 KPAUSE  EQU   >0800                 ; Virtual key pause
 247b 0000 0400 KFREE   EQU   >0400                 ; ***NOT USED YET***
 248b           *--------------------------------------------------------------
 249b           * Keyboard Player 1
 250b           *--------------------------------------------------------------
 251b 0000 0280 K1UPLF  EQU   >0280                 ; Virtual key up   + left
 252b 0000 0180 K1UPRG  EQU   >0180                 ; Virtual key up   + right
 253b 0000 0240 K1DNLF  EQU   >0240                 ; Virtual key down + left
 254b 0000 0140 K1DNRG  EQU   >0140                 ; Virtual key down + right
 255b 0000 0200 K1LF    EQU   >0200                 ; Virtual key left
 256b 0000 0100 K1RG    EQU   >0100                 ; Virtual key right
 257b 0000 0080 K1UP    EQU   >0080                 ; Virtual key up
 258b 0000 0040 K1DN    EQU   >0040                 ; Virtual key down
 259b 0000 0020 K1FIRE  EQU   >0020                 ; Virtual key fire
 260b           *--------------------------------------------------------------
 261b           * Keyboard Player 2
 262b           *--------------------------------------------------------------
 263b 0000 0014 K2UPLF  EQU   >0014                 ; Virtual key up   + left
 264b 0000 000C K2UPRG  EQU   >000C                 ; Virtual key up   + right
 265b 0000 0012 K2DNLF  EQU   >0012                 ; Virtual key down + left
 266b 0000 000A K2DNRG  EQU   >000A                 ; Virtual key down + right
 267b 0000 0010 K2LF    EQU   >0010                 ; Virtual key left
 268b 0000 0008 K2RG    EQU   >0008                 ; Virtual key right
 269b 0000 0004 K2UP    EQU   >0004                 ; Virtual key up
 270b 0000 0002 K2DN    EQU   >0002                 ; Virtual key down
 271b 0000 0001 K2FIRE  EQU   >0001                 ; Virtual key fire
 272b           ***************************************************************
 273b           * Misc equates (bank switching, etc.)
 274b           ********@*****@*********************@**************************
 275b 0000 6000 BANK0   EQU   >6000
 276b 0000 6002 BANK1   EQU   >6002
 277b           ***************************************************************
 278b           *                      Some constants
 279b           ********@*****@*********************@**************************
 280b                   EVEN                        ; Just in case
 281b 6026 8000 WBIT0   DATA  >8000                 ; Binary 1000000000000000
 282b 6028 4000 WBIT1   DATA  >4000                 ; Binary 0100000000000000
 283b 602A 2000 WBIT2   DATA  >2000                 ; Binary 0010000000000000
 284b 602C 1000 WBIT3   DATA  >1000                 ; Binary 0001000000000000
 285b 602E 0800 WBIT4   DATA  >0800                 ; Binary 0000100000000000
 286b 6030 0400 WBIT5   DATA  >0400                 ; Binary 0000010000000000
 287b 6032 0200 WBIT6   DATA  >0200                 ; Binary 0000001000000000
 288b 6034 0100 WBIT7   DATA  >0100                 ; Binary 0000000100000000
 289b 6036 0080 WBIT8   DATA  >0080                 ; Binary 0000000010000000
 290b 6038 0040 WBIT9   DATA  >0040                 ; Binary 0000000001000000
 291b 603A 0020 WBIT10  DATA  >0020                 ; Binary 0000000000100000
 292b 603C 0010 WBIT11  DATA  >0010                 ; Binary 0000000000010000
 293b 603E 0008 WBIT12  DATA  >0008                 ; Binary 0000000000001000
 294b 6040 0004 WBIT13  DATA  >0004                 ; Binary 0000000000000100
 295b 6042 0002 WBIT14  DATA  >0002                 ; Binary 0000000000000010
 296b 6044 0001 WBIT15  DATA  >0001                 ; Binary 0000000000000001
 297b 6046 FFFF WHFFFF  DATA  >FFFF                 ; Binary 1111111111111111
 298b 6048 00   BD0     BYTE  0                     ; Digit 0
 299b 6049 01   BD1     BYTE  1                     ; Digit 1
 300b 604A 02   BD2     BYTE  2                     ; Digit 2
 301b 604B 03   BD3     BYTE  3                     ; Digit 3
 302b 604C 04   BD4     BYTE  4                     ; Digit 4
 303b 604D 05   BD5     BYTE  5                     ; Digit 5
 304b 604E 06   BD6     BYTE  6                     ; Digit 6
 305b 604F 07   BD7     BYTE  7                     ; Digit 7
 306b 6050 08   BD8     BYTE  8                     ; Digit 8
 307b 6051 09   BD9     BYTE  9                     ; Digit 9
 308b 6052 D0   BD208   BYTE  208                   ; Digit 208 (>E0)
 309b 6053 0000         EVEN
 310b           *--------------------------------------------------------------
 311b           * The equates for constants
 312b           *--------------------------------------------------------------
 313b 0000 603C ANYKEY  EQU   WBIT11                ; BIT 11 in the CONFIG register
 314b 0000 6026 BBIT0   EQU   WBIT0
 315b 0000 6028 BBIT1   EQU   WBIT1
 316b 0000 602A BBIT2   EQU   WBIT2
 317b 0000 602C BBIT3   EQU   WBIT3
 318b 0000 602E BBIT4   EQU   WBIT4
 319b 0000 6030 BBIT5   EQU   WBIT5
 320b 0000 6032 BBIT6   EQU   WBIT6
 321b 0000 6034 BBIT7   EQU   WBIT7
 322b 0000 603D BH10    EQU   WBIT11+1              ; >10
 323b 0000 603B BH20    EQU   WBIT10+1              ; >20
 324b 0000 6039 BH40    EQU   WBIT9+1               ; >40
 325b 0000 6037 BH80    EQU   WBIT8+1               ; >80
 326b 0000 6034 WH100   EQU   WBIT7                 ; >0100
 327b 0000 6028 WH4000  EQU   WBIT1                 ; >4000   
 328b           
 329b           ***************************************************************
 330b           *                    Video mode tables
 331b           ***************************************************************
 332b           * Graphics mode 1 (32 columns)
 333b           *--------------------------------------------------------------
 334b 6054 00E2 GRAPH1  BYTE  >00,>E2,>00,>0E,>01,>06,>02,SPFBCK,0,32
 334b 6056 000E  
 334b 6058 0106  
 334b 605A 0201  
 334b 605C 0020  
 335b           * ; VDP#0 Control bits
 336b           * ;      bit 6=0: M3 | Graphics 1 mode
 337b           * ;      bit 7=0: Disable external VDP input
 338b           * ; VDP#1 Control bits
 339b           * ;      bit 0=1: 16K selection
 340b           * ;      bit 1=1: Enable display
 341b           * ;      bit 2=1: Enable VDP interrupt
 342b           * ;      bit 3=0: M1 \ Graphics 1 mode
 343b           * ;      bit 4=0: M2 /
 344b           * ;      bit 5=0: reserved
 345b           * ;      bit 6=1: 16x16 sprites
 346b           * ;      bit 7=0: Sprite magnification (1x)
 347b           * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >400)
 348b           * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >040)
 349b           * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >800)
 350b           * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >080)
 351b           * ; VDP#6 SPT (Sprite pattern table)     at >0400  (>80 * >008)
 352b           * ; VDP#7 Set screen background color
 353b           ***************************************************************
 354b           * Textmode (40 columns)
 355b           *--------------------------------------------------------------
 356b 605E 00F2 TXTMOD  BYTE  >00,>F2,>00,>0E,>01,>06,>80,SPFCLR,0,40
 356b 6060 000E  
 356b 6062 0106  
 356b 6064 80A0  
 356b 6066 0028  
 357b           * ; VDP#0 Control bits
 358b           * ;      bit 6=0: M3 | Graphics 1 mode
 359b           * ;      bit 7=0: Disable external VDP input
 360b           * ; VDP#1 Control bits
 361b           * ;      bit 0=1: 16K selection
 362b           * ;      bit 1=1: Enable display
 363b           * ;      bit 2=1: Enable VDP interrupt
 364b           * ;      bit 3=1: M1 \ TEXT MODE
 365b           * ;      bit 4=0: M2 /
 366b           * ;      bit 5=0: reserved
 367b           * ;      bit 6=1: 16x16 sprites
 368b           * ;      bit 7=0: Sprite magnification (1x)
 369b           * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >400)
 370b           * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >040)
 371b           * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >800)
 372b           * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >080)
 373b           * ; VDP#6 SPT (Sprite pattern table)     at >0400  (>80 * >008)
 374b           * ; VDP#7 Set foreground/background color
 375b           ***************************************************************
 376b           
 377b           
 378b           ***************************************************************
 379b           *                Data used by runtime library
 380b           ********@*****@*********************@**************************
 381b 6068 69B4 KDATA   DATA  KERNEL                ; Address of kernel thread
 382b           *--------------------------------------------------------------
 383b           * ; Machine code for tight loop. 
 384b           * ; The MOV operation at MCLOOP must be injected by the calling routine.
 385b           *--------------------------------------------------------------        
 386b           *       DATA  >????                 ; \ MCLOOP  MOV   ...
 387b 606A 0606 MCCODE  DATA  >0606                 ; |         DEC   R6 (TMP2)
 388b 606C 16FD         DATA  >16FD                 ; |         JNE   MCLOOP
 389b 606E 045B         DATA  >045B                 ; /         B     *R11
 390b           *--------------------------------------------------------------
 391b           * ; Machine code for reading from the speech synthesizer
 392b           * ; The SRC instruction takes 12 uS for execution in scratchpad RAM.
 393b           * ; Is required for the 12 uS delay. It destroys R5.
 394b           *--------------------------------------------------------------   
 395b 6070 D114 SPCODE  DATA  >D114                 ; \         MOVB  *R4,R4 (TMP0)
 396b 6072 0BC5         DATA  >0BC5                 ; /         SRC   R5,12  (TMP1)
 397b                   EVEN
 398b           *:..
 399b           
 400b                        
 401b           *//////////////////////////////////////////////////////////////
 402b           *                     FILL & COPY FUNCTIONS
 403b           *//////////////////////////////////////////////////////////////
 404b           
 405b           
 406b           * FILM   (DATA P0,P1,P2) / XFILM ..:
 407b           ***************************************************************
 408b           * FILM - Fill CPU memory with byte
 409b           ***************************************************************
 410b           *  BL   @FILM
 411b           *  DATA P0,P1,P2
 412b           *--------------------------------------------------------------
 413b           *  P0 = Memory start address
 414b           *  P1 = Byte to fill
 415b           *  P2 = Number of bytes to fill
 416b           *--------------------------------------------------------------
 417b           *  BL   @XFILM
 418b           *
 419b           *  TMP0 = Memory start address
 420b           *  TMP1 = Byte to fill
 421b           *  TMP2 = Number of bytes to fill
 422b           ********@*****@*********************@**************************
 423b 6074 C13B FILM    MOV   *R11+,TMP0            ; Memory start
 424b 6076 C17B         MOV   *R11+,TMP1            ; Byte to fill
 425b 6078 C1BB         MOV   *R11+,TMP2            ; Repeat count        
 426b           *--------------------------------------------------------------
 427b           * Fill memory with 16 bit words
 428b           *--------------------------------------------------------------              
 429b 607A C1C6 XFILM   MOV   TMP2,TMP3
 430b 607C 0247         ANDI  TMP3,1                ; TMP3=1 -> ODD else EVEN
 430b 607E 0001  
 431b 6080 1301         JEQ   FILM1
 432b 6082 0606         DEC   TMP2                  ; Make TMP2 even        
 433b 6084 D820 FILM1   MOVB  @TMP1LB,@TMP1HB       ; Duplicate value    
 433b 6086 830B  
 433b 6088 830A  
 434b 608A CD05 FILM2   MOV   TMP1,*TMP0+
 435b 608C 0646         DECT  TMP2
 436b 608E 16FD         JNE   FILM2
 437b           *--------------------------------------------------------------
 438b           * Fill last byte if ODD
 439b           *--------------------------------------------------------------          
 440b 6090 C1C7         MOV   TMP3,TMP3
 441b 6092 1301         JEQ   FILMZ
 442b 6094 D505         MOVB  TMP1,*TMP0
 443b 6096 045B FILMZ   B     *R11
 444b           * :..
 445b           
 446b           * FILV   (DATA P0,P1,P2) / XFILV ..:
 447b           ***************************************************************
 448b           * FILV - Fill VRAM with byte
 449b           ***************************************************************
 450b           *  BL   @FILV
 451b           *  DATA P0,P1,P2
 452b           *--------------------------------------------------------------
 453b           *  P0 = VDP start address
 454b           *  P1 = Byte to fill
 455b           *  P2 = Number of bytes to fill
 456b           *--------------------------------------------------------------
 457b           *  BL   @XFILV
 458b           *
 459b           *  TMP0 = VDP start address
 460b           *  TMP1 = Byte to fill
 461b           *  TMP2 = Number of bytes to fill
 462b           ********@*****@*********************@**************************
 463b 6098 C13B FILV    MOV   *R11+,TMP0            ; Memory start
 464b 609A C17B         MOV   *R11+,TMP1            ; Byte to fill
 465b 609C C1BB         MOV   *R11+,TMP2            ; Repeat count        
 466b           *--------------------------------------------------------------
 467b           *    Setup VDP write address
 468b           *--------------------------------------------------------------
 469b 609E 0264 XFILV   ORI   TMP0,>4000
 469b 60A0 4000  
 470b 60A2 06C4         SWPB  TMP0
 471b 60A4 D804         MOVB  TMP0,@VDPA
 471b 60A6 8C02  
 472b 60A8 06C4         SWPB  TMP0
 473b 60AA D804         MOVB  TMP0,@VDPA
 473b 60AC 8C02  
 474b           *--------------------------------------------------------------
 475b           *    Fill bytes in VDP memory
 476b           *--------------------------------------------------------------   
 477b 60AE 020F         LI    R15,VDPW              ; Set VDP write address     
 477b 60B0 8C00  
 478b 60B2 06C5         SWPB  TMP1
 479b 60B4 C820         MOV   @FILZZ,@MCLOOP        ; Setup move command
 479b 60B6 60BE  
 479b 60B8 8320  
 480b 60BA 0460         B     @MCLOOP               ; Write data to VDP
 480b 60BC 8320  
 481b 60BE D7C5 FILZZ   DATA  >D7C5                 ; MOVB TMP1,*R15
 482b           *:..
 483b           
 484b           * CPYM2M (DATA P0,P1,P2) / XPYM2M ..:
 485b           ***************************************************************
 486b           * CPYM2M - Copy CPU memory to CPU memory
 487b           ***************************************************************
 488b           *  BL   @CPYM2M
 489b           *  DATA P0,P1,P2
 490b           *--------------------------------------------------------------
 491b           *  P0 = Memory source address
 492b           *  P1 = Memory target address
 493b           *  P2 = Number of bytes to copy
 494b           *--------------------------------------------------------------
 495b           *  BL @XPYM2M
 496b           *
 497b           *  TMP0 = Memory source address
 498b           *  TMP1 = Memory target address
 499b           *  TMP2 = Number of bytes to copy
 500b           ********@*****@*********************@**************************
 501b 60C0 C13B CPYM2M  MOV   *R11+,TMP0            ; Memory source address
 502b 60C2 C17B         MOV   *R11+,TMP1            ; Memory target address
 503b 60C4 C1BB         MOV   *R11+,TMP2            ; Number of bytes to copy        
 504b           *--------------------------------------------------------------
 505b           * Do some checks first
 506b           *-------------------------------------------------------------- 
 507b 60C6 024C XPYM2M  ANDI  CONFIG,>7FFF          ; Clear CONFIG bit 0
 507b 60C8 7FFF  
 508b 60CA C1C4         MOV   TMP0,TMP3
 509b 60CC 0247         ANDI  TMP3,1        
 509b 60CE 0001  
 510b 60D0 1618         JNE   CPYODD                ; Odd source address handling      
 511b 60D2 C1C5 CPYM1   MOV   TMP1,TMP3
 512b 60D4 0247         ANDI  TMP3,1        
 512b 60D6 0001  
 513b 60D8 1614         JNE   CPYODD                ; Odd target address handling      
 514b           *--------------------------------------------------------------
 515b           * 8 bit copy 
 516b           *-------------------------------------------------------------- 
 517b 60DA 2320 CPYM2   COC   @WBIT0,CONFIG         ; CONFIG bit 0 set ?
 517b 60DC 6026  
 518b 60DE 1605         JNE   CPYM3   
 519b 60E0 C820         MOV   @TMP011,@MCLOOP       ; Setup byte copy command
 519b 60E2 6108  
 519b 60E4 8320  
 520b 60E6 0460         B     @MCLOOP               ; Copy memory and exit
 520b 60E8 8320  
 521b           *--------------------------------------------------------------
 522b           * 16 bit copy
 523b           *--------------------------------------------------------------              
 524b 60EA C1C6 CPYM3   MOV   TMP2,TMP3
 525b 60EC 0247         ANDI  TMP3,1                ; TMP3=1 -> ODD else EVEN
 525b 60EE 0001  
 526b 60F0 1301         JEQ   CPYM4
 527b 60F2 0606         DEC   TMP2                  ; Make TMP2 even        
 528b 60F4 CD74 CPYM4   MOV   *TMP0+,*TMP1+
 529b 60F6 0646         DECT  TMP2
 530b 60F8 16FD         JNE   CPYM4
 531b           *--------------------------------------------------------------
 532b           * Copy last byte if ODD
 533b           *--------------------------------------------------------------          
 534b 60FA C1C7         MOV   TMP3,TMP3
 535b 60FC 1301         JEQ   CPYMZ
 536b 60FE D554         MOVB  *TMP0,*TMP1                
 537b 6100 045B CPYMZ   B     *R11
 538b           *--------------------------------------------------------------
 539b           * Handle odd source/target address
 540b           *--------------------------------------------------------------         
 541b 6102 026C CPYODD  ORI   CONFIG,>8000        ; Set CONFIG bot 0
 541b 6104 8000  
 542b 6106 10E9         JMP   CPYM2
 543b 6108 DD74 TMP011  DATA  >DD74               ; MOVB *TMP0+,*TMP1+        
 544b           
 545b                   
 546b           * :.. 
 547b           
 548b           * CPYM2V (DATA P0,P1,P2) / XPYM2V ..:
 549b           ***************************************************************
 550b           * CPYM2V - Copy CPU memory to VRAM
 551b           ***************************************************************
 552b           *  BL   @CPYM2V
 553b           *  DATA P0,P1,P2
 554b           *--------------------------------------------------------------
 555b           *  P0 = VDP start address
 556b           *  P1 = RAM/ROM start address
 557b           *  P2 = Number of bytes to copy
 558b           *--------------------------------------------------------------
 559b           *  BL @XPYM2V
 560b           *
 561b           *  TMP0 = VDP start address
 562b           *  TMP1 = RAM/ROM start address
 563b           *  TMP2 = Number of bytes to copy
 564b           ********@*****@*********************@**************************
 565b 610A C13B CPYM2V  MOV   *R11+,TMP0            ; VDP Start address
 566b 610C C17B         MOV   *R11+,TMP1            ; RAM/ROM start address
 567b 610E C1BB         MOV   *R11+,TMP2            ; Bytes to copy   
 568b           *--------------------------------------------------------------
 569b           *    Setup VDP write address
 570b           *--------------------------------------------------------------        
 571b 6110 0264 XPYM2V  ORI   TMP0,>4000
 571b 6112 4000  
 572b 6114 06C4         SWPB  TMP0
 573b 6116 D804         MOVB  TMP0,@VDPA
 573b 6118 8C02  
 574b 611A 06C4         SWPB  TMP0
 575b 611C D804         MOVB  TMP0,@VDPA
 575b 611E 8C02  
 576b           *--------------------------------------------------------------
 577b           *    Copy bytes from CPU memory to VRAM
 578b           *--------------------------------------------------------------                       
 579b 6120 020F         LI    R15,VDPW              ; Set VDP write address
 579b 6122 8C00  
 580b 6124 C820         MOV   @TMP008,@MCLOOP       ; Setup copy command
 580b 6126 612E  
 580b 6128 8320  
 581b 612A 0460         B     @MCLOOP               ; Write data to VDP
 581b 612C 8320  
 582b 612E D7F5 TMP008  DATA  >D7F5                 ; MOVB *TMP1+,*R15        
 583b           *:..
 584b           
 585b           * CPYV2M (DATA P0,P1,P2) / XPYV2M ..:
 586b           ***************************************************************
 587b           * CPYV2M - Copy VRAM to CPU memory
 588b           ***************************************************************
 589b           *  BL @CPYV2M
 590b           *  DATA P0,P1,P2
 591b           *--------------------------------------------------------------
 592b           *  P0 = VDP source address
 593b           *  P1 = RAM target address
 594b           *  P2 = Number of bytes to copy
 595b           *--------------------------------------------------------------
 596b           *  BL @XPYV2M
 597b           *
 598b           *  TMP0 = VDP source address
 599b           *  TMP1 = RAM target address
 600b           *  TMP2 = Number of bytes to copy
 601b           ********@*****@*********************@**************************
 602b 6130 C13B CPYV2M  MOV   *R11+,TMP0            ; VDP source address
 603b 6132 C17B         MOV   *R11+,TMP1            ; Target address in RAM
 604b 6134 C1BB         MOV   *R11+,TMP2            ; Bytes to copy
 605b           *--------------------------------------------------------------
 606b           *    Setup VDP read address
 607b           *--------------------------------------------------------------    
 608b 6136 06C4 XPYV2M  SWPB  TMP0
 609b 6138 D804         MOVB  TMP0,@VDPA
 609b 613A 8C02  
 610b 613C 06C4         SWPB  TMP0
 611b 613E D804         MOVB  TMP0,@VDPA
 611b 6140 8C02  
 612b           *--------------------------------------------------------------
 613b           *    Copy bytes from VDP memory to RAM
 614b           *--------------------------------------------------------------          
 615b 6142 020F         LI    R15,VDPR              ; Set VDP read address
 615b 6144 8800  
 616b 6146 C820         MOV   @TMP007,@MCLOOP       ; Setup copy command
 616b 6148 6150  
 616b 614A 8320  
 617b 614C 0460         B     @MCLOOP               ; Read data from VDP
 617b 614E 8320  
 618b 6150 DD5F TMP007  DATA  >DD5F                 ; MOVB *R15,*TMP+        
 619b           *:..
 620b           
 621b           * CPYG2M (DATA P0,P1,P2) / XPYG2M ..:
 622b           ***************************************************************
 623b           * CPYG2M - Copy GROM memory to CPU memory
 624b           ***************************************************************
 625b           *  BL @CPYG2M
 626b           *  DATA P0,P1,P2
 627b           *--------------------------------------------------------------
 628b           *  P0 = GROM source address
 629b           *  P1 = CPU target address
 630b           *  P2 = Number of bytes to copy
 631b           *--------------------------------------------------------------
 632b           *  BL @CPYG2M
 633b           *
 634b           *  TMP0 = GROM source address
 635b           *  TMP1 = CPU target address
 636b           *  TMP2 = Number of bytes to copy
 637b           ********@*****@*********************@**************************
 638b 6152 C13B CPYG2M  MOV   *R11+,TMP0            ; Memory source address
 639b 6154 C17B         MOV   *R11+,TMP1            ; Memory target address
 640b 6156 C1BB         MOV   *R11+,TMP2            ; Number of bytes to copy
 641b           *--------------------------------------------------------------
 642b           * Setup GROM source address
 643b           *--------------------------------------------------------------
 644b 6158 D804 XPYG2M  MOVB  TMP0,@GRMWA
 644b 615A 9C02  
 645b 615C 06C4         SWPB  TMP0
 646b 615E D804         MOVB  TMP0,@GRMWA                  
 646b 6160 9C02  
 647b           *--------------------------------------------------------------
 648b           *    Copy bytes from GROM to CPU memory
 649b           *--------------------------------------------------------------                       
 650b 6162 0204         LI    TMP0,GRMRD            ; Set TMP0 to GROM data port
 650b 6164 9800  
 651b 6166 C820         MOV   @TMP003,@MCLOOP       ; Setup copy command
 651b 6168 6170  
 651b 616A 8320  
 652b 616C 0460         B     @MCLOOP               ; Copy bytes
 652b 616E 8320  
 653b 6170 DD54 TMP003  DATA  >DD54                 ; MOVB *TMP0,*TMP1+
 654b           *:..        
 655b                             
 656b           * CPYG2V (DATA P0,P1,P2) / XPYG2V ..:
 657b           ***************************************************************
 658b           * CPYG2V - Copy GROM memory to VRAM memory
 659b           ***************************************************************
 660b           *  BL @CPYG2V
 661b           *  DATA P0,P1,P2
 662b           *--------------------------------------------------------------
 663b           *  P0 = GROM source address
 664b           *  P1 = VDP target address
 665b           *  P2 = Number of bytes to copy
 666b           *--------------------------------------------------------------
 667b           *  BL @CPYG2V
 668b           *
 669b           *  TMP0 = GROM source address
 670b           *  TMP1 = VDP target address
 671b           *  TMP2 = Number of bytes to copy
 672b           ********@*****@*********************@**************************
 673b 6172 C13B CPYG2V  MOV   *R11+,TMP0            ; Memory source address
 674b 6174 C17B         MOV   *R11+,TMP1            ; Memory target address
 675b 6176 C1BB         MOV   *R11+,TMP2            ; Number of bytes to copy
 676b           *--------------------------------------------------------------
 677b           * Setup GROM source address
 678b           *--------------------------------------------------------------
 679b 6178 D804 XPYG2V  MOVB  TMP0,@GRMWA
 679b 617A 9C02  
 680b 617C 06C4         SWPB  TMP0
 681b 617E D804         MOVB  TMP0,@GRMWA                  
 681b 6180 9C02  
 682b           *--------------------------------------------------------------
 683b           * Setup VDP target address
 684b           *--------------------------------------------------------------
 685b 6182 0265         ORI   TMP1,>4000
 685b 6184 4000  
 686b 6186 06C5         SWPB  TMP1
 687b 6188 D805         MOVB  TMP1,@VDPA
 687b 618A 8C02  
 688b 618C 06C5         SWPB  TMP1
 689b 618E D805         MOVB  TMP1,@VDPA            ; Set VDP target address
 689b 6190 8C02  
 690b           *--------------------------------------------------------------
 691b           *    Copy bytes from GROM to VDP memory
 692b           *--------------------------------------------------------------                       
 693b 6192 0207         LI    TMP3,GRMRD            ; Set TMP3 to GROM data port
 693b 6194 9800  
 694b 6196 020F         LI    R15,VDPW              ; Set VDP write address
 694b 6198 8C00  
 695b 619A C820         MOV   @TMP002,@MCLOOP       ; Setup copy command
 695b 619C 61A4  
 695b 619E 8320  
 696b 61A0 0460         B     @MCLOOP               ; Copy bytes
 696b 61A2 8320  
 697b 61A4 D7D7 TMP002  DATA  >D7D7                 ; MOVB *TMP3,*R15        
 698b           *:..
 699b           
 700b           
 701b           *//////////////////////////////////////////////////////////////
 702b           *                      VDP LOW LEVEL FUNCTIONS
 703b           *//////////////////////////////////////////////////////////////
 704b           
 705b           * VDWA   () / VDRA () ..:
 706b           ***************************************************************
 707b           * VDWA / VDRA - Setup VDP write or read address
 708b           ***************************************************************
 709b           *  BL   @VDWA
 710b           *
 711b           *  TMP0 = VDP destination address for write
 712b           *--------------------------------------------------------------
 713b           *  BL   @VDRA
 714b           *
 715b           *  TMP0 = VDP source address for read
 716b           ********@*****@*********************@**************************
 717b 61A6 0264 VDWA    ORI   TMP0,>4000            ; Prepare VDP address for write
 717b 61A8 4000  
 718b 61AA 06C4 VDRA    SWPB  TMP0
 719b 61AC D804         MOVB  TMP0,@VDPA
 719b 61AE 8C02  
 720b 61B0 06C4         SWPB  TMP0
 721b 61B2 D804         MOVB  TMP0,@VDPA            ; Set VDP address
 721b 61B4 8C02  
 722b 61B6 045B         B     *R11
 723b           * :..
 724b           
 725b           * VPUTB  (DATA P0, P1) / XVPUTB ..:
 726b           ***************************************************************
 727b           * VPUTB - VDP put single byte
 728b           ***************************************************************
 729b           *  BL @VPUTB
 730b           *  DATA P0,P1
 731b           *--------------------------------------------------------------
 732b           *  P0 = VDP target address
 733b           *  P1 = Byte to write
 734b           ********@*****@*********************@**************************
 735b 61B8 C13B VPUTB   MOV   *R11+,TMP0            ; Get VDP target address
 736b 61BA C17B         MOV   *R11+,TMP1
 737b 61BC C18B XVPUTB  MOV   R11,TMP2              ; Save R11
 738b 61BE 06A0         BL    @VDWA                 ; Set VDP write address
 738b 61C0 61A6  
 739b 61C2 06C5         SWPB  TMP1                  ; Get byte to write
 740b 61C4 D7C5         MOVB  TMP1,*R15             ; Write byte
 741b 61C6 0456         B     *TMP2                 ; Exit
 742b           *:..        
 743b           
 744b           * VGETB  (DATA P0) / XVGETB ..:
 745b           ***************************************************************
 746b           * VGETB - VDP get single byte
 747b           ***************************************************************
 748b           *  BL @VGETB
 749b           *  DATA P0
 750b           *--------------------------------------------------------------
 751b           *  P0 = VDP source address
 752b           ********@*****@*********************@**************************
 753b 61C8 C13B VGETB   MOV   *R11+,TMP0            ; Get VDP source address
 754b 61CA C18B XVGETB  MOV   R11,TMP2              ; Save R11
 755b 61CC 06A0         BL    @VDRA                 ; Set VDP read address
 755b 61CE 61AA  
 756b 61D0 D120         MOVB  @VDPR,TMP0            ; Read byte
 756b 61D2 8800  
 757b 61D4 0984         SRL   TMP0,8                ; Right align
 758b 61D6 0456         B     *TMP2                 ; Exit
 759b           *:..
 760b                   
 761b           * VIDTAB (DATA P0) / XIDTAB ..:
 762b           ***************************************************************
 763b           * VIDTAB - Dump videomode table
 764b           ***************************************************************
 765b           *  BL   @VIDTAB
 766b           *  DATA P0
 767b           *--------------------------------------------------------------
 768b           *  P0 = Address of video mode table
 769b           *--------------------------------------------------------------
 770b           *  BL   @XIDTAB
 771b           *
 772b           *  TMP0 = Address of video mode table
 773b           *--------------------------------------------------------------
 774b           *  Remarks
 775b           *  TMP1 = MSB is the VDP target register
 776b           *         LSB is the value to write
 777b           ********@*****@*********************@**************************
 778b 61D8 C13B VIDTAB  MOV   *R11+,TMP0            ; Get video mode table
 779b 61DA C394 XIDTAB  MOV   *TMP0,R14             ; Store copy of VDP#0 and #1 in RAM
 780b           *--------------------------------------------------------------
 781b           * Calculate PNT base address
 782b           *--------------------------------------------------------------
 783b 61DC C144         MOV   TMP0,TMP1
 784b 61DE 05C5         INCT  TMP1
 785b 61E0 D155         MOVB  *TMP1,TMP1            ; Get value for VDP#2
 786b 61E2 0245         ANDI  TMP1,>FF00            ; Only keep MSB
 786b 61E4 FF00  
 787b 61E6 0A25         SLA   TMP1,2                ; TMP1 *= 400
 788b 61E8 C805         MOV   TMP1,@WBASE           ; Store calculated base
 788b 61EA 8328  
 789b           *--------------------------------------------------------------
 790b           * Dump VDP shadow registers
 791b           *--------------------------------------------------------------
 792b 61EC 0205         LI    TMP1,>8000            ; Start with VDP register 0
 792b 61EE 8000  
 793b 61F0 0206         LI    TMP2,8
 793b 61F2 0008  
 794b 61F4 D834 VIDTA1  MOVB  *TMP0+,@TMP1LB        ; Write value to VDP register
 794b 61F6 830B  
 795b 61F8 06C5         SWPB  TMP1        
 796b 61FA D805         MOVB  TMP1,@VDPA        
 796b 61FC 8C02  
 797b 61FE 06C5         SWPB  TMP1
 798b 6200 D805         MOVB  TMP1,@VDPA
 798b 6202 8C02  
 799b 6204 0225         AI    TMP1,>0100
 799b 6206 0100  
 800b 6208 0606         DEC   TMP2
 801b 620A 16F4         JNE   VIDTA1                ; Next register
 802b 620C C814         MOV   *TMP0,@WCOLMN         ; Store # of columns per row
 802b 620E 833C  
 803b 6210 045B         B     *R11
 804b           *:..
 805b           
 806b           * PUTVR  (DATA P0) / PUTVRX ..:
 807b           ***************************************************************
 808b           * PUTVR  - Put single VDP register
 809b           ***************************************************************
 810b           *  BL   @PUTVR
 811b           *  DATA P0
 812b           *--------------------------------------------------------------
 813b           *  P0 = MSB is the VDP target register
 814b           *       LSB is the value to write
 815b           *--------------------------------------------------------------
 816b           *  BL   @PUTVRX
 817b           *
 818b           *  TMP0 = MSB is the VDP target register
 819b           *         LSB is the value to write
 820b           ********@*****@*********************@**************************
 821b 6212 C13B PUTVR   MOV   *R11+,TMP0
 822b 6214 0264 PUTVRX  ORI   TMP0,>8000
 822b 6216 8000  
 823b 6218 06C4         SWPB  TMP0        
 824b 621A D804         MOVB  TMP0,@VDPA        
 824b 621C 8C02  
 825b 621E 06C4         SWPB  TMP0
 826b 6220 D804         MOVB  TMP0,@VDPA
 826b 6222 8C02  
 827b 6224 045B         B     *R11
 828b           *:..
 829b           
 830b           * PUTV01 () ..:
 831b           ***************************************************************
 832b           * PUTV01  - Put VDP registers #0 and #1
 833b           ***************************************************************
 834b           *  BL   @PUTV01
 835b           ********@*****@*********************@**************************
 836b 6226 C20B PUTV01  MOV   R11,TMP4              ; Save R11
 837b 6228 C10E         MOV   R14,TMP0
 838b 622A 0984         SRL   TMP0,8
 839b 622C 06A0         BL    @PUTVRX               ; Write VR#0
 839b 622E 6214  
 840b 6230 0204         LI    TMP0,>0100
 840b 6232 0100  
 841b 6234 D820         MOVB  @R14LB,@TMP0LB
 841b 6236 831D  
 841b 6238 8309  
 842b 623A 06A0         BL    @PUTVRX               ; Write VR#1
 842b 623C 6214  
 843b 623E 0458         B     *TMP4                 ; Exit
 844b           * :..        
 845b           
 846b           * SCROFF () ..:
 847b           ***************************************************************
 848b           * SCROFF - Disable screen display
 849b           ***************************************************************
 850b           *  BL @SCROFF
 851b           ********@*****@*********************@**************************
 852b 6240 43A0 SCROFF  SZC   @WBIT9,R14            ; VDP#R1 bit 1=0 (Disable screen display)
 852b 6242 6038  
 853b 6244 10F0         JMP   PUTV01
 854b           *:..
 855b           
 856b           * SCRON  () ..:
 857b           ***************************************************************
 858b           * SCRON - Disable screen display
 859b           ***************************************************************
 860b           *  BL @SCRON
 861b           ********@*****@*********************@**************************
 862b 6246 E3A0 SCRON   SOC   @WBIT9,R14            ; VDP#R1 bit 1=1 (Enable screen display)
 862b 6248 6038  
 863b 624A 10ED         JMP   PUTV01
 864b           *:..
 865b           
 866b           * INTOFF () ..:
 867b           ***************************************************************
 868b           * INTOFF - Disable VDP interrupt
 869b           ***************************************************************
 870b           *  BL @INTOFF
 871b           ********@*****@*********************@**************************
 872b 624C 43A0 INTOFF  SZC   @WBIT10,R14           ; VDP#R1 bit 2=0 (Disable VDP interrupt)
 872b 624E 603A  
 873b 6250 10EA         JMP   PUTV01
 874b           *:..
 875b           
 876b           * INTON  () ..:
 877b           ***************************************************************
 878b           * INTON - Enable VDP interrupt
 879b           ***************************************************************
 880b           *  BL @INTON
 881b           ********@*****@*********************@**************************
 882b 6252 E3A0 INTON   SOC   @WBIT10,R14           ; VDP#R1 bit 2=1 (Enable VDP interrupt) 
 882b 6254 603A  
 883b 6256 10E7         JMP   PUTV01
 884b           *:..
 885b                   
 886b           * SMAG1X () ..:
 887b           ***************************************************************
 888b           * SMAG1X - Set sprite magnification 1x
 889b           ***************************************************************
 890b           *  BL @SMAG1X
 891b           ********@*****@*********************@**************************
 892b 6258 43A0 SMAG1X  SZC   @WBIT14,R14           ; VDP#R1 bit 7=0 (Sprite magnification 1x)
 892b 625A 6042  
 893b 625C 10E4         JMP   PUTV01
 894b           *:..
 895b           
 896b           * SMAG2X () ..:
 897b           ***************************************************************
 898b           * SMAG2X - Set sprite magnification 2x
 899b           ***************************************************************
 900b           *  BL @SMAG2X
 901b           ********@*****@*********************@**************************
 902b 625E 43A0 SMAG2X  SZC   @WBIT14,R14           ; VDP#R1 bit 7=1 (Sprite magnification 2x)
 902b 6260 6042  
 903b 6262 10E1         JMP   PUTV01
 904b           *:..
 905b           
 906b           * S8X8   () ..:
 907b           ***************************************************************
 908b           * S8X8 - Set sprite size 8x8 bits
 909b           ***************************************************************
 910b           *  BL @S8X8
 911b           ********@*****@*********************@**************************
 912b 6264 43A0 S8X8    SZC   @WBIT12,R14           ; VDP#R1 bit 6=0 (Sprite size 8x8)
 912b 6266 603E  
 913b 6268 10DE         JMP   PUTV01
 914b           *:..
 915b           
 916b           * S16X16 () ..:
 917b           ***************************************************************
 918b           * S16X16 - Set sprite size 16x16 bits
 919b           ***************************************************************
 920b           *  BL @S16X16
 921b           ********@*****@*********************@**************************
 922b 626A E3A0 S16X16  SOC   @WBIT12,R14           ; VDP#R1 bit 6=1 (Sprite size 16x16)
 922b 626C 603E  
 923b 626E 10DB         JMP   PUTV01
 924b           *:..  
 925b                   
 926b           * YX2PNT (@YX) ..:
 927b           ***************************************************************
 928b           * YX2PNT - Get VDP PNT address for current YX cursor position
 929b           ***************************************************************
 930b           *  BL   @YX2PNT
 931b           *--------------------------------------------------------------
 932b           *  INPUT
 933b           *  @WYX = Cursor YX position
 934b           *--------------------------------------------------------------
 935b           *  OUTPUT
 936b           *  TMP0 = VDP address for entry in Pattern Name Table
 937b           *--------------------------------------------------------------
 938b           *  Register usage
 939b           *  TMP0, R14, R15
 940b           ********@*****@*********************@**************************
 941b 6270 C10E YX2PNT  MOV   R14,TMP0              ; Save VDP#0 & VDP#1
 942b 6272 C3A0         MOV   @WYX,R14              ; Get Y
 942b 6274 832A  
 943b 6276 098E         SRL   R14,8                 ; Right justify
 944b 6278 3BA0         MPY   @WCOLMN,R14           ; pos = Y * (columns per row)
 944b 627A 833C  
 945b           *--------------------------------------------------------------
 946b           * Do rest of calculation with R15
 947b           *--------------------------------------------------------------        
 948b 627C B820         AB    @BX,@R15LB            ; pos = pos + X
 948b 627E 832B  
 948b 6280 831F  
 949b 6282 A3E0         A     @WBASE,R15            ; pos = pos + (PNT base address)        
 949b 6284 8328  
 950b           *--------------------------------------------------------------
 951b           * Clean up before exit
 952b           *--------------------------------------------------------------         
 953b 6286 C384         MOV   TMP0,R14              ; Restore VDP#0 & VDP#1
 954b 6288 C10F         MOV   R15,TMP0              ; Return pos in TMP0
 955b 628A 020F         LI    R15,VDPW              ; Set VDP write address
 955b 628C 8C00  
 956b 628E 045B         B     *R11
 957b           * :..
 958b                   
 959b           * YX2PX  (@YX) / YX2PXX ..:
 960b           ***************************************************************
 961b           * YX2PX - Get pixel position for cursor YX position
 962b           ***************************************************************
 963b           *  BL   @YX2PX
 964b           *
 965b           *  (CONFIG:0 = 1) = Skip sprite adjustment
 966b           *--------------------------------------------------------------
 967b           *  INPUT
 968b           *  @WYX   = Cursor YX position
 969b           *--------------------------------------------------------------
 970b           *  OUTPUT
 971b           *  TMP0HB = Y pixel position
 972b           *  TMP0LB = X pixel position
 973b           *--------------------------------------------------------------
 974b           *  Remarks
 975b           *  This subroutine does not support multicolor or text mode
 976b           ********@*****@*********************@**************************
 977b 6290 C120 YX2PX   MOV   @WYX,TMP0
 977b 6292 832A  
 978b 6294 C18B YX2PXX  MOV   R11,TMP2              ; Save return address        
 979b 6296 06C4         SWPB  TMP0                  ; Y<->X
 980b 6298 04C5         CLR   TMP1                  ; Clear before copy
 981b 629A D144         MOVB  TMP0,TMP1             ; Copy X to TMP1
 982b 629C 0A35         SLA   TMP1,3                ; X=X*8        
 983b 629E 0A34         SLA   TMP0,3                ; Y=Y*8
 984b 62A0 D105         MOVB  TMP1,TMP0
 985b 62A2 06C4         SWPB  TMP0                  ; X<->Y        
 986b 62A4 2320 YX2PI1  COC   @WBIT0,CONFIG         ; Skip sprite adjustment ?
 986b 62A6 6026  
 987b 62A8 1305         JEQ   YX2PI3                ; Yes, exit
 988b           *--------------------------------------------------------------
 989b           * Adjust for Y sprite location
 990b           * See VDP Programmers Guide, Section 9.2.1
 991b           *--------------------------------------------------------------
 992b 62AA 7120 YX2PI2  SB    @BD1,TMP0             ; Adjust Y. Top of screen is at >FF
 992b 62AC 6049  
 993b 62AE 9120         CB    @BD208,TMP0           ; Y position = >D0 ?
 993b 62B0 6052  
 994b 62B2 13FB         JEQ   YX2PI2                ; Yes, but that's not allowed, correct
 995b 62B4 0456 YX2PI3  B     *TMP2                 ; Exit
 996b 62B6 2000 BDIG32  DATA  >2000
 997b           * :..
 998b           
 999b           * PX2YX  () ..:
1000b           ***************************************************************
1001b           * PX2YX - Get YX tile position for specified YX pixel position
1002b           ***************************************************************
1003b           *  BL   @PX2YX
1004b           *--------------------------------------------------------------
1005b           *  INPUT
1006b           *  TMP0   = Pixel YX position
1007b           *
1008b           *  (CONFIG:0 = 1) = Skip sprite adjustment
1009b           *--------------------------------------------------------------
1010b           *  OUTPUT
1011b           *  TMP0HB = Y tile position
1012b           *  TMP0LB = X tile position
1013b           *  TMP1HB = Y pixel offset
1014b           *  TMP1LB = X pixel offset
1015b           *--------------------------------------------------------------
1016b           *  Remarks
1017b           *  This subroutine does not support multicolor or text mode
1018b           ********@*****@*********************@**************************
1019b 62B8 2320 PX2YX   COC   @WBIT0,CONFIG         ; Skip sprite adjustment ?
1019b 62BA 6026  
1020b 62BC 1302         JEQ   PX2YX1
1021b 62BE 0224         AI    TMP0,>0100            ; Adjust Y. Top of screen is at >FF
1021b 62C0 0100  
1022b 62C2 C144 PX2YX1  MOV   TMP0,TMP1             ; Copy YX
1023b 62C4 C184         MOV   TMP0,TMP2             ; Copy YX
1024b           *--------------------------------------------------------------
1025b           * Calculate Y tile position 
1026b           *--------------------------------------------------------------
1027b 62C6 09B4         SRL   TMP0,11               ; Y: Move to TMP0LB & (Y = Y / 8)
1028b           *--------------------------------------------------------------
1029b           * Calculate Y pixel offset
1030b           *--------------------------------------------------------------
1031b 62C8 C1C4         MOV   TMP0,TMP3             ; Y: Copy Y tile to TMP3LB
1032b 62CA 0AB7         SLA   TMP3,11               ; Y: Move to TMP3HB & (Y = Y * 8)
1033b 62CC 0507         NEG   TMP3
1034b 62CE B1C5         AB    TMP1,TMP3             ; Y: offset = Y pixel old + (-Y) pixel new
1035b           *--------------------------------------------------------------
1036b           * Calculate X tile position
1037b           *--------------------------------------------------------------
1038b 62D0 0245         ANDI  TMP1,>00FF            ; Clear TMP1HB
1038b 62D2 00FF  
1039b 62D4 0A55         SLA   TMP1,5                ; X: Move to TMP1HB & (X = X / 8)
1040b 62D6 D105         MOVB  TMP1,TMP0             ; X: TMP0 <-- XY tile position
1041b 62D8 06C4         SWPB  TMP0                  ; XY tile position <-> YX tile position
1042b           *--------------------------------------------------------------
1043b           * Calculate X pixel offset
1044b           *--------------------------------------------------------------
1045b 62DA 0245         ANDI  TMP1,>FF00            ; X: Get rid of remaining junk in TMP1LB
1045b 62DC FF00  
1046b 62DE 0A35         SLA   TMP1,3                ; X: (X = X * 8)
1047b 62E0 0505         NEG   TMP1
1048b 62E2 06C6         SWPB  TMP2                  ; YX <-> XY                
1049b 62E4 B146         AB    TMP2,TMP1             ; offset X = X pixel old  + (-X) pixel new
1050b 62E6 06C5         SWPB  TMP1                  ; X0 <-> 0X
1051b 62E8 D147         MOVB  TMP3,TMP1             ; 0X --> YX
1052b 62EA 045B         B     *R11                  ; Exit
1053b           * :..
1054b           
1055b           * SCRDIM (DATA P0,P1) ..:
1056b           ***************************************************************
1057b           * SCRDIM - Set (virtual) screen dimension
1058b           ***************************************************************
1059b           *  BL   @SCRDIM
1060b           *--------------------------------------------------------------
1061b           *  INPUT
1062b           *  P0 = PNT base address
1063b           *  P1 = Number of columns per row
1064b           ********@*****@*********************@**************************
1065b 62EC C83B SCRDIM  MOV   *R11+,@WBASE          ; VDP destination address
1065b 62EE 8328  
1066b 62F0 C83B         MOV   *R11+,@WCOLMN         ; Number of columns per row
1066b 62F2 833C  
1067b 62F4 045B         B     *R11                  ; Exit
1068b           * :..
1069b           
1070b                   
1071b           *//////////////////////////////////////////////////////////////
1072b           *                      VDP TILE FUNCTIONS
1073b           *//////////////////////////////////////////////////////////////
1074b           
1075b           * LDFNT  (DATA P0,P1) ..:
1076b           ***************************************************************
1077b           *  - Load TI-99/4A font from GROM into VDP
1078b           ***************************************************************
1079b           *  BL   @LDFNT
1080b           *  DATA P0,P1
1081b           *--------------------------------------------------------------
1082b           *  P0 = VDP Target address
1083b           *  P1 = Font options
1084b           ********@*****@*********************@**************************
1085b 62F6 C20B LDFNT   MOV   R11,TMP4              ; Save R11
1086b 62F8 05CB         INCT  R11                   ; Get 2nd parameter (font options)
1087b 62FA C11B         MOV   *R11,TMP0             ; Get parameter value
1088b 62FC 024C         ANDI  CONFIG,>7FFF          ; CONFIG register bit 0=0
1088b 62FE 7FFF  
1089b 6300 2120         COC   @WBIT0,TMP0
1089b 6302 6026  
1090b 6304 1604         JNE   LDFNT1
1091b 6306 026C         ORI   CONFIG,>8000          ; CONFIG register bit 0=1            
1091b 6308 8000  
1092b 630A 0244         ANDI  TMP0,>7FFF            ; Parameter value bit 0=0         
1092b 630C 7FFF  
1093b 630E C124 LDFNT1  MOV   @TMP006(TMP0),TMP0    ; Load GROM index address ...
1093b 6310 636E  
1094b 6312 0205         LI    TMP1,TMP3HB           ; ... into register TMP3
1094b 6314 830E  
1095b 6316 0206         LI    TMP2,2
1095b 6318 0002  
1096b 631A 06A0         BL    @XPYG2M               ; Get font table address
1096b 631C 6158  
1097b           *--------------------------------------------------------------
1098b           * Setup GROM source and VDP target address
1099b           *--------------------------------------------------------------
1100b 631E D807         MOVB  TMP3,@GRMWA
1100b 6320 9C02  
1101b 6322 06C7         SWPB  TMP3
1102b 6324 D807         MOVB  TMP3,@GRMWA           ; Setup GROM address for reading                
1102b 6326 9C02  
1103b 6328 C118         MOV   *TMP4,TMP0            ; Get 1st parameter (VDP destination)
1104b 632A 06A0         BL    @VDWA                 ; Setup VDP destination address         
1104b 632C 61A6  
1105b 632E 05C8         INCT  TMP4                  ; R11=R11+2
1106b 6330 C158         MOV   *TMP4,TMP1            ; Get font options into TMP1
1107b 6332 0245         ANDI  TMP1,>7FFF            ; Parameter value bit 0=0    
1107b 6334 7FFF  
1108b 6336 C1A5         MOV   @TMP006+2(TMP1),TMP2  ; Get number of patterns to copy
1108b 6338 6370  
1109b 633A C165         MOV   @TMP006+4(TMP1),TMP1  ; 7 or 8 byte pattern ?
1109b 633C 6372  
1110b           *--------------------------------------------------------------
1111b           * Copy from GROM to VRAM
1112b           *--------------------------------------------------------------
1113b 633E 0B15 LDFNT2  SRC   TMP1,1                ; Carry set ?
1114b 6340 1812         JOC   LDFNT4                ; Yes, go insert a >00
1115b 6342 D120         MOVB  @GRMRD,TMP0
1115b 6344 9800  
1116b           *--------------------------------------------------------------
1117b           *   Make font fat
1118b           *--------------------------------------------------------------         
1119b 6346 2320         COC   @WBIT0,CONFIG         ; Fat flag set ?
1119b 6348 6026  
1120b 634A 1603         JNE   LDFNT3                ; No, so skip         
1121b 634C D3C4         MOVB  TMP0,TMP6
1122b 634E 091F         SRL   TMP6,1
1123b 6350 E10F         SOC   TMP6,TMP0                  
1124b           *-------------------------------------------------------------
1125b           *   Dump byte to VDP and do housekeeping
1126b           *--------------------------------------------------------------
1127b 6352 D804 LDFNT3  MOVB  TMP0,@VDPW            ; Dump byte to VRAM
1127b 6354 8C00  
1128b 6356 0606         DEC   TMP2
1129b 6358 16F2         JNE   LDFNT2
1130b 635A 05C8         INCT  TMP4                  ; R11=R11+2
1131b 635C 020F         LI    R15,VDPW              ; Set VDP write address
1131b 635E 8C00  
1132b 6360 024C         ANDI  CONFIG,>7FFF          ; CONFIG register bit 0=0
1132b 6362 7FFF  
1133b 6364 0458         B     *TMP4                 ; Exit
1134b 6366 D820 LDFNT4  MOVB  @BD0,@VDPW            ; Insert byte >00 into VRAM
1134b 6368 6048  
1134b 636A 8C00  
1135b 636C 10E8         JMP   LDFNT2
1136b 636E 004C TMP006  DATA  >004C,64*8,>0000      ; Pointer to TI title screen font
1136b 6370 0200  
1136b 6372 0000  
1137b 6374 004E         DATA  >004E,64*7,>0101      ; Pointer to upper case font
1137b 6376 01C0  
1137b 6378 0101  
1138b 637A 004E         DATA  >004E,96*7,>0101      ; Pointer to upper & lower case font
1138b 637C 02A0  
1138b 637E 0101  
1139b 6380 0050         DATA  >0050,32*7,>0101      ; Pointer to lower case font 
1139b 6382 00E0  
1139b 6384 0101  
1140b           *:..
1141b           
1142b           * PUTSTR (DATA P0) / XUTSTR ..:
1143b           ***************************************************************
1144b           * Put length-byte prefixed string at current YX
1145b           ***************************************************************
1146b           *  BL   @PUTSTR
1147b           *  DATA P0
1148b           *
1149b           *  P0 = Pointer to string
1150b           *--------------------------------------------------------------
1151b           *  REMARKS
1152b           *  First byte of string must contain length
1153b           ********@*****@*********************@**************************
1154b 6386 C17B PUTSTR  MOV   *R11+,TMP1
1155b 6388 D1B5         MOVB  *TMP1+,TMP2           ; Get length byte
1156b 638A C1CB XUTSTR  MOV   R11,TMP3
1157b 638C 06A0         BL    @YX2PNT               ; Get VDP destination address
1157b 638E 6270  
1158b 6390 C2C7         MOV   TMP3,R11        
1159b 6392 0986         SRL   TMP2,8                ; Right justify length byte        
1160b 6394 0460         B     @XPYM2V               ; Display string
1160b 6396 6110  
1161b           *:..
1162b           
1163b           * PUTAT  (DATA P0) ..:
1164b           ***************************************************************
1165b           * Put length-byte prefixed string at YX
1166b           ***************************************************************
1167b           *  BL   @PUTAT
1168b           *  DATA P0,P1
1169b           *
1170b           *  P0 = YX position
1171b           *  P1 = Pointer to string
1172b           *--------------------------------------------------------------
1173b           *  REMARKS
1174b           *  First byte of string must contain length
1175b           ********@*****@*********************@**************************
1176b 6398 C83B PUTAT   MOV   *R11+,@WYX            ; Set YX position
1176b 639A 832A  
1177b 639C 0460         B     @PUTSTR     
1177b 639E 6386  
1178b           *:..
1179b           
1180b           * HCHAR  (DATA P0,P1,...,EOL) ..:
1181b           ***************************************************************
1182b           * Repeat characters horizontally at YX
1183b           ***************************************************************
1184b           *  BL    @HCHAR
1185b           *  DATA  P0,P1
1186b           *  ...
1187b           *  DATA  EOL                        ; End-of-list
1188b           *--------------------------------------------------------------
1189b           *  P0HB = Y position
1190b           *  P0LB = X position
1191b           *  P1HB = Byte to write
1192b           *  P1LB = Number of times to repeat
1193b           ********@*****@*********************@**************************
1194b 63A0 C83B HCHAR   MOV   *R11+,@WYX            ; Set YX position
1194b 63A2 832A  
1195b 63A4 D17B         MOVB  *R11+,TMP1
1196b 63A6 0985         SRL   TMP1,8                ; Byte to write
1197b 63A8 D1BB         MOVB  *R11+,TMP2
1198b 63AA 0986         SRL   TMP2,8                ; Repeat count
1199b 63AC C1CB         MOV   R11,TMP3
1200b 63AE 06A0         BL    @YX2PNT               ; Get VDP address into TMP0
1200b 63B0 6270  
1201b           *--------------------------------------------------------------
1202b           *    Draw line
1203b           *--------------------------------------------------------------         
1204b 63B2 020B         LI    R11,HCHAR1  
1204b 63B4 63BA  
1205b 63B6 0460         B     @XFILV                ; Draw
1205b 63B8 609E  
1206b           *--------------------------------------------------------------
1207b           *    Do housekeeping
1208b           *--------------------------------------------------------------        
1209b 63BA 8817 HCHAR1  C     *TMP3,@WHFFFF         ; End-Of-List marker found ?
1209b 63BC 6046  
1210b 63BE 1302         JEQ   HCHAR2                ; Yes, exit
1211b 63C0 C2C7         MOV   TMP3,R11
1212b 63C2 10EE         JMP   HCHAR                 ; Next one
1213b 63C4 05C7 HCHAR2  INCT  TMP3
1214b 63C6 0457         B     *TMP3                 ; Exit
1215b           *:..
1216b           
1217b           * VCHAR  (DATA P0,P1,...,EOL) ..:
1218b           ***************************************************************
1219b           * Repeat characters vertically at YX
1220b           ***************************************************************
1221b           *  BL    @VCHAR
1222b           *  DATA  P0,P1
1223b           *  ...
1224b           *  DATA  EOL                        ; End-of-list
1225b           *--------------------------------------------------------------
1226b           *  P0HB = Y position
1227b           *  P0LB = X position
1228b           *  P1HB = Byte to write
1229b           *  P1LB = Number of times to repeat
1230b           ********@*****@*********************@**************************
1231b 63C8 C83B VCHAR   MOV   *R11+,@WYX            ; Set YX position
1231b 63CA 832A  
1232b 63CC C1CB         MOV   R11,TMP3              ; Save R11 in TMP3
1233b 63CE C220 VCHAR1  MOV   @WCOLMN,TMP4          ; Get columns per row
1233b 63D0 833C  
1234b 63D2 06A0         BL    @YX2PNT               ; Get VDP address into TMP0        
1234b 63D4 6270  
1235b 63D6 D177         MOVB  *TMP3+,TMP1           ; Byte to write        
1236b 63D8 D1B7         MOVB  *TMP3+,TMP2
1237b 63DA 0986         SRL   TMP2,8                ; Repeat count        
1238b           *--------------------------------------------------------------
1239b           *    Setup VDP write address
1240b           *--------------------------------------------------------------
1241b 63DC 0264 VCHAR2  ORI   TMP0,>4000
1241b 63DE 4000  
1242b 63E0 06C4 VCHAR3  SWPB  TMP0
1243b 63E2 D804         MOVB  TMP0,@VDPA
1243b 63E4 8C02  
1244b 63E6 06C4         SWPB  TMP0
1245b 63E8 D804         MOVB  TMP0,@VDPA
1245b 63EA 8C02  
1246b           *--------------------------------------------------------------
1247b           *    Dump tile to VDP and do housekeeping
1248b           *--------------------------------------------------------------
1249b 63EC D7C5         MOVB  TMP1,*R15             ; Dump tile to VDP
1250b 63EE A108         A     TMP4,TMP0             ; Next row
1251b 63F0 0606         DEC   TMP2
1252b 63F2 16F6         JNE   VCHAR3        
1253b 63F4 8817         C     *TMP3,@WHFFFF         ; End-Of-List marker found ?
1253b 63F6 6046  
1254b 63F8 1303         JEQ   VCHAR4                ; Yes, exit
1255b 63FA C837         MOV   *TMP3+,@WYX           ; Save YX position
1255b 63FC 832A  
1256b 63FE 10E7         JMP   VCHAR1                ; Next one
1257b 6400 05C7 VCHAR4  INCT  TMP3       
1258b 6402 0457         B     *TMP3                 ; Exit
1259b           *:..        
1260b           
1261b           * FILBOX (DATA P0,P1,P2,...,EOL) ..:
1262b           ***************************************************************
1263b           * FILBOX - Fill box with character
1264b           ***************************************************************
1265b           *  BL   @FILBOX
1266b           *  DATA P0,P1,P2
1267b           *  ...
1268b           *  DATA EOL
1269b           *--------------------------------------------------------------
1270b           *  P0HB = Upper left corner Y
1271b           *  P0LB = Upper left corner X
1272b           *  P1HB = Width
1273b           *  P1LB = Height
1274b           *  P2HB = >00
1275b           *  P2LB = Character to fill
1276b           ********@*****@*********************@**************************
1277b 6404 C83B FILBOX  MOV   *R11+,@WYX            ; Upper left corner
1277b 6406 832A  
1278b 6408 D1BB         MOVB  *R11+,TMP2            ; Width in TMP2
1279b 640A D1FB         MOVB  *R11+,TMP3            ; Height in TMP3        
1280b 640C C17B         MOV   *R11+,TMP1            ; Byte to fill       
1281b 640E C20B         MOV   R11,TMP4              ; Save R11
1282b 6410 0986         SRL   TMP2,8                ; Right-align width
1283b 6412 0987         SRL   TMP3,8                ; Right-align height
1284b           *--------------------------------------------------------------
1285b           *  Do single row
1286b           *--------------------------------------------------------------           
1287b 6414 06A0 FILBO1  BL    @YX2PNT               ; Get VDP address into TMP0
1287b 6416 6270  
1288b 6418 020B         LI    R11,FILBO2            ; New return address  
1288b 641A 6420  
1289b 641C 0460         B     @XFILV                ; Fill VRAM with byte
1289b 641E 609E  
1290b           *--------------------------------------------------------------
1291b           *  Recover width & character
1292b           *--------------------------------------------------------------          
1293b 6420 C108 FILBO2  MOV   TMP4,TMP0
1294b 6422 0224         AI    TMP0,-4               ; R11 - 4
1294b 6424 FFFC  
1295b 6426 C1B4         MOV   *TMP0+,TMP2           ; Get Width/Height
1296b 6428 0986         SRL   TMP2,8                ; Right align
1297b 642A C154         MOV   *TMP0,TMP1            ; Get character to fill
1298b           *--------------------------------------------------------------
1299b           *  Housekeeping
1300b           *--------------------------------------------------------------           
1301b 642C A820         A     @WH100,@BY            ; Y=Y+1
1301b 642E 6034  
1301b 6430 832A  
1302b 6432 0607         DEC   TMP3
1303b 6434 15EF         JGT   FILBO1                ; Process next row        
1304b 6436 8818         C     *TMP4,@WHFFFF         ; End-Of-List marker found ?
1304b 6438 6046  
1305b 643A 1302         JEQ   FILBO3                ; Yes, exit
1306b 643C C2C8         MOV   TMP4,R11
1307b 643E 10E2         JMP   FILBOX                ; Next one
1308b 6440 05C8 FILBO3  INCT  TMP4
1309b 6442 0458         B     *TMP4                 ; Exit
1310b           *:..
1311b           
1312b           * PUTBOX (DATA P0,P1,P2,...,EOL) ..:
1313b           ***************************************************************
1314b           * PUTBOX - Put tiles in box
1315b           ***************************************************************
1316b           *  BL   @PUTBOX
1317b           *  DATA P0,P1,P2
1318b           *  ...
1319b           *  DATA EOL
1320b           *--------------------------------------------------------------
1321b           *  P0HB = Upper left corner Y
1322b           *  P0LB = Upper left corner X
1323b           *  P1HB = Width
1324b           *  P1LB = Height
1325b           *  P2   = Pointer to length-byte prefixed string
1326b           ********@*****@*********************@**************************
1327b 6444 C83B PUTBOX  MOV   *R11+,@WYX            ; Upper left corner
1327b 6446 832A  
1328b 6448 D1BB         MOVB  *R11+,TMP2            ; Width in TMP2
1329b 644A D1FB         MOVB  *R11+,TMP3            ; Height in TMP3        
1330b 644C C17B         MOV   *R11+,TMP1            ; Pointer to string
1331b 644E C20B         MOV   R11,TMP4              ; Save R11        
1332b 6450 B1A0         AB    @BX,TMP2
1332b 6452 832B  
1333b 6454 B1E0         AB    @BY,TMP3                
1333b 6456 832A  
1334b 6458 024C         ANDI  CONFIG,>7FFF          ; Reset bit 0 (state flag)
1334b 645A 7FFF  
1335b           *--------------------------------------------------------------
1336b           *  Setup VDP write address
1337b           *--------------------------------------------------------------        
1338b 645C 06A0 PUTBO1  BL    @YX2PNT               ; Get VDP address into TMP0
1338b 645E 6270  
1339b 6460 06A0         BL    @VDWA                 ; Set VDP write address
1339b 6462 61A6  
1340b           *--------------------------------------------------------------
1341b           *  Prepare string for processing
1342b           *--------------------------------------------------------------
1343b 6464 2320         COC   @WBIT0,CONFIG         ; state flag 0 set ?
1343b 6466 6026  
1344b 6468 1303         JEQ   PUTBO2                ; Yes, so skip
1345b 646A D135         MOVB  *TMP1+,TMP0           ; Get length byte
1346b 646C 0984         SRL   TMP0,8                ; Right justify
1347b 646E 1005         JMP   PUTBO3
1348b 6470 C106 PUTBO2  MOV   TMP2,TMP0             ; Recover counter
1349b 6472 0244         ANDI  TMP0,>00FF            ; Counter is in LB
1349b 6474 00FF  
1350b 6476 0246         ANDI  TMP2,>FF00            ; Only keep with in TMP2
1350b 6478 FF00  
1351b           *--------------------------------------------------------------
1352b           *  Write line of tiles in box
1353b           *--------------------------------------------------------------                
1354b 647A D7F5 PUTBO3  MOVB  *TMP1+,*R15           ; Write to VDP
1355b 647C 0604         DEC   TMP0                  
1356b 647E 1316         JEQ   PUTBO6                ; End of string, reset to begin
1357b           *--------------------------------------------------------------
1358b           *  Adjust cursor
1359b           *--------------------------------------------------------------         
1360b 6480 05A0 PUTBO4  INC   @WYX                  ; X=X+1
1360b 6482 832A  
1361b 6484 91A0         CB    @BX,TMP2              ; Right boundary reached ?
1361b 6486 832B  
1362b 6488 11F8         JLT   PUTBO3                ; Not yet, continue
1363b 648A A820         A     @WH100,@BY            ; Y=Y+1        
1363b 648C 6034  
1363b 648E 832A  
1364b 6490 91E0         CB    @BY,TMP3              ; Bottom boundary reached ?
1364b 6492 832A  
1365b 6494 1312         JEQ   PUTBO7                ; Yes, exit
1366b           *--------------------------------------------------------------
1367b           *  Recover starting column
1368b           *-------------------------------------------------------------- 
1369b 6496 D820         MOVB  @TMP0LB,@TMP2LB       ; Save counter
1369b 6498 8309  
1369b 649A 830D  
1370b 649C C108         MOV   TMP4,TMP0        
1371b 649E 0224         AI    TMP0,-5
1371b 64A0 FFFB  
1372b 64A2 D814         MOVB  *TMP0,@BX             ; Recover X
1372b 64A4 832B  
1373b 64A6 026C         ORI   CONFIG,>8000          ; CONFIG register bit 0=1 
1373b 64A8 8000  
1374b 64AA 10D8         JMP   PUTBO1                ; Draw next line           
1375b           *--------------------------------------------------------------
1376b           *  Recover string pointer
1377b           *--------------------------------------------------------------          
1378b 64AC C108 PUTBO6  MOV   TMP4,TMP0
1379b 64AE 0224         AI    TMP0,-2               ; R11 - 2        
1379b 64B0 FFFE  
1380b 64B2 C154         MOV   *TMP0,TMP1            ; Get string pointer
1381b 64B4 D135         MOVB  *TMP1+,TMP0           ; Get length byte
1382b 64B6 0984         SRL   TMP0,8                ; Right justify
1383b 64B8 10E3         JMP   PUTBO4                ; Adjust cursor
1384b 64BA 8818 PUTBO7  C     *TMP4,@WHFFFF         ; End-Of-List marker found ?
1384b 64BC 6046  
1385b 64BE 1302         JEQ   PUTBO8                ; Yes, exit
1386b 64C0 C2C8         MOV   TMP4,R11
1387b 64C2 10C0         JMP   PUTBOX                ; Next one
1388b 64C4 024C PUTBO8  ANDI  CONFIG,>7FFF          ; CONFIG register bit 0=0
1388b 64C6 7FFF  
1389b 64C8 0458         B     *TMP4                 ; Exit
1390b           *:..
1391b           
1392b           * MKNUM  (DATA P0,P1,P2) ..:
1393b           ***************************************************************
1394b           * MKNUM - Convert unsigned number to string
1395b           ***************************************************************
1396b           *  BL   @MKNUM
1397b           *  DATA P0,P1,P2
1398b           *
1399b           *  P0   = Pointer to 16 bit unsigned number
1400b           *  P1   = Pointer to 5 byte string buffer
1401b           *  P2HB = Offset for ASCII digit
1402b           *  P2LB = Character for replacing leading 0's
1403b           *
1404b           *  (CONFIG:0 = 1) = Display number at cursor YX
1405b           ********@*****@*********************@**************************
1406b 64CA 0207 MKNUM   LI    TMP3,5                ; Digit counter
1406b 64CC 0005  
1407b 64CE C17B         MOV   *R11+,TMP1            ; \ Get 16 bit unsigned number
1408b 64D0 C155         MOV   *TMP1,TMP1            ; /
1409b 64D2 C23B         MOV   *R11+,TMP4            ; Pointer to string buffer        
1410b 64D4 0228         AI    TMP4,4                ; Get end of buffer
1410b 64D6 0004  
1411b 64D8 0206         LI    TMP2,10               ; Divide by 10 to isolate last digit
1411b 64DA 000A  
1412b           *--------------------------------------------------------------
1413b           *  Do string conversion
1414b           *--------------------------------------------------------------  
1415b 64DC 04C4 MKNUM1  CLR   TMP0                  ; Clear the high word of the dividend
1416b 64DE 3D06         DIV   TMP2,TMP0             ; (TMP0:TMP1) / 10 (TMP2)
1417b 64E0 06C5         SWPB  TMP1                  ; Move to high-byte for writing to buffer        
1418b 64E2 B15B         AB    *R11,TMP1             ; Add offset for ASCII digit        
1419b 64E4 D605         MOVB  TMP1,*TMP4            ; Write remainder to string buffer
1420b 64E6 C144         MOV   TMP0,TMP1             ; Move integer result into R4 for the next digit
1421b 64E8 0608         DEC   TMP4                  ; Adjust string pointer for next digit
1422b 64EA 0607         DEC   TMP3                  ; Decrease counter
1423b 64EC 16F7         JNE   MKNUM1                ; Do next digit
1424b           *--------------------------------------------------------------
1425b           *  Replace leading 0's with fill character
1426b           *--------------------------------------------------------------
1427b 64EE 0207         LI    TMP3,4                ; Check first 4 digits
1427b 64F0 0004  
1428b 64F2 0588         INC   TMP4                  ; Too far, back to buffer start
1429b 64F4 C11B         MOV   *R11,TMP0
1430b 64F6 0A84         SLA   TMP0,8                ; Only keep fill character in HB
1431b 64F8 96D8 MKNUM2  CB    *TMP4,*R11            ; Digit = 0 ?
1432b 64FA 1305         JEQ   MKNUM4                ; Yes, replace with fill character
1433b 64FC 05CB MKNUM3  INCT  R11
1434b 64FE 2320         COC   @WBIT0,CONFIG         ; Check if 'display' bit is set
1434b 6500 6026  
1435b 6502 1305         JEQ   MKNUM5                ; Yes, so show at current YX position
1436b 6504 045B         B     *R11                  ; Exit
1437b 6506 DE04 MKNUM4  MOVB  TMP0,*TMP4+           ; Replace leading 0 with fill character
1438b 6508 0607         DEC   TMP3                  ; 4th digit processed ?
1439b 650A 13F8         JEQ   MKNUM3                ; Yes, exit
1440b 650C 10F5         JMP   MKNUM2                ; No, next one
1441b           *--------------------------------------------------------------
1442b           *  Display integer on screen at current YX position
1443b           *--------------------------------------------------------------        
1444b 650E 024C MKNUM5  ANDI  CONFIG,>7FFF          ; Reset bit 0
1444b 6510 7FFF  
1445b 6512 C10B         MOV   R11,TMP0
1446b 6514 0224         AI    TMP0,-4
1446b 6516 FFFC  
1447b 6518 C154         MOV   *TMP0,TMP1            ; Get buffer address
1448b 651A 0206         LI    TMP2,>0500            ; String length = 5
1448b 651C 0500  
1449b 651E 0460         B     @XUTSTR               ; Display string
1449b 6520 638A  
1450b                   
1451b           * :..
1452b           
1453b           * PUTNUM (DATA P0,P1,P2,P3) ..:
1454b           ***************************************************************
1455b           * PUTNUM - Put unsigned number on screen 
1456b           ***************************************************************
1457b           *  BL   @PUTNUM
1458b           *  DATA P0,P1,P2,P3
1459b           *--------------------------------------------------------------
1460b           *  P0   = YX position
1461b           *  P1   = Pointer to 16 bit unsigned number
1462b           *  P2   = Pointer to 5 byte string buffer
1463b           *  P3HB = Offset for ASCII digit
1464b           *  P3LB = Character for replacing leading 0's
1465b           ********@*****@*********************@**************************
1466b 6522 C83B PUTNUM  MOV   *R11+,@WYX            ; Set cursor
1466b 6524 832A  
1467b 6526 026C         ORI   CONFIG,>8000          ; CONFIG register bit 0=1
1467b 6528 8000  
1468b 652A 10CF         JMP   MKNUM                 ; Convert number and display
1469b           *:..
1470b           
1471b           
1472b           
1473b                   
1474b           *//////////////////////////////////////////////////////////////
1475b           *                            SOUND
1476b           *//////////////////////////////////////////////////////////////
1477b           
1478b           * MUTE   () / MUTE2  ..: 
1479b           ***************************************************************
1480b           * MUTE - Mute all sound generators
1481b           ***************************************************************
1482b           *  BL  @MUTE
1483b           *  Mute sound generators and clear sound pointer
1484b           *
1485b           *  BL  @MUTE2
1486b           *  Mute sound generators without clearing sound pointer
1487b           ********@*****@*********************@**************************                      
1488b 652C 04E0 MUTE    CLR   @WSDLST               ; Clear sound pointer
1488b 652E 8334  
1489b 6530 4320 MUTE2   SZC   @WBIT13,CONFIG        ; Turn off/pause sound player
1489b 6532 6040  
1490b 6534 0204         LI    TMP0,MUTTAB
1490b 6536 6546  
1491b 6538 0205         LI    TMP1,SOUND            ; Sound generator port >8400
1491b 653A 8400  
1492b 653C D574         MOVB  *TMP0+,*TMP1          ; Generator 0
1493b 653E D574         MOVB  *TMP0+,*TMP1          ; Generator 1
1494b 6540 D574         MOVB  *TMP0+,*TMP1          ; Generator 2
1495b 6542 D554         MOVB  *TMP0,*TMP1           ; Generator 3
1496b 6544 045B         B     *R11
1497b 6546 9FBF MUTTAB  BYTE  >9F,>BF,>DF,>FF       ; Table for muting all generators
1497b 6548 DFFF  
1498b           * :..
1499b           
1500b           * SDPREP (DATA P0,P1) ..:
1501b           ***************************************************************
1502b           * SDPREP - Prepare for playing sound
1503b           ***************************************************************
1504b           *  BL   @SDPREP
1505b           *  DATA P0,P1
1506b           *
1507b           *  P0 = Address where tune is stored
1508b           *  P1 = Option flags for sound player 
1509b           *--------------------------------------------------------------
1510b           *  REMARKS
1511b           *  Use the below equates for P1:
1512b           *
1513b           *  SDOPT1 => Tune is in CPU memory + loop
1514b           *  SDOPT2 => Tune is in CPU memory
1515b           *  SDOPT3 => Tune is in VRAM + loop
1516b           *  SDOPT4 => Tune is in VRAM
1517b           ********@*****@*********************@************************** 
1518b 654A C81B SDPREP  MOV   *R11,@WSDLST          ; Set tune address
1518b 654C 8334  
1519b 654E C83B         MOV   *R11+,@WSDTMP         ; Set tune address in temp
1519b 6550 8336  
1520b 6552 024C         ANDI  R12,>FFF8             ; Clear bits 13-14-15
1520b 6554 FFF8  
1521b 6556 E33B         SOC   *R11+,CONFIG          ; Set options
1522b 6558 D820         MOVB  @BD1,@R13LB           ; Set initial duration
1522b 655A 6049  
1522b 655C 831B  
1523b 655E 045B         B     *R11
1524b           *:..
1525b                   
1526b           * SDPLAY () ..:
1527b           ***************************************************************
1528b           * SDPLAY - Sound player for tune in VRAM or CPU memory
1529b           ***************************************************************
1530b           *  BL  @SDPLAY
1531b           *--------------------------------------------------------------
1532b           *  REMARKS
1533b           *  Set config register bit13=0 to pause player.
1534b           *  Set config register bit14=1 to repeat (or play next tune).
1535b           ********@*****@*********************@**************************                   
1536b 6560 2320 SDPLAY  COC   @WBIT13,CONFIG        ; Play tune ?
1536b 6562 6040  
1537b 6564 1301         JEQ   SDPLA1                ; Yes, play
1538b 6566 045B         B     *R11
1539b           *--------------------------------------------------------------
1540b           * Initialisation
1541b           *--------------------------------------------------------------              
1542b 6568 060D SDPLA1  DEC   R13                   ; duration = duration - 1
1543b 656A 9820         CB    @R13LB,@BD0           ; R13LB == 0 ?
1543b 656C 831B  
1543b 656E 6048  
1544b 6570 1301         JEQ   SDPLA3                ; Play next note
1545b 6572 045B SDPLA2  B     *R11                  ; Note still busy, exit  
1546b 6574 2320 SDPLA3  COC   @WBIT15,CONFIG        ; Play tune from CPU memory ?
1546b 6576 6044  
1547b 6578 131A         JEQ   MMPLAY 
1548b           *--------------------------------------------------------------
1549b           * Play tune from VDP memory
1550b           *--------------------------------------------------------------        
1551b 657A C120 VDPLAY  MOV   @WSDTMP,TMP0          ; Get tune address        
1551b 657C 8336  
1552b 657E 06C4         SWPB  TMP0
1553b 6580 D804         MOVB  TMP0,@VDPA
1553b 6582 8C02  
1554b 6584 06C4         SWPB  TMP0
1555b 6586 D804         MOVB  TMP0,@VDPA
1555b 6588 8C02  
1556b 658A 04C4         CLR   TMP0        
1557b 658C D120         MOVB  @VDPR,TMP0            ; length = 0 (end of tune) ?
1557b 658E 8800  
1558b 6590 131E         JEQ   SDEXIT                ; Yes. exit
1559b 6592 0984 VDPLA1  SRL   TMP0,8                ; Right justify length byte
1560b 6594 A804         A     TMP0,@WSDTMP          ; Adjust for next table entry
1560b 6596 8336  
1561b 6598 D820 VDPLA2  MOVB  @VDPR,@>8400          ; Feed byte to sound generator
1561b 659A 8800  
1561b 659C 8400  
1562b 659E 0604         DEC   TMP0
1563b 65A0 16FB         JNE   VDPLA2
1564b 65A2 D820         MOVB  @VDPR,@R13LB          ; Set duration counter       
1564b 65A4 8800  
1564b 65A6 831B  
1565b 65A8 05E0 VDPLA3  INCT  @WSDTMP               ; Adjust for next table entry, honour byte (1) + (n+1)
1565b 65AA 8336  
1566b 65AC 045B         B     *R11
1567b           *--------------------------------------------------------------
1568b           * Play tune from CPU memory
1569b           *-------------------------------------------------------------- 
1570b 65AE C120 MMPLAY  MOV   @WSDTMP,TMP0
1570b 65B0 8336  
1571b 65B2 D174         MOVB  *TMP0+,TMP1           ; length = 0 (end of tune) ?
1572b 65B4 130C         JEQ   SDEXIT                ; Yes, exit
1573b 65B6 0985 MMPLA1  SRL   TMP1,8                ; Right justify length byte
1574b 65B8 A805         A     TMP1,@WSDTMP          ; Adjust for next table entry
1574b 65BA 8336  
1575b 65BC D834 MMPLA2  MOVB  *TMP0+,@>8400         ; Feed byte to sound generator
1575b 65BE 8400  
1576b 65C0 0605         DEC   TMP1
1577b 65C2 16FC         JNE   MMPLA2
1578b 65C4 D814         MOVB  *TMP0,@R13LB          ; Set duration counter
1578b 65C6 831B  
1579b 65C8 05E0         INCT  @WSDTMP               ; Adjust for next table entry, honour byte (1) + (n+1)
1579b 65CA 8336  
1580b 65CC 045B         B     *R11
1581b           *--------------------------------------------------------------
1582b           * Exit. Check if tune must be looped
1583b           *--------------------------------------------------------------         
1584b 65CE 2320 SDEXIT  COC   @WBIT14,CONFIG        ; Loop flag set ?
1584b 65D0 6042  
1585b 65D2 1607         JNE   SDEXI2                ; No, exit
1586b 65D4 C820         MOV   @WSDLST,@WSDTMP 
1586b 65D6 8334  
1586b 65D8 8336  
1587b 65DA D820         MOVB  @BD1,@R13LB           ; Set initial duration
1587b 65DC 6049  
1587b 65DE 831B  
1588b 65E0 045B SDEXI1  B     *R11                  ; Exit
1589b 65E2 024C SDEXI2  ANDI  CONFIG,>FFF8          ; Reset music player
1589b 65E4 FFF8  
1590b 65E6 045B         B     *R11                  ; Exit        
1591b           * :..
1592b           
1593b           
1594b           *//////////////////////////////////////////////////////////////
1595b           *                            SPEECH
1596b           *//////////////////////////////////////////////////////////////
1597b           
1598b           * SPSTAT () ..:
1599b           ***************************************************************
1600b           * SPSTAT - Read status register byte from speech synthesizer
1601b           ***************************************************************
1602b           *  LI  TMP2,@>....
1603b           *  B   @SPSTAT
1604b           *--------------------------------------------------------------
1605b           * REMARKS
1606b           * Destroys R11 !
1607b           * 
1608b           * Register usage
1609b           * TMP0HB = Status byte read from speech synth
1610b           * TMP1   = Temporary use  (scratchpad machine code)
1611b           * TMP2   = Return address for this subroutine
1612b           * R11    = Return address (scratchpad machine code)
1613b           ********@*****@*********************@**************************
1614b 65E8 0204 SPSTAT  LI    TMP0,SPCHRD           ; (R4) = >9000
1614b 65EA 9000  
1615b 65EC C820         MOV   @SPCODE,@MCSPRD       ; \
1615b 65EE 6070  
1615b 65F0 8322  
1616b 65F2 C820         MOV   @SPCODE+2,@MCSPRD+2   ; / Load speech read code
1616b 65F4 6072  
1616b 65F6 8324  
1617b 65F8 020B         LI    R11,SPSTA1            ; Return to SPSTA1
1617b 65FA 6600  
1618b 65FC 0460         B     @MCSPRD               ; Run scratchpad code
1618b 65FE 8322  
1619b 6600 C820 SPSTA1  MOV   @MCCODE,@MCSPRD       ; \
1619b 6602 606A  
1619b 6604 8322  
1620b 6606 C820         MOV   @MCCODE+2,@MCSPRD+2   ; / Restore tight loop code        
1620b 6608 606C  
1620b 660A 8324  
1621b 660C 0456         B     *TMP2                 ; Exit
1622b           *:..
1623b                   
1624b           * SPCONN () ..:
1625b           ***************************************************************
1626b           * SPCONN - Check if speech synthesizer connected
1627b           ***************************************************************
1628b           * BL  @SPCONN
1629b           *--------------------------------------------------------------
1630b           * OUTPUT
1631b           * TMP0HB = Byte read from speech synth
1632b           *--------------------------------------------------------------
1633b           * REMARKS
1634b           * See Editor/Assembler manual, section 22.1.6 page 354.
1635b           * Calls SPSTAT.
1636b           * 
1637b           * Register usage
1638b           * TMP0HB = Byte read from speech synth
1639b           * TMP3   = Copy of R11
1640b           * R12    = CONFIG register
1641b           ********@*****@*********************@**************************        
1642b 660E C1CB SPCONN  MOV   R11,TMP3              ; Save R11
1643b 6610 D820         MOVB  @BH10,@SPCHWT         ; Load >10
1643b 6612 603D  
1643b 6614 9400  
1644b 6616 0206         LI    TMP2,SPCON1           
1644b 6618 661E  
1645b 661A 0460         B     @SPSTAT               ; Read status byte
1645b 661C 65E8  
1646b 661E 0457 SPCON1  B     *TMP3                 ; Exit
1647b           *:..        
1648b           
1649b           * SPPREP (DATA P0,P1) ..:
1650b           ***************************************************************
1651b           * SPPREP - Prepare for playing speech
1652b           ***************************************************************
1653b           *  BL   @SPPREP
1654b           *  DATA P0,P1
1655b           *
1656b           *  P0 = Address of LPC data for external voice
1657b           *       or index of word to speak if resident voice
1658b           *  P1 = Option flags for speech player 
1659b           *--------------------------------------------------------------
1660b           *  REMARKS
1661b           *  Use the below equates for P1:
1662b           *
1663b           *  SPOPT1  => External voice
1664b           *  SPOPT2  => Resident voice
1665b           ********@*****@*********************@************************** 
1666b 6620 C83B SPPREP  MOV   *R11+,@WSPEAK         ; Set speech address
1666b 6622 8338  
1667b 6624 024C         ANDI  R12,>E3FF             ; Clear bits 3-4-5
1667b 6626 E3FF  
1668b 6628 E33B         SOC   *R11+,CONFIG          ; Set options
1669b 662A 045B         B     *R11
1670b           *:..
1671b                  
1672b           * SPPLAY () ..:
1673b           ***************************************************************
1674b           * SPPLAY - Speech player
1675b           ***************************************************************
1676b           * BL  @SPPLAY
1677b           *--------------------------------------------------------------
1678b           * Register usage
1679b           * TMP3   = Copy of R11
1680b           * R12    = CONFIG register
1681b           ********@*****@*********************@**************************                
1682b 662C 2720 SPPLAY  CZC   @WBIT3,CONFIG         ; Player off ?
1682b 662E 602C  
1683b 6630 1332         JEQ   SPPLAZ                ; Yes, exit
1684b 6632 C1CB SPPLA1  MOV   R11,TMP3              ; Save R11
1685b 6634 2320         COC   @TMP010,CONFIG        ; Is on/busy/external ?
1685b 6636 6698  
1686b 6638 1313         JEQ   SPKEX3                ; Check FIFO buffer level
1687b 663A 2320         COC   @WBIT5,CONFIG         ; Start speak external ?
1687b 663C 6030  
1688b 663E 1300         JEQ   SPKEXT                ; Yes, do it
1689b           *--------------------------------------------------------------
1690b           * Speak resident: ****
1691b           *--------------------------------------------------------------        
1692b           *       NOT   YET
1693b           *--------------------------------------------------------------
1694b           * Speak external: Push LPC data to speech synthesizer
1695b           *--------------------------------------------------------------        
1696b 6640 C120 SPKEXT  MOV   @WSPEAK,TMP0
1696b 6642 8338  
1697b 6644 D834         MOVB  *TMP0+,@SPCHWT        ; Send byte to speech synth
1697b 6646 9400  
1698b 6648 1000         JMP   $+2                   ; Delay
1699b 664A 0206         LI    TMP2,16
1699b 664C 0010  
1700b 664E D834 SPKEX1  MOVB  *TMP0+,@SPCHWT        ; Send byte to speech synth
1700b 6650 9400  
1701b 6652 0606         DEC   TMP2
1702b 6654 16FC         JNE   SPKEX1
1703b 6656 026C         ORI   CONFIG,>1800          ; bit 4=1 (busy) & bit 5=1 (external)
1703b 6658 1800  
1704b 665A C804         MOV   TMP0,@WSPEAK          ; Update LPC pointer
1704b 665C 8338  
1705b 665E 101B         JMP   SPPLAZ                ; Exit
1706b           *--------------------------------------------------------------
1707b           * Speak external: Check synth FIFO buffer level 
1708b           *--------------------------------------------------------------         
1709b 6660 0206 SPKEX3  LI    TMP2,SPKEX4           ; Set return address for SPSTAT
1709b 6662 6668  
1710b 6664 0460         B     @SPSTAT               ; Get speech FIFO buffer status
1710b 6666 65E8  
1711b 6668 2120 SPKEX4  COC   @WH4000,TMP0          ; FIFO BL (buffer low) bit set ?
1711b 666A 6028  
1712b 666C 1301         JEQ   SPKEX5                ; Yes, refill
1713b 666E 1013         JMP   SPPLAZ                ; No, exit
1714b           *--------------------------------------------------------------
1715b           * Speak external: Refill synth with LPC data if FIFO buffer low
1716b           *--------------------------------------------------------------         
1717b 6670 C120 SPKEX5  MOV   @WSPEAK,TMP0        
1717b 6672 8338  
1718b 6674 0206         LI    TMP2,8                ; Bytes to send to speech synth
1718b 6676 0008  
1719b 6678 D174 SPKEX6  MOVB  *TMP0+,TMP1         
1720b 667A D805         MOVB  TMP1,@SPCHWT          ; Send byte to speech synth
1720b 667C 9400  
1721b 667E 0285         CI    TMP1,SPKOFF           ; Speak off marker found ?
1721b 6680 FF00  
1722b 6682 1305         JEQ   SPKEX8
1723b 6684 0606         DEC   TMP2
1724b 6686 16F8         JNE   SPKEX6                ; Send next byte
1725b 6688 C804         MOV   TMP0,@WSPEAK          ; Update LPC pointer
1725b 668A 8338  
1726b 668C 1004 SPKEX7  JMP   SPPLAZ                ; Exit
1727b           *--------------------------------------------------------------
1728b           * Speak external: Done with speaking
1729b           *--------------------------------------------------------------   
1730b 668E 4320 SPKEX8  SZC   @TMP010,CONFIG        ; bit 3,4,5=0
1730b 6690 6698  
1731b 6692 04E0         CLR   @WSPEAK               ; Reset pointer
1731b 6694 8338  
1732b 6696 0457 SPPLAZ  B     *TMP3                 ; Exit
1733b 6698 1C00 TMP010  DATA  >1C00                 ; Binary 0001110000000000
1734b           *:..
1735b           
1736b           
1737b           
1738b           *//////////////////////////////////////////////////////////////
1739b           *                           KEYBOARD
1740b           *//////////////////////////////////////////////////////////////
1741b           
1742b           * VIRTKB () ..:
1743b           ***************************************************************
1744b           * VIRTKB - Read virtual keyboard and joysticks
1745b           ***************************************************************
1746b           *  BL @VIRTKB
1747b           *--------------------------------------------------------------
1748b           *  COLUMN     0     1  2  3  4  5    6   7
1749b           *         +---------------------------------+------+
1750b           *  ROW 7  |   =     .  ,  M  N  /   JS1 JS2 | Fire |
1751b           *  ROW 6  | SPACE   L  K  J  H  :;  JS1 JS2 | Left |
1752b           *  ROW 5  | ENTER   O  I  U  Y  P   JS1 JS2 | Right|
1753b           *  ROW 4  |         9  8  7  6  0   JS1 JS2 | Down |
1754b           *  ROW 3  | FCTN    2  3  4  5  1   JS1 JS2 | Up   |
1755b           *  ROW 2  | SHIFT   S  D  F  G  A           +------|
1756b           *  ROW 1  | CTRL    W  E  R  T  Q                  |
1757b           *  ROW 0  |         X  C  V  B  Z                  |
1758b           *         +----------------------------------------+
1759b           *  See MG smart programmer 1986 
1760b           *  September/Page 15 and November/Page 6
1761b           *  Also see virtual keyboard status for bits to check
1762b           *--------------------------------------------------------------
1763b           *  Register usage
1764b           *  TMP0     Keyboard matrix column to process
1765b           *  TMP1MSB  Keyboard matrix 8 bits of 1 column
1766b           *  TMP2     Virtual keyboard flags
1767b           *  TMP3     Address of entry in mapping table
1768b           *  TMP4     Copy of R12 (CONFIG REGISTER)
1769b           *  R12      CRU communication
1770b           ********@*****@*********************@**************************
1771b 669A 4320 VIRTKB  SZC   @WBIT11,CONFIG        ; Reset ANY key
1771b 669C 603C  
1772b 669E C20C         MOV   CONFIG,TMP4           ; Save R12 (CONFIG REGISTER)        
1773b 66A0 04C4         CLR   TMP0                  ; Value in MSB! Start with column 0
1774b 66A2 04C6         CLR   TMP2                  ; Erase virtual keyboard flags
1775b 66A4 0207         LI    TMP3,KBMAP0           ; Start with column 0
1775b 66A6 6716  
1776b           *--------------------------------------------------------------        
1777b           * Check alpha lock key
1778b           *-------@-----@---------------------@--------------------------
1779b 66A8 04CC         CLR   R12
1780b 66AA 1E15         SBZ   >0015                 ; Set P5
1781b 66AC 1F07         TB    7
1782b 66AE 1302         JEQ   VIRTK1
1783b 66B0 0206         LI    TMP2,KALPHA           ; Alpha lock key down
1783b 66B2 8000  
1784b           *--------------------------------------------------------------        
1785b           * Scan keyboard matrix
1786b           *-------@-----@---------------------@--------------------------
1787b 66B4 1D15 VIRTK1  SBO   >0015                 ; Reset P5
1788b 66B6 020C         LI    R12,>0024             ; Scan full 8x8 keyboard matrix. R12 is used by LDCR
1788b 66B8 0024  
1789b 66BA 30C4         LDCR  TMP0,3                ; Set keyboard column with a value from 0-7 (3=3 bits)
1790b 66BC 020C         LI    R12,>0006             ; Load CRU base for row. R12 required by STCR
1790b 66BE 0006  
1791b 66C0 0705         SETO  TMP1                  ; >FFFF
1792b 66C2 3605         STCR  TMP1,8                ; Bring 8 row bits into MSB of TMP1
1793b 66C4 0545         INV   TMP1
1794b 66C6 1302         JEQ   VIRTK2                ; >0000 ?
1795b 66C8 E220         SOC   @WBIT11,TMP4          ; Set ANY key in copy of CONFIG register
1795b 66CA 603C  
1796b           *--------------------------------------------------------------
1797b           * Process column
1798b           *-------@-----@---------------------@--------------------------                
1799b 66CC 2177 VIRTK2  COC   *TMP3+,TMP1           ; Check bit mask
1800b 66CE 1601         JNE   VIRTK3
1801b 66D0 E197         SOC   *TMP3,TMP2            ; Set virtual keyboard flags
1802b 66D2 05C7 VIRTK3  INCT  TMP3
1803b 66D4 8817         C     *TMP3,@KBEOC          ; End-of-column ?
1803b 66D6 6722  
1804b 66D8 16F9         JNE   VIRTK2                ; No, next entry
1805b 66DA 05C7         INCT  TMP3
1806b           *--------------------------------------------------------------
1807b           * Prepare for next column
1808b           *-------@-----@---------------------@--------------------------                               
1809b 66DC 0284 VIRTK4  CI    TMP0,>0700            ; Column 7 processed ?
1809b 66DE 0700  
1810b 66E0 1309         JEQ   VIRTK6                ; Yes, exit
1811b 66E2 0284         CI    TMP0,>0200            ; Column 2 processed ?
1811b 66E4 0200  
1812b 66E6 1303         JEQ   VIRTK5                ; Yes, skip
1813b 66E8 0224         AI    TMP0,>0100
1813b 66EA 0100  
1814b 66EC 10E3         JMP   VIRTK1
1815b 66EE 0204 VIRTK5  LI    TMP0,>0500            ; Skip columns 3-4        
1815b 66F0 0500  
1816b 66F2 10E0         JMP   VIRTK1
1817b           *--------------------------------------------------------------
1818b           * Exit
1819b           *-------@-----@---------------------@--------------------------
1820b 66F4 C308 VIRTK6  MOV   TMP4,CONFIG           ; Restore CONFIG register
1821b 66F6 C806         MOV   TMP2,@WVRTKB          ; Save virtual keyboard flags
1821b 66F8 8332  
1822b 66FA 1601         JNE   VIRTK7        
1823b 66FC 045B         B     *R11                  ; Exit
1824b 66FE 0286 VIRTK7  CI    TMP2,>FFFF            ; FCTN-QUIT pressed ?
1824b 6700 FFFF  
1825b 6702 1603         JNE   VIRTK8                ; No
1826b 6704 0701         SETO  R1                    ; Set exit flag
1827b 6706 0460         B     @RUNLI1               ; Yes, reset computer
1827b 6708 6A0E  
1828b 670A 0286 VIRTK8  CI    TMP2,KALPHA           ; Only alpha-lock pressed ?
1828b 670C 8000  
1829b 670E 1602         JNE   VIRTK9
1830b 6710 4320         SZC   @WBIT11,CONFIG        ; Yes, so reset ANY key
1830b 6712 603C  
1831b 6714 045B VIRTK9  B     *R11                  ; Exit
1832b           *--------------------------------------------------------------
1833b           * Mapping table
1834b           *-------@-----@---------------------@--------------------------           
1835b           *                                   ; Bit 01234567
1836b 6716 1100 KBMAP0  DATA  >1100,>FFFF           ; >11 00010001  FCTN QUIT
1836b 6718 FFFF  
1837b 671A 0200         DATA  >0200,K1FIRE          ; >02 00000010  spacebar
1837b 671C 0020  
1838b 671E 0400         DATA  >0400,KENTER          ; >04 00000100  enter
1838b 6720 4000  
1839b 6722 FFFF KBEOC   DATA  >FFFF
1840b 6724 0800 KBMAP1  DATA  >0800,KBACK           ; >08 00001000  FCTN BACK 
1840b 6726 1000  
1841b 6728 2000         DATA  >2000,K1LF            ; >20 00100000  S (arrow left)
1841b 672A 0200  
1842b 672C 8000         DATA  >8000,K1DN            ; >80 10000000  X (arrow down)
1842b 672E 0040  
1843b 6730 FFFF         DATA  >FFFF
1844b 6732 0800 KBMAP2  DATA  >0800,KREDO           ; >08 00001000  FCTN REDO
1844b 6734 2000  
1845b 6736 2000         DATA  >2000,K1RG            ; >20 00100000  D (arrow right)
1845b 6738 0100  
1846b 673A 4000         DATA  >4000,K1UP            ; >80 01000000  E (arrow up)
1846b 673C 0080  
1847b 673E FFFF         DATA  >FFFF
1848b 6740 0800 KBCOL5  DATA  >0800,KPAUSE          ; >08 00001000  P (pause)
1848b 6742 0800  
1849b 6744 8000         DATA  >8000,K1FIRE          ; >80 01000000  Q (fire)
1849b 6746 0020  
1850b 6748 FFFF         DATA  >FFFF
1851b 674A 0100 KBMAP6  DATA  >0100,K1FIRE          ; >01 00000001  joystick 1 FIRE
1851b 674C 0020  
1852b 674E 0200         DATA  >0200,K1LF            ; >02 00000010  joystick 1 left
1852b 6750 0200  
1853b 6752 0400         DATA  >0400,K1RG            ; >04 00000100  joystick 1 right
1853b 6754 0100  
1854b 6756 0800         DATA  >0800,K1DN            ; >08 00001000  joystick 1 down
1854b 6758 0040  
1855b 675A 1000         DATA  >1000,K1UP            ; >10 00010000  joystick 1 up
1855b 675C 0080  
1856b 675E FFFF         DATA  >FFFF
1857b 6760 0100 KBMAP7  DATA  >0100,K2FIRE          ; >01 00000001  joystick 2 FIRE
1857b 6762 0001  
1858b 6764 0200         DATA  >0200,K2LF            ; >02 00000010  joystick 2 left
1858b 6766 0010  
1859b 6768 0400         DATA  >0400,K2RG            ; >04 00000100  joystick 2 right
1859b 676A 0008  
1860b 676C 0800         DATA  >0800,K2DN            ; >08 00001000  joystick 2 down
1860b 676E 0002  
1861b 6770 1000         DATA  >1000,K2UP            ; >10 00010000  joystick 2 up
1861b 6772 0004  
1862b 6774 FFFF         DATA  >FFFF
1863b           *:..
1864b           
1865b           * REALKB () ..:
1866b           ***************************************************************
1867b           * REALKB - Scan keyboard in real mode
1868b           ***************************************************************
1869b           *  BL @REALKB
1870b           *--------------------------------------------------------------
1871b           *  Taken from the book "TMS9900 assembler auf dem TI-99/4A".
1872b           *  Based on work done by Simon Koppelmann.
1873b           ********@*****@*********************@**************************
1874b 6776 C10C REALKB  MOV   R12,TMP0              ; Save R12 (CONFIG) in TMP0
1875b 6778 0244         ANDI  TMP0,>7FFF            ; Reset bit 0 in saved CONFIG register
1875b 677A 7FFF  
1876b 677C 020C         LI    R12,>0024
1876b 677E 0024  
1877b 6780 020F         LI    R15,KBSMAL            ; Default is KBSMAL table
1877b 6782 6814  
1878b 6784 04C6         CLR   TMP2              
1879b 6786 30C6         LDCR  TMP2,>0003            ; Lower case by default        
1880b           *--------------------------------------------------------------
1881b           * SHIFT key pressed ?
1882b           *--------------------------------------------------------------         
1883b 6788 04CC         CLR   R12
1884b 678A 1F08         TB    >0008                 ; Shift-key ?
1885b 678C 1302         JEQ   REALK1                ; No
1886b 678E 020F         LI    R15,KBSHFT            ; Yes, use KBSHIFT table
1886b 6790 6844  
1887b           *--------------------------------------------------------------
1888b           * FCTN key pressed ?
1889b           *--------------------------------------------------------------                  
1890b 6792 1F07 REALK1  TB    >0007                 ; FNCTN-key ?
1891b 6794 1302         JEQ   REALK2                ; No
1892b 6796 020F         LI    R15,KBFCTN            ; Yes, use KBFCTN table
1892b 6798 6874  
1893b           *--------------------------------------------------------------
1894b           * CTRL key pressed ?
1895b           *-------------------------------------------------------------- 
1896b 679A 1F09 REALK2  TB    >0009                 ; CTRL-key ?
1897b 679C 1302         JEQ   REALK3                ; No
1898b 679E 020F         LI    R15,KBCTRL            ; Yes, use KBCTRL table
1898b 67A0 68A4  
1899b           *--------------------------------------------------------------
1900b           * ALPHA LOCK key down ?
1901b           *-------------------------------------------------------------- 
1902b 67A2 1E15 REALK3  SBZ   >0015                 ; Set P5
1903b 67A4 1F07         TB    >0007                 ; ALPHA-Lock key ?
1904b 67A6 1602         JNE   REALK4                ; No,  saved CONFIG register bit 0 = 0
1905b 67A8 0264         ORI   TMP0,>8000            ; Yes, saved CONFIG register bit 0 = 1       
1905b 67AA 8000  
1906b           *--------------------------------------------------------------
1907b           * Scan keyboard column
1908b           *-------------------------------------------------------------- 
1909b 67AC 1D15 REALK4  SBO   >0015                 ; Reset P5
1910b 67AE 0206         LI    TMP2,6                ; Bitcombination for CRU, column counter
1910b 67B0 0006  
1911b 67B2 0606 REALK5  DEC   TMP2
1912b 67B4 020C         LI    R12,>24               ; CRU address for P2-P4
1912b 67B6 0024  
1913b 67B8 06C6         SWPB  TMP2
1914b 67BA 30C6         LDCR  TMP2,3                ; Transfer bit combination
1915b 67BC 06C6         SWPB  TMP2
1916b 67BE 020C         LI    R12,6                 ; CRU read address
1916b 67C0 0006  
1917b 67C2 3607         STCR  TMP3,8                ; Transfer 8 bits into R2HB
1918b 67C4 0547         INV   TMP3                  ;
1919b 67C6 0247         ANDI  TMP3,>FF00            ; Clear TMP3LB
1919b 67C8 FF00  
1920b           *--------------------------------------------------------------
1921b           * Scan keyboard row
1922b           *--------------------------------------------------------------         
1923b 67CA 04C5         CLR   TMP1                  ; Use TMP1 as row counter from now on
1924b 67CC 0A17 REALK6  SLA   TMP3,1                ; R2 bitcombinations scanned by shifting left.
1925b 67CE 1807         JOC   REALK8                ; If no carry after 8 loops, then it means no key
1926b 67D0 0585 REALK7  INC   TMP1                  ; was pressed on that line.
1927b 67D2 0285         CI    TMP1,8
1927b 67D4 0008  
1928b 67D6 1AFA         JL    REALK6
1929b 67D8 C186         MOV   TMP2,TMP2             ; All 6 columns processed ?
1930b 67DA 1BEB         JH    REALK5                ; No, next column
1931b 67DC 1017         JMP   REALKZ                ; Yes, exit
1932b           *--------------------------------------------------------------
1933b           * Check for match in data table
1934b           *--------------------------------------------------------------         
1935b 67DE C206 REALK8  MOV   TMP2,TMP4
1936b 67E0 0A38         SLA   TMP4,3                ; TMP4 = TMP2 * 8
1937b 67E2 A205         A     TMP1,TMP4             ; TMP4 = TMP4 + TMP1
1938b 67E4 A20F         A     R15,TMP4              ; TMP4 = TMP4 + base address of data table (R15)
1939b 67E6 D618         MOVB  *TMP4,*TMP4           ; Is the byte on that address = >00 ?
1940b 67E8 13F3         JEQ   REALK7                ; Yes, then discard and continue scanning (FCTN, SHIFT, CTRL)
1941b           *--------------------------------------------------------------
1942b           * Determine ASCII value of key
1943b           *-------------------------------------------------------------- 
1944b 67EA D198 REALK9  MOVB  *TMP4,TMP2            ; Real keypress. It's safe to reuse TMP2 now
1945b 67EC 2120         COC   @WBIT0,TMP0           ; ALPHA-Lock key pressed ?
1945b 67EE 6026  
1946b 67F0 1608         JNE   REALKA                ; No, continue with KBCONT4
1947b 67F2 9806         CB    TMP2,@KBSMAL+42       ; Is ASCII of key pressed < 97 ('a') ?
1947b 67F4 683E  
1948b 67F6 1A05         JL    REALKA
1949b 67F8 9806         CB    TMP2,@KBSMAL+40       ; and ASCII of key pressed > 122 ('z') ?
1949b 67FA 683C  
1950b 67FC 1B02         JH    REALKA                ; No, continue with REALKA
1951b 67FE 0226         AI    TMP2,->2000           ; ASCII = ASCII - 32 (lowercase to uppercase!)             
1951b 6800 E000  
1952b 6802 0986 REALKA  SRL   TMP2,8                ; Right justify
1953b 6804 C806         MOV   TMP2,@WASCKB          ; Store ASCII value of key pressed
1953b 6806 833E  
1954b 6808 E120         SOC   @WBIT11,TMP0          ; Set ANYKEY flag in saved CONFIG register 
1954b 680A 603C  
1955b 680C C304 REALKZ  MOV   TMP0,R12              ; Restore CONFIG register
1956b 680E 020F         LI    R15,VDPW              ; Setup VDP write address again after using R15 as temp storage
1956b 6810 8C00  
1957b 6812 045B         B     *R11                  ; Exit        
1958b           ********@*****@*********************@**************************
1959b 6814 FF00 KBSMAL  DATA  >FF00,>0000,>FF0D,>203D
1959b 6816 0000  
1959b 6818 FF0D  
1959b 681A 203D  
1960b 681C 7877         TEXT  'xws29ol.'
1960b 681E 7332  
1960b 6820 396F  
1960b 6822 6C2E  
1961b 6824 6365         TEXT  'ced38ik,'
1961b 6826 6433  
1961b 6828 3869  
1961b 682A 6B2C  
1962b 682C 7672         TEXT  'vrf47ujm'
1962b 682E 6634  
1962b 6830 3775  
1962b 6832 6A6D  
1963b 6834 6274         TEXT  'btg56yhn'
1963b 6836 6735  
1963b 6838 3679  
1963b 683A 686E  
1964b 683C 7A71         TEXT  'zqa10p;/'
1964b 683E 6131  
1964b 6840 3070  
1964b 6842 3B2F  
1965b 6844 FF00 KBSHFT  DATA  >FF00,>0000,>FF0D,>202B
1965b 6846 0000  
1965b 6848 FF0D  
1965b 684A 202B  
1966b 684C 5857         TEXT  'XWS@(OL>'
1966b 684E 5340  
1966b 6850 284F  
1966b 6852 4C3E  
1967b 6854 4345         TEXT  'CED#*IK<'
1967b 6856 4423  
1967b 6858 2A49  
1967b 685A 4B3C  
1968b 685C 5652         TEXT  'VRF$&UJM'
1968b 685E 4624  
1968b 6860 2655  
1968b 6862 4A4D  
1969b 6864 4254         TEXT  'BTG%^YHN'
1969b 6866 4725  
1969b 6868 5E59  
1969b 686A 484E  
1970b 686C 5A51         TEXT  'ZQA!)P:-'        
1970b 686E 4121  
1970b 6870 2950  
1970b 6872 3A2D  
1971b 6874 FF00 KBFCTN  DATA  >FF00,>0000,>FF0D,>2005
1971b 6876 0000  
1971b 6878 FF0D  
1971b 687A 2005  
1972b 687C 0A7E         DATA  >0A7E,>0804,>0F27,>C2B9
1972b 687E 0804  
1972b 6880 0F27  
1972b 6882 C2B9  
1973b 6884 600B         DATA  >600B,>0907,>063F,>C1B8
1973b 6886 0907  
1973b 6888 063F  
1973b 688A C1B8  
1974b 688C 7F5B         DATA  >7F5B,>7B02,>015F,>C0C3
1974b 688E 7B02  
1974b 6890 015F  
1974b 6892 C0C3  
1975b 6894 BE5D         DATA  >BE5D,>7D0E,>0CC6,>BFC4
1975b 6896 7D0E  
1975b 6898 0CC6  
1975b 689A BFC4  
1976b 689C 5CB9         DATA  >5CB9,>7C03,>BC22,>BDBA        
1976b 689E 7C03  
1976b 68A0 BC22  
1976b 68A2 BDBA  
1977b 68A4 FF00 KBCTRL  DATA  >FF00,>0000,>FF0D,>209D
1977b 68A6 0000  
1977b 68A8 FF0D  
1977b 68AA 209D  
1978b 68AC 9897         DATA  >9897,>93B2,>9F8F,>8C9B
1978b 68AE 93B2  
1978b 68B0 9F8F  
1978b 68B2 8C9B  
1979b 68B4 8385         DATA  >8385,>84B3,>9E89,>8B80
1979b 68B6 84B3  
1979b 68B8 9E89  
1979b 68BA 8B80  
1980b 68BC 9692         DATA  >9692,>86B4,>B795,>8A8D
1980b 68BE 86B4  
1980b 68C0 B795  
1980b 68C2 8A8D  
1981b 68C4 8294         DATA  >8294,>87B5,>B698,>888E
1981b 68C6 87B5  
1981b 68C8 B698  
1981b 68CA 888E  
1982b 68CC 9A91         DATA  >9A91,>81B1,>B090,>9CBB
1982b 68CE 81B1  
1982b 68D0 B090  
1982b 68D2 9CBB  
1983b           * :..        
1984b           
1985b           
1986b            
1987b 68D4 2320 GETKEY  COC   @WBIT11,CONFIG        ; ANYKEY pressed ?
1987b 68D6 603C  
1988b 68D8 1606         JNE   GETKEZ                ; No, exit
1989b 68DA 4320         SZC   @WBIT11,CONFIG        ; Reset ANYKEY flag in CONFIG register 
1989b 68DC 603C  
1990b 68DE C120         MOV   @WASCKB,TMP0          ; Get ASCII of key pressed
1990b 68E0 833E  
1991b 68E2 04E0 CLRKEY  CLR   @WASCKB               ; Reset ASCII buffer
1991b 68E4 833E  
1992b 68E6 069B GETKEZ  BL    *R11                  ; And exit
1993b           
1994b           
1995b           *//////////////////////////////////////////////////////////////
1996b           *                            TIMERS
1997b           *//////////////////////////////////////////////////////////////
1998b           
1999b           * TMGR   () ..:
2000b           ***************************************************************
2001b           * TMGR - X - Start Timer/Thread scheduler
2002b           ***************************************************************
2003b           *  B @TMGR
2004b           *--------------------------------------------------------------
2005b           *  REMARKS
2006b           *  Timer/Thread scheduler. Normally called from MAIN.
2007b           *  Don't forget to set BTIHI to highest slot in use.
2008b           *
2009b           *  Register usage in TMGR8 - TMGR11
2010b           *  TMP0  = Pointer to timer table
2011b           *  R10LB = Use as slot counter
2012b           *  TMP2  = 2nd word of slot data
2013b           *  TMP3  = Address of routine to call
2014b           ********@*****@*********************@**************************
2015b 68E8 0300 TMGR    LIMI  0                     ; No interrupt processing
2015b 68EA 0000  
2016b           *--------------------------------------------------------------
2017b           * Read VDP status register
2018b           *--------------------------------------------------------------
2019b 68EC D120 TMGR1   MOVB  @VDPS,TMP0            ; Get VDP status register
2019b 68EE 8802  
2020b 68F0 D344         MOVB  TMP0,R13              ; Save copy of VDP status register in R13
2021b 68F2 2120         COC   @WBIT0,TMP0           ; Interupt flag set ?
2021b 68F4 6026  
2022b 68F6 1316         JEQ   TMGR4                 ; Yes, process slots 0..n
2023b           *--------------------------------------------------------------
2024b           * Run speech player
2025b           *--------------------------------------------------------------        
2026b 68F8 2320         COC   @WBIT3,CONFIG         ; Speech player on ?
2026b 68FA 602C  
2027b 68FC 1602         JNE   TMGR2
2028b 68FE 06A0         BL    @SPPLA1               ; Run speech player                
2028b 6900 6632  
2029b           *--------------------------------------------------------------
2030b           * Run kernel thread
2031b           *--------------------------------------------------------------
2032b 6902 2320 TMGR2   COC   @WBIT8,CONFIG         ; Kernel thread blocked ?
2032b 6904 6036  
2033b 6906 1305         JEQ   TMGR3                 ; Yes, skip to user hook
2034b 6908 2320         COC   @WBIT9,CONFIG         ; Kernel thread enabled ?
2034b 690A 6038  
2035b 690C 1602         JNE   TMGR3                 ; No, skip to user hook
2036b 690E 0460         B     @KERNEL               ; Run kernel thread        
2036b 6910 69B4  
2037b           *--------------------------------------------------------------
2038b           * Run user hook 
2039b           *--------------------------------------------------------------
2040b 6912 2320 TMGR3   COC   @WBIT6,CONFIG         ; User hook blocked ?
2040b 6914 6032  
2041b 6916 13EA         JEQ   TMGR1
2042b 6918 2320         COC   @WBIT7,CONFIG         ; User hook enabled ?
2042b 691A 6034  
2043b 691C 16E7         JNE   TMGR1
2044b 691E C120         MOV   @WTIUSR,TMP0
2044b 6920 832E  
2045b 6922 0454         B     *TMP0                 ; Run user hook
2046b           *--------------------------------------------------------------
2047b           * Do some internal housekeeping
2048b           *--------------------------------------------------------------
2049b 6924 4320 TMGR4   SZC   @TMDAT,CONFIG         ; Unblock kernel thread and user hook              
2049b 6926 6986  
2050b 6928 C10A         MOV   R10,TMP0
2051b 692A 0244         ANDI  TMP0,>00FF            ; Clear HI byte
2051b 692C 00FF  
2052b 692E 2320         COC   @WBIT2,CONFIG         ; PAL flag set ?
2052b 6930 602A  
2053b 6932 1303         JEQ   TMGR5
2054b 6934 0284         CI    TMP0,60               ; 1 second reached ?        
2054b 6936 003C  
2055b 6938 1002         JMP   TMGR6
2056b 693A 0284 TMGR5   CI    TMP0,50
2056b 693C 0032  
2057b 693E 1101 TMGR6   JLT   TMGR7                 ; No, continue
2058b 6940 1001         JMP   TMGR8
2059b 6942 058A TMGR7   INC   R10                   ; Increase tick counter
2060b           *--------------------------------------------------------------
2061b           * Loop over slots
2062b           *--------------------------------------------------------------
2063b 6944 C120 TMGR8   MOV   @WTITAB,TMP0          ; Pointer to timer table
2063b 6946 832C  
2064b 6948 024A         ANDI  R10,>FF00             ; Use R10LB as slot counter. Reset.
2064b 694A FF00  
2065b 694C C1D4 TMGR9   MOV   *TMP0,TMP3            ; Is slot empty ?
2066b 694E 1316         JEQ   TMGR11                ; Yes, get next slot
2067b           *--------------------------------------------------------------
2068b           *  Check if slot should be executed
2069b           *--------------------------------------------------------------
2070b 6950 05C4         INCT  TMP0                  ; Second word of slot data
2071b 6952 0594         INC   *TMP0                 ; Update tick count in slot
2072b 6954 C194         MOV   *TMP0,TMP2            ; Get second word of slot data
2073b 6956 9820         CB    @TMP2HB,@TMP2LB       ; Slot target count = Slot internal counter ?
2073b 6958 830C  
2073b 695A 830D  
2074b 695C 1608         JNE   TMGR10                ; No, get next slot
2075b 695E 0246         ANDI  TMP2,>FF00            ; Clear internal counter
2075b 6960 FF00  
2076b 6962 C506         MOV   TMP2,*TMP0            ; Update timer table
2077b           *--------------------------------------------------------------
2078b           *  Run slot, we only need TMP0 to survive
2079b           *--------------------------------------------------------------
2080b 6964 C804         MOV   TMP0,@WTITMP          ; Save TMP0
2080b 6966 8330  
2081b 6968 0697         BL    *TMP3                 ; Call routine in slot
2082b 696A C120 SLOTOK  MOV   @WTITMP,TMP0          ; Restore TMP0
2082b 696C 8330  
2083b           *--------------------------------------------------------------
2084b           *  Prepare for next slot
2085b           *--------------------------------------------------------------
2086b 696E 058A TMGR10  INC   R10                   ; Next slot
2087b 6970 9820         CB    @R10LB,@BTIHI         ; Last slot done ?
2087b 6972 8315  
2087b 6974 8314  
2088b 6976 1504         JGT   TMGR12                ; yes, Wait for next VDP interrupt
2089b 6978 05C4         INCT  TMP0                  ; Offset for next slot
2090b 697A 10E8         JMP   TMGR9                 ; Process next slot
2091b 697C 05C4 TMGR11  INCT  TMP0                  ; Skip 2nd word of slot data
2092b 697E 10F7         JMP   TMGR10                ; Process next slot
2093b 6980 024A TMGR12  ANDI  R10,>FF00             ; Use R10LB as tick counter. Reset.
2093b 6982 FF00  
2094b 6984 10B3         JMP   TMGR1
2095b 6986 0280 TMDAT   DATA  >0280                 ; Bit 8 (kernel thread) and bit 6 (user hook)
2096b           *:..
2097b           
2098b           * MKSLOT (DATA P0,P1,...) ..:
2099b           ***************************************************************
2100b           * MKSLOT - Allocate timer slot(s)
2101b           ***************************************************************
2102b           *  BL    @MKSLOT
2103b           *  BYTE  P0HB,P0LB
2104b           *  DATA  P1
2105b           *  ....
2106b           *  DATA  EOL                        ; End-of-list
2107b           *--------------------------------------------------------------
2108b           *  P0 = Slot number, target count
2109b           *  P1 = Subroutine to call via BL @xxxx if slot is fired
2110b           ********@*****@*********************@**************************
2111b 6988 C13B MKSLOT  MOV   *R11+,TMP0
2112b 698A C17B         MOV   *R11+,TMP1
2113b           *--------------------------------------------------------------
2114b           *  Calculate address of slot
2115b           *--------------------------------------------------------------              
2116b 698C C184         MOV   TMP0,TMP2
2117b 698E 0966         SRL   TMP2,6                ; Right align & TMP2 = TMP2 * 4
2118b 6990 A1A0         A     @WTITAB,TMP2          ; Add table base
2118b 6992 832C  
2119b           *--------------------------------------------------------------
2120b           *  Add slot to table
2121b           *--------------------------------------------------------------        
2122b 6994 CD85         MOV   TMP1,*TMP2+           ; Store address of subroutine
2123b 6996 0A84         SLA   TMP0,8                ; Get rid of slot number
2124b 6998 C584         MOV   TMP0,*TMP2            ; Store target count and reset tick count
2125b           *--------------------------------------------------------------
2126b           *  Check for end of list
2127b           *--------------------------------------------------------------         
2128b 699A 881B         C     *R11,@WHFFFF          ; End of list ?
2128b 699C 6046  
2129b 699E 1301         JEQ   MKSLO1                ; Yes, exit
2130b 69A0 10F3         JMP   MKSLOT                ; Process next entry
2131b           *--------------------------------------------------------------
2132b           *  Exit
2133b           *--------------------------------------------------------------             
2134b 69A2 05CB MKSLO1  INCT  R11
2135b 69A4 045B         B     *R11                  ; Exit
2136b           *:..
2137b           
2138b           * CLSLOT (DATA P0) / XLSLOT ..:
2139b           ***************************************************************
2140b           * CLSLOT - Clear single timer slot
2141b           ***************************************************************
2142b           *  BL    @CLSLOT
2143b           *  DATA  P0
2144b           *--------------------------------------------------------------
2145b           *  P0 = Slot number
2146b           ********@*****@*********************@**************************
2147b 69A6 C13B CLSLOT  MOV   *R11+,TMP0
2148b 69A8 0A24 XLSLOT  SLA   TMP0,2                ; TMP0 = TMP0*4
2149b 69AA A120         A     @WTITAB,TMP0          ; Add table base
2149b 69AC 832C  
2150b 69AE 04F4         CLR   *TMP0+                ; Clear 1st word of slot
2151b 69B0 04D4         CLR   *TMP0                 ; Clear 2nd word of slot
2152b 69B2 045B         B     *R11                  ; Exit
2153b           *:..
2154b           
2155b           * KERNEL () ..:
2156b           ***************************************************************
2157b           * KERNEL - The kernel thread
2158b           *--------------------------------------------------------------
2159b           *  REMARKS
2160b           *  You shouldn't call the kernel thread manually.
2161b           *  Instead control it via the CONFIG register.
2162b           ********@*****@*********************@**************************
2163b 69B4 E320 KERNEL  SOC   @WBIT8,CONFIG         ; Block kernel thread
2163b 69B6 6036  
2164b 69B8 2320         COC   @WBIT13,CONFIG        ; Sound player on ?
2164b 69BA 6040  
2165b 69BC 1602         JNE   KERNE1
2166b 69BE 06A0         BL    @SDPLA1               ; Run sound player
2166b 69C0 6568  
2167b 69C2 06A0 KERNE1  BL    @VIRTKB               ; Scan virtual keyboard
2167b 69C4 669A  
2168b 69C6 2320         COC   @WBIT12,CONFIG        ; Keyboard mode real ?
2168b 69C8 603E  
2169b 69CA 1602         JNE   KERNEZ                ; No, exit
2170b 69CC 06A0         BL    @REALKB               ; Yes also scan the real keyboard
2170b 69CE 6776  
2171b 69D0 0460 KERNEZ  B     @TMGR3                ; Exit
2171b 69D2 6912  
2172b                     
2173b           *:..
2174b           
2175b           * MKHOOK (DATA P0) ..:
2176b           ***************************************************************
2177b           * MKHOOK - Allocate user hook
2178b           ***************************************************************
2179b           *  BL    @MKHOOK
2180b           *  DATA  P0
2181b           *--------------------------------------------------------------
2182b           *  P0 = Address of user hook
2183b           *--------------------------------------------------------------
2184b           *  REMARKS
2185b           *  The user hook gets executed after the kernel thread.
2186b           *  The user hook must always exit with "B @HOOKOK"
2187b           ********@*****@*********************@**************************
2188b 69D4 C83B MKHOOK  MOV   *R11+,@WTIUSR         ; Set user hook address
2188b 69D6 832E  
2189b 69D8 026C         ORI   CONFIG,ENUSR          ; Enable user hook
2189b 69DA 0100  
2190b 69DC 045B MKHOO1  B     *R11                  ; Return
2191b 0000 68EC HOOKOK  EQU   TMGR1                 ; Exit point for user hook        
2192b           *:..
2193b           
2194b           
2195b           *//////////////////////////////////////////////////////////////
2196b           *                       MISC FUNCTIONS
2197b           *//////////////////////////////////////////////////////////////
2198b           
2199b           * POPR.  (...) ..:
2200b           ***************************************************************
2201b           * POPR. - Pop registers & return to caller 
2202b           ***************************************************************
2203b           *  B  @POPRG.
2204b           *--------------------------------------------------------------
2205b           *  REMARKS
2206b           *  R11 must be at stack bottom
2207b           ********@*****@*********************@**************************
2208b 69DE C0F9 POPR3   MOV   *STACK+,R3
2209b 69E0 C0B9 POPR2   MOV   *STACK+,R2
2210b 69E2 C079 POPR1   MOV   *STACK+,R1
2211b 69E4 C039 POPR0   MOV   *STACK+,R0
2212b 69E6 C2F9 POPRT   MOV   *STACK+,R11
2213b 69E8 045B         B     *R11
2214b           *:..
2215b                   
2216b           * RND    (DATA P0) / RNDX ..:
2217b           ***************************************************************
2218b           * RND - Generate random number
2219b           ***************************************************************
2220b           *  BL   @RND
2221b           *  DATA P0
2222b           *--------------------------------------------------------------
2223b           *  P0 = Highest random number allowed
2224b           *
2225b           *--------------------------------------------------------------
2226b           *  BL   @RNDX
2227b           *
2228b           *  TMP0 = Highest random number allowed
2229b           *--------------------------------------------------------------
2230b           *  OUTPUT
2231b           *  TMP0 = The generated random number
2232b           ********@*****@*********************@**************************
2233b 69EA C13B RND     MOV   *R11+,TMP0            ; Highest number allowed
2234b 69EC 04C5 RNDX    CLR   TMP1
2235b 69EE C1A0         MOV   @WSEED,TMP2           ; Get random seed
2235b 69F0 833A  
2236b 69F2 1601         JNE   RND1
2237b 69F4 0586         INC   TMP2                  ; May not be zero
2238b 69F6 0916 RND1    SRL   TMP2,1
2239b 69F8 1702         JNC   RND2
2240b 69FA 29A0         XOR   @RNDDAT,TMP2
2240b 69FC 6A08  
2241b 69FE C806 RND2    MOV   TMP2,@WSEED           ; Store new random seed
2241b 6A00 833A  
2242b 6A02 3D44         DIV   TMP0,TMP1
2243b 6A04 C106         MOV   TMP2,TMP0         
2244b 6A06 045B         B     *R11                  ; Exit
2245b 6A08 B400 RNDDAT  DATA  >0B400                ; The magic number        
2246b           *:..
2247b           
2248b           
2249b           *//////////////////////////////////////////////////////////////
2250b           *                    RUNLIB INITIALISATION
2251b           *//////////////////////////////////////////////////////////////
2252b           
2253b           * RUNLIB () ..:
2254b           ***************************************************************
2255b           *  RUNLIB - Runtime library initalisation
2256b           ***************************************************************
2257b           *  B  @RUNLIB
2258b           *--------------------------------------------------------------
2259b           *  REMARKS
2260b           *  If R1 in WS1 equals >FFFF we return to the TI title screen
2261b           *  after clearing scratchpad memory. 
2262b           *  Use 'B @RUNLI1' to exit your program.
2263b           ********@*****@*********************@**************************
2264b 6A0A 04E0 RUNLIB  CLR   @>8302                ; Reset exit flag (R1 in workspace WS1!)
2264b 6A0C 8302  
2265b           *--------------------------------------------------------------
2266b           * Alternative entry point
2267b           *--------------------------------------------------------------         
2268b 6A0E 0300 RUNLI1  LIMI  0                     ; Turn off interrupts
2268b 6A10 0000  
2269b 6A12 02E0         LWPI  WS1                   ; Activate workspace 1
2269b 6A14 8300  
2270b 6A16 C0E0         MOV   @>83C0,R3             ; Get random seed from OS monitor
2270b 6A18 83C0  
2271b           *--------------------------------------------------------------
2272b           * Clear scratch-pad memory from R4 upwards
2273b           *--------------------------------------------------------------                      
2274b 6A1A 0202 RUNLI2  LI    R2,>8308
2274b 6A1C 8308  
2275b 6A1E 04F2 RUNLI3  CLR   *R2+                  ; Clear scratchpad >8306->83FF
2276b 6A20 0282         CI    R2,>8400
2276b 6A22 8400  
2277b 6A24 16FC         JNE   RUNLI3        
2278b           *--------------------------------------------------------------
2279b           * Exit to TI-99/4A title screen ?
2280b           *--------------------------------------------------------------             
2281b 6A26 0281         CI    R1,>FFFF              ; Exit flag set ?
2281b 6A28 FFFF  
2282b 6A2A 1602         JNE   RUNLI4                ; No, continue
2283b 6A2C 0420         BLWP  @0                    ; Yes, bye bye
2283b 6A2E 0000  
2284b           *--------------------------------------------------------------
2285b           * Determine if VDP is PAL or NTSC 
2286b           *--------------------------------------------------------------         
2287b 6A30 C803 RUNLI4  MOV   R3,@WSEED             ; Set random seed value
2287b 6A32 833A  
2288b 6A34 04C1         CLR   R1                    ; Reset counter
2289b 6A36 0202         LI    R2,10                 ; We test 10 times
2289b 6A38 000A  
2290b 6A3A C0E0 RUNLI5  MOV   @VDPS,R3
2290b 6A3C 8802  
2291b 6A3E 20E0         COC   @WBIT0,R3             ; Interupt flag set ?
2291b 6A40 6026  
2292b 6A42 1302         JEQ   RUNLI6
2293b 6A44 0581         INC   R1                    ; Increase counter
2294b 6A46 10F9         JMP   RUNLI5
2295b 6A48 0602 RUNLI6  DEC   R2                    ; Next test
2296b 6A4A 16F7         JNE   RUNLI5
2297b 6A4C 0281         CI    R1,>1250              ; Max for NTSC reached ?
2297b 6A4E 1250  
2298b 6A50 1202         JLE   RUNLI7                ; No, so it must be NTSC
2299b 6A52 026C         ORI   CONFIG,PALON          ; Yes, it must be PAL, set flag
2299b 6A54 2000  
2300b           *--------------------------------------------------------------
2301b           * Prepare tight loop
2302b           *--------------------------------------------------------------                 
2303b 6A56 06A0 RUNLI7  BL    @CPYM2M
2303b 6A58 60C0  
2304b 6A5A 606A         DATA  MCCODE,MCLOOP+2,6     ; Copy machine code to scratchpad        
2304b 6A5C 8322  
2304b 6A5E 0006  
2305b           *--------------------------------------------------------------
2306b           * Determine TI-99/4A operating system version
2307b           *--------------------------------------------------------------         
2308b 6A60 06A0         BL    @CPYG2M               ; Read GROM >0480 into TMP0
2308b 6A62 6152  
2309b 6A64 0480         DATA  >0480,R3HB,2        
2309b 6A66 8306  
2309b 6A68 0002  
2310b 6A6A 8803         C     R3,@TMP004            ; Check for TI-99/4
2310b 6A6C 6AC4  
2311b 6A6E 1304         JEQ   RUNLI8
2312b 6A70 8803         C     R3,@TMP005            ; Check for TI-99/4A V2.2
2312b 6A72 6AC6  
2313b 6A74 1303         JEQ   RUNLI9
2314b 6A76 1004         JMP   RUNLIA                ; It's a TI-99/4A v1
2315b           *--------------------------------------------------------------
2316b           *    It's a TI-99/4 .... PANIC !
2317b           *--------------------------------------------------------------          
2318b 6A78 0701 RUNLI8  SETO  R1                    ; Set reset flag
2319b 6A7A 10C9         JMP   RUNLI1                ; Bye bye
2320b           *--------------------------------------------------------------
2321b           *    It's a TI-99/4A v2.2
2322b           *--------------------------------------------------------------          
2323b 6A7C 026C RUNLI9  ORI   CONFIG,V22OS          ; Set V2.2 flag        
2323b 6A7E 0020  
2324b           *--------------------------------------------------------------
2325b           * Initialize registers, memory, ...
2326b           *--------------------------------------------------------------             
2327b 6A80 04C1 RUNLIA  CLR   R1
2328b 6A82 04C2         CLR   R2
2329b 6A84 04C3         CLR   R3
2330b 6A86 0209         LI    STACK,>8400           ; Set stack
2330b 6A88 8400  
2331b 6A8A 020F         LI    R15,VDPW              ; Set VDP write address
2331b 6A8C 8C00  
2332b 6A8E 06A0         BL    @MUTE                 ; Mute sound generators                
2332b 6A90 652C  
2333b           *--------------------------------------------------------------
2334b           * Setup video memory
2335b           *--------------------------------------------------------------
2336b 6A92 06A0         BL    @VIDTAB               ; Load video mode table into VDP
2336b 6A94 61D8  
2337b 6A96 6054         DATA  SPVMOD                ; See VIDTAB for details
2338b 6A98 06A0         BL    @FILV
2338b 6A9A 6098  
2339b 6A9C 0000         DATA  >0000,>00,16000       ; Clear VDP memory 
2339b 6A9E 0000  
2339b 6AA0 3E80  
2340b 6AA2 06A0         BL    @FILV
2340b 6AA4 6098  
2341b 6AA6 0380         DATA  >0380,SPFCLR,16       ; Load color table
2341b 6AA8 00A0  
2341b 6AAA 0010  
2342b           *--------------------------------------------------------------
2343b           * Load font
2344b           *--------------------------------------------------------------        
2345b 6AAC 0204         LI    TMP0,SPFONT           ; Get font option
2345b 6AAE 800C  
2346b 6AB0 0544         INV   TMP0                  ; NOFONT (>FFFF) specified ?
2347b 6AB2 1304         JEQ   RUNLIC                ; Yes, skip it
2348b 6AB4 06A0         BL    @LDFNT
2348b 6AB6 62F6  
2349b 6AB8 0900         DATA  >0900,SPFONT          ; Load specified font                
2349b 6ABA 800C  
2350b           *--------------------------------------------------------------
2351b           * Branch to main program
2352b           *--------------------------------------------------------------                        
2353b 6ABC 026C RUNLIC  ORI   CONFIG,ENKNL          ; Enable kernel thread                
2353b 6ABE 0040  
2354b 6AC0 0460         B     @MAIN                 ; Give control to main program
2354b 6AC2 6AC8  
2355b 6AC4 48FC TMP004  DATA  >48FC                 ; TI-99/4   1979
2356b 6AC6 5632 TMP005  DATA  >5632                 ; TI-99/4A  1983  V2.2
2357b           *       DATA  >0A01                 ; TI-99/4A  1981  V1        
2358b           * :..
2359b                   
->End Level [b] *               'D:\Projekte\spectra2\tms9900\runlib.a99'
  25            *--------------------------------------------------------------
  26            * SPECTRA2 startup options
  27            *--------------------------------------------------------------
  28  0000 6054 SPVMOD  EQU   GRAPH1                ; Video mode.   See VIDTAB for details.
  29  0000 800C SPFONT  EQU   FNOPT7                ; Font to load. See LDFONT for details.
  30  0000 00A0 SPFCLR  EQU   >A0                   ; Foreground/Background color for font.
  31  0000 0001 SPFBCK  EQU   >01                   ; Screen background color.        
  32            *--------------------------------------------------------------
  33            * Game memory setup
  34            *--------------------------------------------------------------
  35  0000 8340 SCORE   EQU   >8340                 ; Score
  36  0000 8342 LIVES   EQU   >8342                 ; Lives
  37  0000 8344 LEVEL   EQU   >8344                 ; Level
  38  0000 8346 GASTAT  EQU   >8346                 ; Game status flags
  39  0000 8348 BSPEED  EQU   >8348                 ; Killer bee speed variable
  40  0000 834A BUFFER  EQU   >834A                 ; Working buffer (6 bytes)
  41  0000 8350 TIMERS  EQU   >8350                 ; Timer table
  42  0000 8370 RAMSAT  EQU   >8370                 ; Our SAT in scratchpad memory
  43  0000 834A COUNTER EQU   BUFFER                ; Temporary counter
  44            ***************************************************************
  45            * Initial game setup
  46            ********@*****@*********************@**************************
  47  6AC8 06A0 MAIN    BL    @CPYM2V
  47  6ACA 610A  
  48  6ACC 0808         DATA  >0808,TLTPAT,8*8      ; Load patterns for title letters
  48  6ACE 7265  
  48  6AD0 0040  
  49  6AD2 06A0         BL    @CPYM2V
  49  6AD4 610A  
  50  6AD6 0908         DATA  >0908,LETTRS,73*8     ; Load font into VDP
  50  6AD8 72A5  
  50  6ADA 0248  
  51  6ADC 06A0         BL    @FILV
  51  6ADE 6098  
  52  6AE0 0380         DATA  >0380,>1A,16          ; Fill color table
  52  6AE2 001A  
  52  6AE4 0010  
  53  6AE6 06A0         BL    @PUTVR
  53  6AE8 6212  
  54  6AEA 070A         DATA  >070A                 ; VDP#7 - Set background color
  55  6AEC 06A0         BL    @CPYM2V
  55  6AEE 610A  
  56  6AF0 1000         DATA  >1000,SPRPAT,11*32    ; Load sprite patterns into VDP
