   1b           ***************************************************************
   2b           * Honeycomb Rapture - (c) 2010 by Owen Brand
   3b           *
   4b           * Cartridge conversion by Retroclouds
   5b           *
   6b           * This file: hc_source3.a99
   7b           ***************************************************************
   8b           * Game over
   9b           ********@*****@*********************@**************************
  10b           
  11b                  
  12b           **************************************************************
  13b           * Thread GOGAME - Resume or game over
  14b           ********@*****@*********************@************************** 
  15b 6EB6 0620 GOGAME  DEC   @LIVES                ; Lives = Lives - 1
  15b 6EB8 8342  
  16b 6EBA 1311         JEQ   GOGAM1                ; GAME OVER ?
  17b 6EBC C820         MOV   @SPRSAT+4,@RAMSAT+4   ; Restore bee start position        
  17b 6EBE 6FAE  
  17b 6EC0 8374  
  18b 6EC2 06A0         BL    @PUTAT
  18b 6EC4 6398  
  19b 6EC6 060A         DATA  >060A,GO              ; Here we go ....        
  19b 6EC8 700D  
  20b 6ECA 4820         SZC   @WBIT0,@GASTAT        ; Reset "bee killed" flag
  20b 6ECC 6026  
  20b 6ECE 8346  
  21b 6ED0 E320         SOC   @WBIT13,CONFIG        ; Resume sound player
  21b 6ED2 6040  
  22b 6ED4 06A0         BL    @PUTVR
  22b 6ED6 6212  
  23b 6ED8 070A         DATA  >070A                 ; VDP#7 - Set background color  
  24b 6EDA 0460         B     @GAME1                ; Update stats & resume game              
  24b 6EDC 6C38  
  25b           *--------------------------------------------------------------
  26b           *  Game over
  27b           *--------------------------------------------------------------        
  28b 6EDE 06A0 GOGAM1  BL    @SCROFF               ; Screen off
  28b 6EE0 6240  
  29b 6EE2 06A0         BL    @VPUTB
  29b 6EE4 61B8  
  30b 6EE6 0300         DATA  >0300,>D0             ; End of sprite processing
  30b 6EE8 00D0  
  31b 6EEA 06A0         BL    @FILV
  31b 6EEC 6098  
  32b 6EEE 0000         DATA  >0000,00,768          ; Fill screen        
  32b 6EF0 0000  
  32b 6EF2 0300  
  33b 6EF4 06A0         BL    @FILV
  33b 6EF6 6098  
  34b 6EF8 0380         DATA  >0380,>16,16          ; Set colors black/red
  34b 6EFA 0016  
  34b 6EFC 0010  
  35b 6EFE 06A0         BL    @SCRON                ; Screen on
  35b 6F00 6246  
  36b 6F02 06A0         BL    @MKSLOT
  36b 6F04 6988  
  37b 6F06 0020         DATA  >0020,SHOW1,EOL       ; Display msg with 0.5 seconds interval 
  37b 6F08 6F12  
  37b 6F0A FFFF  
  38b 6F0C 04CA         CLR   R10                   ; Set highest slot to 0  
  39b 6F0E 0460         B     @SLOTOK               ; Back to Thread Scheduler
  39b 6F10 696A  
  40b                   
  41b                   
  42b           ***************************************************************
  43b           * Thread SHOW. - Display "game over" messages
  44b           ********@*****@*********************@************************** 
  45b 6F12 06A0 SHOW1   BL    @PUTAT
  45b 6F14 6398  
  46b 6F16 0505         DATA  >0505,MSG1            ; Line 1                         
  46b 6F18 7018  
  47b 6F1A 06A0         BL    @SDPREP
  47b 6F1C 654A  
  48b 6F1E 789A         DATA  SOUND2,SDOPT2         ; Start "game over" tune
  48b 6F20 0005  
  49b 6F22 C820         MOV   @TMP50,@TIMERS        ; Update slot 0 thread address
  49b 6F24 6F7A  
  49b 6F26 8350  
  50b 6F28 1026         JMP   SHOWZ
  51b 6F2A 06A0 SHOW2   BL    @PUTAT
  51b 6F2C 6398  
  52b 6F2E 0703         DATA  >0703,MSG2            ; Line 2
  52b 6F30 7031  
  53b 6F32 101E         JMP   SHOWY
  54b 6F34 06A0 SHOW3   BL    @PUTAT
  54b 6F36 6398  
  55b 6F38 0905         DATA  >0905,MSG3            ; Line 3
  55b 6F3A 704D  
  56b 6F3C 1019         JMP   SHOWY
  57b 6F3E 06A0 SHOW4   BL    @PUTAT
  57b 6F40 6398  
  58b 6F42 0B09         DATA  >0B09,MSG4            ; Line 4
  58b 6F44 7065  
  59b 6F46 1014         JMP   SHOWY
  60b 6F48 06A0 SHOW5   BL    @PUTAT
  60b 6F4A 6398  
  61b 6F4C 0F07         DATA  >0F07,MSG5            ; Line 5       
  61b 6F4E 7073  
  62b 6F50 06A0         BL    @PUTNUM
  62b 6F52 6522  
  63b 6F54 0F15         DATA  >0F15,SCORE,BUFFER,>3030
  63b 6F56 8340  
  63b 6F58 834A  
  63b 6F5A 3030  
  64b 6F5C 06A0         BL    @MKHOOK
  64b 6F5E 69D4  
  65b 6F60 6F7E         DATA  WAIKEY                ; User hook - restart game when key pressed        
  66b 6F62 06A0         BL    @MKSLOT
  66b 6F64 6988  
  67b 6F66 000A         DATA  >000A,BLKMSG,EOL      ; Blink text "PRESS ANY KEY TO PLAY AGAIN"
  67b 6F68 6F8C  
  67b 6F6A FFFF  
  68b 6F6C 0700         SETO  R0                    ; Use R0 as toggle for BLKMSG
  69b 6F6E 1003         JMP   SHOWZ
  70b           *--------------------------------------------------------------
  71b           *  Update subroutine address in slot 0
  72b           *--------------------------------------------------------------            
  73b 6F70 A820 SHOWY   A     @ADD10,@TIMERS        ; Update slot 0 thread address
  73b 6F72 6F7C  
  73b 6F74 8350  
  74b 6F76 0460 SHOWZ   B     @SLOTOK               ; Back to Thread Scheduler
  74b 6F78 696A  
  75b 6F7A 6F2A TMP50   DATA  SHOW2
  76b 6F7C 000A ADD10   DATA  10                    ; Offset between SHOW1 -> SHOW2 -> SHOW3 -> ... is fixed !!!
  77b           
  78b           
  79b           
  80b           ***************************************************************
  81b           * User hook TSTKEY - Restart game upon keypress
  82b           ********@*****@*********************@************************** 
  83b 6F7E 2320 WAIKEY  COC   @ANYKEY,R12
  83b 6F80 603C  
  84b 6F82 1602         JNE   WAIKE1
  85b 6F84 0460         B     @RUNLIB               ; Restart game
  85b 6F86 6A0A  
  86b 6F88 0460 WAIKE1  B     @HOOKOK
  86b 6F8A 68EC  
  87b           
  88b           ***************************************************************
  89b           * THREAD - Blink message "PRESS ANY KEY TO PLAY AGAIN"
  90b           ********@*****@*********************@************************** 
  91b 6F8C 0540 BLKMSG  INV   R0
  92b 6F8E 1305         JEQ   BLKMS1
  93b 6F90 06A0         BL    @PUTAT
  93b 6F92 6398  
  94b 6F94 1303         DATA  >1303,MSG6            ; Show messsage        
  94b 6F96 707E  
  95b 6F98 1005         JMP   BLKMS2
  96b 6F9A 06A0 BLKMS1  BL    @HCHAR
  96b 6F9C 63A0  
  97b 6F9E 1303         DATA  >1303,>001C,EOL       ; Erase line 6        
  97b 6FA0 001C  
  97b 6FA2 FFFF  
  98b 6FA4 0460 BLKMS2  B     @SLOTOK               ; Exit
  98b 6FA6 696A  
->End Level [b] *               'hc_source3.a99'
