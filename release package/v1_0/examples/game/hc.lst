 239b           ***************************************************************
 240b           * Thread MVKBEE - Move the killer bees
 241b           ***************************************************************
 242b 6E24 C10A MVKBEE  MOV  R10,TMP0               ; Get slot number
 243b 6E26 0244         ANDI TMP0,>00FF             ; Get rid of high byte
 243b 6E28 00FF  
 244b           *--------------------------------------------------------------
 245b           *  index = ((slot - 1) << 2) + 1
 246b           *--------------------------------------------------------------         
 247b 6E2A 0604         DEC  TMP0,1                 ; index = slot - 1
 248b 6E2C 0A24         SLA  TMP0,2                 ; index << 2
 249b 6E2E 0584         INC  TMP0                   ; index++ 
 250b 6E30 C14A         MOV  R10,TMP1               ; Get slot number
 251b 6E32 6160         S    @BSPEED,TMP1           ; Higher slots go faster
 251b 6E34 8348  
 252b 6E36 0915         SRL  TMP1,1
 253b 6E38 7905         SB   TMP1,@RAMSAT(TMP0)     ; RAMSAT address of killer bee X position
 253b 6E3A 8370  
 254b 6E3C 045B         B    *R11
 255b           
 256b           ***************************************************************
 257b           * Thread SPNBEE - Do spin bee sequence
 258b           ********@*****@*********************@************************** 
 259b 6E3E C820 SPNBEE  MOV   @BEEPOS,@RAMSAT+4     ; Reposition bee
 259b 6E40 6E84  
 259b 6E42 8374  
 260b 6E44 C060         MOV   @COUNTER,R1
 260b 6E46 834A  
 261b 6E48 0281         CI    R1,2                  ; Already spinned 2 times ?
 261b 6E4A 0002  
 262b 6E4C 160B         JNE   SPNBE1                ; No continue                
 263b           *--------------------------------------------------------------
 264b           *  Show message "Oops be careful"
 265b           *--------------------------------------------------------------          
 266b 6E4E 06A0         BL    @PUTAT
 266b 6E50 6398  
 267b 6E52 0508         DATA  >0508,OOPS            ; Ooops be careful....
 267b 6E54 6FFD  
 268b 6E56 06A0         BL    @MKSLOT        
 268b 6E58 6988  
 269b 6E5A 0240         DATA  >0240,GOGAME,EOL      ; Set delay   
 269b 6E5C 6EB6  
 269b 6E5E FFFF  
 270b 6E60 0460         B     @SLOTOK               ; Exit
 270b 6E62 696A  
 271b           *--------------------------------------------------------------
 272b           *  Spin the bee
 273b           *--------------------------------------------------------------                  
 274b 6E64 04C1 SPNBE1  CLR   R1
 275b 6E66 D060         MOVB  @RAMSAT+6,R1
 275b 6E68 8376  
 276b 6E6A 0281         CI    R1,>2000              ; Last pattern ?
 276b 6E6C 2000  
 277b 6E6E 1605         JNE   SPNBE2
 278b 6E70 0201         LI    R1,>0400
 278b 6E72 0400  
 279b 6E74 05A0         INC   @COUNTER              ; Counter = Counter + 1
 279b 6E76 834A  
 280b 6E78 1002         JMP   SPNBE3
 281b 6E7A 0221 SPNBE2  AI    R1,>0400              ; pattern = pattern + 4
 281b 6E7C 0400  
 282b 6E7E D801 SPNBE3  MOVB  R1,@RAMSAT+6
 282b 6E80 8376  
 283b 6E82 045B         B     *R11                  ; Exit        
 284b 6E84 5A78 BEEPOS  DATA  >5A78                 ; Y=90, X=120
 285b           
 286b           
 287b           ***************************************************************
 288b           * Thread MVPLAN - Move plane accross the screen
 289b           ***************************************************************
 290b 6E86 9820 MVPLAN  CB    @RAMSAT+1,@TMPDAT     ; Screen boundary reached ?
 290b 6E88 8371  
 290b 6E8A 6E9C  
 291b 6E8C 1303         JEQ   MVPLA1                ; Yes, X=0
 292b 6E8E 05A0         INC   @RAMSAT               ; No,  X=X+1
 292b 6E90 8370  
 293b 6E92 1003         JMP   MVPLA2                ; Exit
 294b 6E94 D820 MVPLA1  MOVB  @BD0,@RAMSAT+1        ; X=0
 294b 6E96 6048  
 294b 6E98 8371  
 295b 6E9A 045B MVPLA2  B     *R11                  ; Exit
 296b 6E9C FE00 TMPDAT  DATA  >FE00        
 297b           
 298b           
 299b           **************************************************************
 300b           * Thread CLRMSG - Clear message
 301b           ********@*****@*********************@**************************
 302b 6E9E 06A0 CLRMSG  BL    @HCHAR        
 302b 6EA0 63A0  
 303b 6EA2 0508         DATA  >0508,>200F           ; Clear 1st message line
 303b 6EA4 200F  
 304b 6EA6 060A         DATA  >060A,>200F,EOL       ; Clear 2nd message line
 304b 6EA8 200F  
 304b 6EAA FFFF  
 305b 6EAC 06A0         BL    @CLSLOT
 305b 6EAE 69A6  
 306b 6EB0 0006         DATA  6                     ; Clear slot 6
 307b 6EB2 0460         B     @SLOTOK               ; Exit        
 307b 6EB4 696A  
->End Level [b] *               'hc_source2.a99'
