  81b           ***************************************************************
  82b           * User hook - Check for coincidence
  83b           ***************************************************************
  84b 6C92 2360 COINC   COC  @WBIT2,R13             ; Coincidence bit set ?
  84b 6C94 602A  
  85b 6C96 1619         JNE  COINCZ                 ; No, exit
  86b 6C98 C020         MOV  @GASTAT,R0             ; Sequence already busy
  86b 6C9A 8346  
  87b 6C9C 2020         COC  @WBIT0,R0
  87b 6C9E 6026  
  88b 6CA0 1314         JEQ  COINCZ
  89b           *--------------------------------------------------------------
  90b           * Bee gets killed by killer bee
  91b           *--------------------------------------------------------------        
  92b 6CA2 06A0         BL    @MUTE2                ; Pause sound player
  92b 6CA4 6530  
  93b 6CA6 E820         SOC   @WBIT0,@GASTAT        ; Bee killed = 1
  93b 6CA8 6026  
  93b 6CAA 8346  
  94b 6CAC 06A0         BL    @CPYM2V
  94b 6CAE 610A  
  95b 6CB0 0380         DATA  >0380,COLOR2,16       ; Load 2nd color table into VDP
  95b 6CB2 70AA  
  95b 6CB4 0010  
  96b 6CB6 06A0         BL    @PUTVR
  96b 6CB8 6212  
  97b 6CBA 0706         DATA  >0706                 ; VDP#7 - Set background color
  98b 6CBC 06A0         BL    @MKSLOT        
  98b 6CBE 6988  
  99b 6CC0 0207         DATA  >0207,SPNBEE,EOL      ; Start "spin bee" sequence
  99b 6CC2 6E3E  
  99b 6CC4 FFFF  
 100b 6CC6 04E0         CLR   @COUNTER
 100b 6CC8 834A  
 101b 6CCA 0460 COINCZ  B     @HOOKOK               ; Exit
 101b 6CCC 68EC  
 102b           
 103b           
 104b           ***************************************************************
 105b           * Thread DMPSAT - Dump SAT to VDP
 106b           ***************************************************************
 107b 6CCE C060 DMPSAT  MOV   @GASTAT,R1            ; Get game status flags        
 107b 6CD0 8346  
 108b 6CD2 2060         COC   @WBIT0,R1             ; Bee kill sequence busy ?
 108b 6CD4 6026  
 109b 6CD6 1306         JEQ   DMPSA1        
 110b           *--------------------------------------------------------------
 111b           *  Dump SAT containing killer bees
 112b           *--------------------------------------------------------------               
 113b 6CD8 06A0         BL    @CPYM2V
 113b 6CDA 610A  
 114b 6CDC 0300         DATA  >0300,RAMSAT,6*4      ; Dump SAT to VDP           
 114b 6CDE 8370  
 114b 6CE0 0018  
 115b 6CE2 100A         JMP   DMPSAZ
 116b           *--------------------------------------------------------------
 117b           *  Dump SAT for bee died sequence
 118b           *--------------------------------------------------------------       
 119b 6CE4 06A0 DMPSA1  BL    @CPYM2V
 119b 6CE6 610A  
 120b 6CE8 0300         DATA  >0300,RAMSAT,2*4      ; Dump SAT to VDP      
 120b 6CEA 8370  
 120b 6CEC 0008  
 121b 6CEE 06A0         BL    @FILV
 121b 6CF0 6098  
 122b 6CF2 0308         DATA  >0308,>D0,1           ; End of sprite processing     
 122b 6CF4 00D0  
 122b 6CF6 0001  
 123b 6CF8 0460 DMPSAZ  B     @SLOTOK               ; Exit
 123b 6CFA 696A  
 124b           
 125b           
 126b           
 127b           
 128b           ********@*****@*********************@**************************
 129b 6CFC A820 DOSCOR  A     @ADD100,@SCORE
 129b 6CFE 6E22  
 129b 6D00 8340  
 130b 6D02 06A0         BL    @PUTNUM               ; Display score, fill with '0'
 130b 6D04 6522  
 131b 6D06 0102         DATA  >0102,SCORE,BUFFER,>3030 
 131b 6D08 8340  
 131b 6D0A 834A  
 131b 6D0C 3030  
 132b 6D0E C820         MOV   @SPRSAT+4,@RAMSAT+4   ; Restore bee start position  
 132b 6D10 6FAE  
 132b 6D12 8374  
 133b 6D14 7820         SB    @BD1,@BSPEED          ; Increase killer bee speed
 133b 6D16 6049  
 133b 6D18 8348  
 134b 6D1A 06A0         BL    @SDPREP
 134b 6D1C 654A  
 135b 6D1E 78E3         DATA  SOUND3,SDOPT2         ; Start "score" tune        
 135b 6D20 0005  
 136b 6D22 0460         B     @SLOTOK               ; Return to Thread Scheduler
 136b 6D24 696A  
 137b           
 138b           
 139b           ***************************************************************
 140b           * Thread MVBEE - Move the bee
 141b           ***************************************************************
 142b 6D26 2320 MVBEE   COC   @WBIT11,CONFIG        ; ANY key pressed ?
 142b 6D28 603C  
 143b 6D2A 1304         JEQ   MVBEE1                ; Yes, check keys
 144b 6D2C C820         MOV   @MVLIST+40,@RAMSAT+6  ; Update pattern/color
 144b 6D2E 6E12  
 144b 6D30 8376  
 145b 6D32 045B         B     *R11                  ; Exit
 146b 6D34 C120 MVBEE1  MOV   @WVRTKB,TMP0          ; Get keyboard flags    
 146b 6D36 8332  
 147b 6D38 0205         LI    TMP1,MVLIST           ; List
 147b 6D3A 6DEA  
 148b 6D3C 0206         LI    TMP2,8                ; List counter
 148b 6D3E 0008  
 149b           *--------------------------------------------------------------
 150b           *    Check direction
 151b           *--------------------------------------------------------------        
 152b 6D40 2115 MVBEE2  COC   *TMP1,TMP0
 153b 6D42 1608         JNE   MVBEE3
 154b 6D44 4135         SZC   *TMP1+,TMP0           ; Remove this key combination
 155b 6D46 B835         AB    *TMP1+,@RAMSAT+4      ; Update Y
 155b 6D48 8374  
 156b 6D4A B835         AB    *TMP1+,@RAMSAT+5      ; Update X
 156b 6D4C 8375  
 157b 6D4E C835         MOV   *TMP1+,@RAMSAT+6      ; Update pattern/color
 157b 6D50 8376  
 158b 6D52 1002         JMP   MVBEE4
 159b 6D54 0225 MVBEE3  AI    TMP1,6
 159b 6D56 0006  
 160b 6D58 0606 MVBEE4  DEC   TMP2
 161b 6D5A 16F2         JNE   MVBEE2
 162b           *--------------------------------------------------------------
 163b           *    Prepare for checking Y-boundaries
 164b           *--------------------------------------------------------------
 165b 6D5C 024C         ANDI  CONFIG,>7FFF          ; CONFIG register bit 0=0
 165b 6D5E 7FFF  
 166b 6D60 C120         MOV   @RAMSAT+4,TMP0        ; Sprite YX in TMP0
 166b 6D62 8374  
 167b 6D64 C160         MOV   @MVLIM,TMP1           ; Get Y-boundaries
 167b 6D66 6E1A  
 168b           *--------------------------------------------------------------
 169b           *       Compare boundaries
 170b           *--------------------------------------------------------------
 171b 6D68 9144 MVBEE5  CB    TMP0,TMP1             ; Compare min
 172b 6D6A 1401         JHE   MVBEE6
 173b 6D6C D105         MOVB  TMP1,TMP0             ; Set sprite min
 174b 6D6E 06C5 MVBEE6  SWPB  TMP1                  ; Swap min/max
 175b 6D70 9144         CB    TMP0,TMP1             ; Compare max        
 176b 6D72 1201         JLE   MVBEE7
 177b 6D74 D105         MOVB  TMP1,TMP0             ; Set sprite max
 178b           *--------------------------------------------------------------
 179b           *    Prepare for checking X-boundaries
 180b           *--------------------------------------------------------------       
 181b 6D76 2320 MVBEE7  COC   @WBIT0,CONFIG         ; X-already checked ?
 181b 6D78 6026  
 182b 6D7A 1306         JEQ   MVBEE8
 183b 6D7C 026C         ORI   CONFIG,>8000          ; CONFIG register bit 0=1
 183b 6D7E 8000  
 184b 6D80 06C4         SWPB  TMP0                  ; Bee YX -> XY
 185b 6D82 C160         MOV   @MVLIM+2,TMP1         ; Get X-boundaries
 185b 6D84 6E1C  
 186b 6D86 10F0         JMP   MVBEE5
 187b           *--------------------------------------------------------------
 188b           *    Update RAMSAT
 189b           *--------------------------------------------------------------         
 190b 6D88 06C4 MVBEE8  SWPB  TMP0                  ; Bee XY -> YX
 191b 6D8A C804         MOV   TMP0,@RAMSAT+4        ; Save updated YX in RAMSAT
 191b 6D8C 8374  
 192b 6D8E 024C         ANDI  CONFIG,>7FFF          ; CONFIG register bit 0=0
 192b 6D90 7FFF  
 193b           *--------------------------------------------------------------
 194b           *    Check if bee reached honeycomb
 195b           *-------------------------------------------------------------- 
 196b 6D92 9804 MVBEE9  CB    TMP0,@MVCOMB          ; Y position greater than >48 ?
 196b 6D94 6E1E  
 197b 6D96 1527         JGT   MVBEEZ
 198b 6D98 0A84         SLA   TMP0,8
 199b 6D9A 9804         CB    TMP0,@MVCOMB+1        ; X position less than >D0 ?
 199b 6D9C 6E1F  
 200b 6D9E 1123         JLT   MVBEEZ
 201b 6DA0 9804         CB    TMP0,@MVCOMB+2        ; X position greater than >E0 ?
 201b 6DA2 6E20  
 202b 6DA4 1520         JGT   MVBEEZ
 203b           *--------------------------------------------------------------
 204b           *    Yes, now update score
 205b           *--------------------------------------------------------------         
 206b 6DA6 A820         A     @ADD100,@SCORE
 206b 6DA8 6E22  
 206b 6DAA 8340  
 207b 6DAC 06A0         BL    @PUTNUM               ; Display score, fill with '0'
 207b 6DAE 6522  
 208b 6DB0 0102         DATA  >0102,SCORE,BUFFER,>3030 
 208b 6DB2 8340  
 208b 6DB4 834A  
 208b 6DB6 3030  
 209b 6DB8 C820         MOV   @SPRSAT+4,@RAMSAT+4   ; Restore bee start position  
 209b 6DBA 6FAE  
 209b 6DBC 8374  
 210b 6DBE 7820         SB    @BD1,@BSPEED          ; Increase killer bee speed
 210b 6DC0 6049  
 210b 6DC2 8348  
 211b 6DC4 06A0         BL    @SDPREP
 211b 6DC6 654A  
 212b 6DC8 78E3         DATA  SOUND3,SDOPT2         ; Start "score" tune        
 212b 6DCA 0005  
 213b 6DCC 06A0         BL    @MKSLOT
 213b 6DCE 6988  
 214b 6DD0 0630         DATA  >0630,MVBEEY,EOL      ; Restart "game" tune in 1 second
 214b 6DD2 6DD8  
 214b 6DD4 FFFF  
 215b 6DD6 1007         JMP   MVBEEZ
 216b           *--------------------------------------------------------------
 217b           *    Restart "game" tune
 218b           *--------------------------------------------------------------             
 219b 6DD8 06A0 MVBEEY  BL    @SDPREP
 219b 6DDA 654A  
 220b 6DDC 7605         DATA  SOUND1,SDOPT1         ; Start tune
 220b 6DDE 0007  
 221b 6DE0 06A0         BL    @CLSLOT               ; Clear slot
 221b 6DE2 69A6  
 222b 6DE4 0006         DATA  6
 223b           *--------------------------------------------------------------
 224b           *    Exit
 225b           *--------------------------------------------------------------     
 226b 6DE6 0460 MVBEEZ  B     @SLOTOK               ; Exit        
 226b 6DE8 696A  
 227b 6DEA 0280 MVLIST  DATA  K1UPLF,>FFFF,>2001    ; Up-left
 227b 6DEC FFFF  
 227b 6DEE 2001  
 228b 6DF0 0180         DATA  K1UPRG,>FF01,>0801    ; Up-right
 228b 6DF2 FF01  
 228b 6DF4 0801  
 229b 6DF6 0240         DATA  K1DNLF,>01FF,>1801    ; Down-left   
 229b 6DF8 01FF  
 229b 6DFA 1801  
 230b 6DFC 0140         DATA  K1DNRG,>0101,>1001    ; Down-right
 230b 6DFE 0101  
 230b 6E00 1001  
 231b 6E02 0200         DATA  K1LF,>00FF,>1C01      ; Left
 231b 6E04 00FF  
 231b 6E06 1C01  
 232b 6E08 0100         DATA  K1RG,>0001,>0C01      ; Right
 232b 6E0A 0001  
 232b 6E0C 0C01  
 233b 6E0E 0080         DATA  K1UP,>FF00,>0401      ; Up         
 233b 6E10 FF00  
 233b 6E12 0401  
 234b 6E14 0040         DATA  K1DN,>0100,>1401      ; Down
 234b 6E16 0100  
 234b 6E18 1401  
 235b 6E1A 38A7 MVLIM   DATA  >38A7,>05F0           ; Bee screen boundaries (y-min,y-max,x-min,x-max)       
 235b 6E1C 05F0  
 236b 6E1E 40D4 MVCOMB  BYTE  >40,>D4,>DC,>00       ; Honeycomb boundaries  (y-max,X-min,x-max,dummy)
 236b 6E20 DC00  
 237b 6E22 0064 ADD100  DATA 100                    ; 100 points
