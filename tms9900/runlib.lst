  0184            ************************************************************
  0185            * The config register equates
  0186            *-----------------------------------------------------------
  0187            * Configuration flags
  0188            * ===================
  0189            * 
  0190            * ; 15  Sound player: tune source       1=ROM/RAM      0=VDP
  0191            * ; 14  Sound player: repeat tune       1=yes          0=no
  0192            * ; 13  Sound player: enabled           1=yes          0=no 
  0193            * ; 12  Keyboard: mode                  1=real         0=vir
  0194            * ; 11  Keyboard: ANY key pressed       1=yes          0=no
  0195            * ; 10  TI-99/4A v2.2 OS                1=yes          0=no
  0196            * ; 09  Timer: Kernel thread enabled    1=yes          0=no
  0197            * ; 08  Timer: Block kernel thread      1=yes          0=no	
  0198            * ; 07  Timer: User hook enabled        1=yes          0=no	
  0199            * ; 06  Timer: Block user hook          1=yes          0=no
  0200            * ; 05  speech player: external voice   1=yes          0=no
  0201            * ; 04  Speech player: busy             1=yes          0=no
  0202            * ; 03  Speech player: enabled          1=yes          0=no
  0203            * ; 02  VDP9918 PAL version             1=yes(50)      0=no(
  0204            * ; 01  Subroutine state flag 1         1=on           0=off
  0205            * ; 00  Subroutine state flag 0         1=on           0=off
  0206            ********@*****@*********************@***********************
  0207      2000  PALON   EQU   >2000                 ; bit 2=1   (VDP9918 PAL
  0208      0100  ENUSR   EQU   >0100                 ; bit 7=1   (Enable user
  0209      0040  ENKNL   EQU   >0040                 ; bit 9=1   (Enable kern
  0210      0020  V22OS   EQU   >0020                 ; bit 10=1  (TI-99/4A V2
  0211            ************************************************************
  0212            * Subroutine parameter equates
  0213            ************************************************************
  0214      FFFF  EOL     EQU   >FFFF                 ; End-Of-List
  0215      FFFF  NOFONT  EQU   >FFFF                 ; Skip loading font in R
  0216      0000  NOREP   EQU   0                     ; PUTBOX => Value for P3
  0217      3030  NUM1    EQU   >3030                 ; MKNUM  => ASCII 0-9, l
  0218      3020  NUM2    EQU   >3020                 ; MKNUM  => ASCII 0-9, l
  0219      0007  SDOPT1  EQU   7                     ; SDPLAY => 111 (Player 
  0220      0005  SDOPT2  EQU   5                     ; SDPLAY => 101 (Player 
  0221      0006  SDOPT3  EQU   6                     ; SDPLAY => 110 (Player 
  0222      0004  SDOPT4  EQU   4                     ; SDPLAY => 100 (Player 
  0223      0000  FNOPT1  EQU   >0000                 ; LDFNT  => Load TI titl
  0224      0006  FNOPT2  EQU   >0006                 ; LDFNT  => Load upper c
  0225      000C  FNOPT3  EQU   >000C                 ; LDFNT  => Load upper/l
  0226      0012  FNOPT4  EQU   >0012                 ; LDFNT  => Load lower c
  0227      8000  FNOPT5  EQU   >8000                 ; LDFNT  => Load TI titl
  0228      8006  FNOPT6  EQU   >8006                 ; LDFNT  => Load upper c
  0229      800C  FNOPT7  EQU   >800C                 ; LDFNT  => Load upper/l
  0230      8012  FNOPT8  EQU   >8012                 ; LDFNT  => Load lower c
