*****  UNDEFINED SYMBOL - 0378
  0379            * ; VDP#0 Control bits
  0380            * ;      bit 6=0: M3 | Graphics 1 mode
  0381            * ;      bit 7=0: Disable external VDP input
  0382            * ; VDP#1 Control bits
  0383            * ;      bit 0=1: 16K selection
  0384            * ;      bit 1=1: Enable display
  0385            * ;      bit 2=1: Enable VDP interrupt
  0386            * ;      bit 3=0: M1 \ Graphics 1 mode
  0387            * ;      bit 4=0: M2 /
  0388            * ;      bit 5=0: reserved
  0389            * ;      bit 6=1: 16x16 sprites
  0390            * ;      bit 7=0: Sprite magnification (1x)
  0391            * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >4
  0392            * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >0
  0393            * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >8
  0394            * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >0
  0395            * ; VDP#6 SPT (Sprite pattern table)     at >1000  (>02 * >8
  0396            * ; VDP#7 Set screen background color
  0397            ************************************************************
