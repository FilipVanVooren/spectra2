*****  UNDEFINED SYMBOL - 0400
  0401            * ; VDP#0 Control bits
  0402            * ;      bit 6=0: M3 | Graphics 1 mode
  0403            * ;      bit 7=0: Disable external VDP input
  0404            * ; VDP#1 Control bits
  0405            * ;      bit 0=1: 16K selection
  0406            * ;      bit 1=1: Enable display
  0407            * ;      bit 2=1: Enable VDP interrupt
  0408            * ;      bit 3=1: M1 \ TEXT MODE
  0409            * ;      bit 4=0: M2 /
  0410            * ;      bit 5=0: reserved
  0411            * ;      bit 6=1: 16x16 sprites
  0412            * ;      bit 7=0: Sprite magnification (1x)
  0413            * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >4
  0414            * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >0
  0415            * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >8
  0416            * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >0
  0417            * ; VDP#6 SPT (Sprite pattern table)     at >0000  (>00 * >8
  0418            * ; VDP#7 Set foreground/background color
  0419            ************************************************************
  0420            
  0421            
  0422            ************************************************************
