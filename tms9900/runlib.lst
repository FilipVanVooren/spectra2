  0432 0050 16FD          DATA  >16FD                 ; |         JNE   MCLOOP
  0433 0052 045B          DATA  >045B                 ; /         B     *R11
  0434            *-----------------------------------------------------------
  0435            * ; Machine code for reading from the speech synthesizer
  0436            * ; The SRC instruction takes 12 uS for execution in scratch
  0437            * ; Is required for the 12 uS delay. It destroys R5.
  0438            *-----------------------------------------------------------
  0439 0054 D114  SPCODE  DATA  >D114                 ; \         MOVB  *R4,R4
  0440 0056 0BC5          DATA  >0BC5                 ; /         SRC   R5,12 
