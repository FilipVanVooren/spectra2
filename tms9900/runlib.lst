  0746            * RLE2V (DATA P0,P1,P2) ..:
  0747            ************************************************************
  0748            * RLE2V - RLE decompress to VRAM memory
  0749            ************************************************************
  0750            *  BL   @RLE2V
  0751            *  DATA P0,P1,P2
  0752            *-----------------------------------------------------------
  0753            *  P0 = ROM/RAM source address 
  0754            *  P1 = VDP target address
  0755            *  P2 = Length of RLE encoded data
  0756            *-----------------------------------------------------------
  0757            *  BL @RLE2VX
  0758            *

 Xa99 Cross Assembler
VERSION 1.2/A                                                PAGE 0015
  0759            *  TMP0     = VDP target address
  0760            *  TMP2 (!) = ROM/RAM source address 
  0761            *  TMP3 (!) = Length of RLE encoded data
  0762            *-----------------------------------------------------------
  0763            *  Detail on RLE compression format:
  0764            *  - If high bit is set, remaining 7 bits indicate to copy 
  0765            *    the next byte that many times.
  0766            *  - If high bit is clear, remaining 7 bits indicate how man
  0767            *    data bytes (non-repeated) follow.
  0768            ********@*****@*********************@***********************
  0769 018A C1BB  RLE2V   MOV   *R11+,TMP2            ; ROM/RAM source address
  0770 018C C13B          MOV   *R11+,TMP0            ; VDP target address
  0771 018E C1FB          MOV   *R11+,TMP3            ; Length of RLE encoded 
  0772 0190 C80B          MOV   R11,@WAUX1            ; Save return address
       0192 833C 
  0773 0194 06A0  RLE2VX  BL    @VDWA                 ; Setup VDP address from
       0196 01D0'
  0774 0198 C106          MOV   TMP2,TMP0             ; We can safely reuse TM
  0775 019A D1B4  RLE2V0  MOVB  *TMP0+,TMP2           ; Get control byte into 
  0776 019C 0607          DEC   TMP3                  ; Update length
  0777 019E 1314          JEQ   RLE2VZ                ; End of list
  0778 01A0 0A16          SLA   TMP2,1                ; Check bit 0 of control
  0779 01A2 1808          JOC   RLE2V2                ; Yes, next byte is comp
  0780            *-----------------------------------------------------------
  0781            *    Dump uncompressed bytes
  0782            *-----------------------------------------------------------
  0783 01A4 C820  RLE2V1  MOV   @RLEDAT,@MCLOOP       ; Setup machine code (MO
       01A6 01CE'
       01A8 8320 
  0784 01AA 0996          SRL   TMP2,9                ; Use control byte as co
  0785 01AC 61C6          S     TMP2,TMP3             ; Update length        
  0786 01AE 06A0          BL    @MCLOOP               ; Write data to VDP
       01B0 8320 
  0787 01B2 1008          JMP   RLE2V3                
  0788            *-----------------------------------------------------------
  0789            *    Dump compressed bytes
  0790            *-----------------------------------------------------------
  0791 01B4 C820  RLE2V2  MOV   @FILZZ,@MCLOOP        ; Setup machine code(MOV
       01B6 00A2'
       01B8 8320 
  0792 01BA 0996          SRL   TMP2,9                ; Use control byte as co
  0793 01BC 0607          DEC   TMP3                  ; Update length        
  0794 01BE D174          MOVB  *TMP0+,TMP1           ; Byte to fill
  0795 01C0 06A0          BL    @MCLOOP               ; Write data to VDP
       01C2 8320 
  0796            *-----------------------------------------------------------
  0797            *    Check if more data to decompress
  0798            *-----------------------------------------------------------
  0799 01C4 C1C7  RLE2V3  MOV   TMP3,TMP3             ; Length counter = 0 ?
  0800 01C6 16E9          JNE   RLE2V0                ; Not yet, process data
  0801            *-----------------------------------------------------------
  0802            *    Exit
  0803            *-----------------------------------------------------------
  0804 01C8 C2E0  RLE2VZ  MOV   @WAUX1,R11
       01CA 833C 
  0805 01CC 045B          B     *R11                  ; Return
  0806 01CE D7F4  RLEDAT  DATA  >D7F4                 ; MOVB *TMP0+,*R15
  0807            * :..        
