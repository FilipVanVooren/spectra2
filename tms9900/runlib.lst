  0293            * Bank switch routine ..:
  0294            ************************************************************
  0295            * SWBNK  (DATA P0, P1) / SWBNKX

 Xa99 Cross Assembler
VERSION 1.2/A                                                PAGE 0006
  0296            ************************************************************
  0297            * SWBNK - Switch ROM bank
  0298            ************************************************************
  0299            *  BL   @SWBNK
  0300            *  DATA P0,P1
  0301            *-----------------------------------------------------------
  0302            *  P0 = Bank selection address (>600X)
  0303            *  P1 = Vector address
  0304            *-----------------------------------------------------------
  0305            *  B    @SWBNKX
  0306            *
  0307            *  TMP0 = Bank selection address (>600X)
  0308            *  TMP1 = Vector address
  0309            *-----------------------------------------------------------
  0310            *  Important! The bank-switch routine must be at the exact
  0311            *  same location accross banks
  0312            ********@*****@*********************@***********************
  0313 0000 C13B  SWBNK   MOV   *R11+,TMP0
  0314 0002 C17B          MOV   *R11+,TMP1
  0315 0004 04D4  SWBNKX  CLR   *TMP0                 ; Select bank in TMP0
  0316 0006 C155          MOV   *TMP1,TMP1
  0317 0008 0455          B     *TMP1                 ; Switch to routine in T
  0318            * :..
