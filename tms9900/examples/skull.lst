  1491 64AC C15B          MOV   *R11,TMP1             ; P1 - Height/Width in T
  1492 64AE C1BB          MOV   *R11+,TMP2            ; P1 - Height/Width in T
  1493 64B0 C1FB          MOV   *R11+,TMP3            ; P2 - Pointer to string
  1494 64B2 C83B          MOV   *R11+,@WAUX1          ; P3 - Box repeat count 
       64B4 833C 
  1495 64B6 C80B          MOV   R11,@WAUX2            ; Save R11
       64B8 833E 
