  0309            * Bank switch routine ..:
  0310            ************************************************************
  0311            * SWBNK  (DATA P0, P1) / SWBNKX
  0312            ************************************************************
  0313            * SWBNK - Switch ROM bank
  0314            ************************************************************
  0315            *  BL   @SWBNK
  0316            *  DATA P0,P1
  0317            *-----------------------------------------------------------
  0318            *  P0 = Bank selection address (>600X)
  0319            *  P1 = Vector address
  0320            *-----------------------------------------------------------
  0321            *  B    @SWBNKX
  0322            *
  0323            *  TMP0 = Bank selection address (>600X)
  0324            *  TMP1 = Vector address
  0325            *-----------------------------------------------------------
  0326            *  Important! The bank-switch routine must be at the exact
  0327            *  same location accross banks
  0328            ********@*****@*********************@***********************
  0329 6020 C13B  SWBNK   MOV   *R11+,TMP0
  0330 6022 C17B          MOV   *R11+,TMP1
  0331 6024 04D4  SWBNKX  CLR   *TMP0                 ; Select bank in TMP0
  0332 6026 C155          MOV   *TMP1,TMP1
  0333 6028 0455          B     *TMP1                 ; Switch to routine in T
