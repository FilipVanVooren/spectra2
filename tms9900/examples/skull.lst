  0201            * The config register equates
  0202            *-----------------------------------------------------------
  0203            * Configuration flags
  0204            * ===================
  0205            * 
  0206            * ; 15  Sound player: tune source       1=ROM/RAM      0=VDP
  0207            * ; 14  Sound player: repeat tune       1=yes          0=no
  0208            * ; 13  Sound player: enabled           1=yes          0=no 
  0209            * ; 12  Keyboard: mode                  1=real         0=vir
  0210            * ; 11  Keyboard: ANY key pressed       1=yes          0=no
  0211            * ; 10  TI-99/4A v2.2 OS                1=yes          0=no
  0212            * ; 09  Timer: Kernel thread enabled    1=yes          0=no
  0213            * ; 08  Timer: Block kernel thread      1=yes          0=no	
  0214            * ; 07  Timer: User hook enabled        1=yes          0=no	
  0215            * ; 06  Timer: Block user hook          1=yes          0=no
  0216            * ; 05  speech player: external voice   1=yes          0=no
  0217            * ; 04  Speech player: busy             1=yes          0=no
  0218            * ; 03  Speech player: enabled          1=yes          0=no
  0219            * ; 02  VDP9918 PAL version             1=yes(50)      0=no(
  0220            * ; 01  Subroutine state flag 1         1=on           0=off
  0221            * ; 00  Subroutine state flag 0         1=on           0=off
  0222            ********@*****@*********************@***********************
  0223      2000  PALON   EQU   >2000                 ; bit 2=1   (VDP9918 PAL
  0224      0100  ENUSR   EQU   >0100                 ; bit 7=1   (Enable user

