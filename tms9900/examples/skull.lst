  2027            * VIRTKB () ..:
  2028            ************************************************************
  2029            * VIRTKB - Read virtual keyboard and joysticks
  2030            ************************************************************
  2031            *  BL @VIRTKB
  2032            *-----------------------------------------------------------
  2033            *  COLUMN     0     1  2  3  4  5    6   7
  2034            *         +---------------------------------+------+
  2035            *  ROW 7  |   =     .  ,  M  N  /   JS1 JS2 | Fire |
  2036            *  ROW 6  | SPACE   L  K  J  H  :;  JS1 JS2 | Left |
  2037            *  ROW 5  | ENTER   O  I  U  Y  P   JS1 JS2 | Right|
  2038            *  ROW 4  |         9  8  7  6  0   JS1 JS2 | Down |
  2039            *  ROW 3  | FCTN    2  3  4  5  1   JS1 JS2 | Up   |
  2040            *  ROW 2  | SHIFT   S  D  F  G  A           +------|
  2041            *  ROW 1  | CTRL    W  E  R  T  Q                  |
  2042            *  ROW 0  |         X  C  V  B  Z                  |
  2043            *         +----------------------------------------+
  2044            *  See MG smart programmer 1986 
  2045            *  September/Page 15 and November/Page 6
  2046            *  Also see virtual keyboard status for bits to check
  2047            *-----------------------------------------------------------
  2048            *  Register usage
  2049            *  TMP0     Keyboard matrix column to process
  2050            *  TMP1MSB  Keyboard matrix 8 bits of 1 column
  2051            *  TMP2     Virtual keyboard flags
  2052            *  TMP3     Address of entry in mapping table
  2053            *  TMP4     Copy of R12 (CONFIG REGISTER)
  2054            *  R12      CRU communication
  2055            ********@*****@*********************@***********************
  2056 67CE 4320  VIRTKB  SZC   @WBIT11,CONFIG        ; Reset ANY key
       67D0 6040 
  2057 67D2 C20C          MOV   CONFIG,TMP4           ; Save R12 (CONFIG REGIS
  2058 67D4 04C4          CLR   TMP0                  ; Value in MSB! Start wi
  2059 67D6 04C6          CLR   TMP2                  ; Erase virtual keyboard
  2060 67D8 0207          LI    TMP3,KBMAP0           ; Start with column 0
       67DA 684A 
  2061            *-----------------------------------------------------------
  2062            * Check alpha lock key
  2063            *-------@-----@---------------------@-----------------------
  2064 67DC 04CC          CLR   R12
  2065 67DE 1E15          SBZ   >0015                 ; Set P5
  2066 67E0 1F07          TB    7
  2067 67E2 1302          JEQ   VIRTK1
  2068 67E4 0206          LI    TMP2,KALPHA           ; Alpha lock key down
       67E6 8000 
  2069            *-----------------------------------------------------------
  2070            * Scan keyboard matrix
  2071            *-------@-----@---------------------@-----------------------
  2072 67E8 1D15  VIRTK1  SBO   >0015                 ; Reset P5
  2073 67EA 020C          LI    R12,>0024             ; Scan full 8x8 keyboard
       67EC 0024 
  2074 67EE 30C4          LDCR  TMP0,3                ; Set keyboard column wi
  2075 67F0 020C          LI    R12,>0006             ; Load CRU base for row.
       67F2 0006 
  2076 67F4 0705          SETO  TMP1                  ; >FFFF
  2077 67F6 3605          STCR  TMP1,8                ; Bring 8 row bits into 
  2078 67F8 0545          INV   TMP1
