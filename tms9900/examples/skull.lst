  0762            * RLE2V (DATA P0,P1,P2) ..:
  0763            ************************************************************
  0764            * RLE2V - RLE decompress to VRAM memory
  0765            ************************************************************
  0766            *  BL   @RLE2V
  0767            *  DATA P0,P1,P2
  0768            *-----------------------------------------------------------
  0769            *  P0 = ROM/RAM source address 
  0770            *  P1 = VDP target address
  0771            *  P2 = Length of RLE encoded data
  0772            *-----------------------------------------------------------
  0773            *  BL @RLE2VX
  0774            *
  0775            *  TMP0     = VDP target address
  0776            *  TMP2 (!) = ROM/RAM source address 
  0777            *  TMP3 (!) = Length of RLE encoded data
  0778            *-----------------------------------------------------------
  0779            *  Detail on RLE compression format:
  0780            *  - If high bit is set, remaining 7 bits indicate to copy 
  0781            *    the next byte that many times.
  0782            *  - If high bit is clear, remaining 7 bits indicate how man
  0783            *    data bytes (non-repeated) follow.
  0784            ********@*****@*********************@***********************
  0785 61AA C1BB  RLE2V   MOV   *R11+,TMP2            ; ROM/RAM source address
  0786 61AC C13B          MOV   *R11+,TMP0            ; VDP target address
  0787 61AE C1FB          MOV   *R11+,TMP3            ; Length of RLE encoded 
  0788 61B0 C80B          MOV   R11,@WAUX1            ; Save return address
       61B2 833C 
  0789 61B4 06A0  RLE2VX  BL    @VDWA                 ; Setup VDP address from
       61B6 61F0 
  0790 61B8 C106          MOV   TMP2,TMP0             ; We can safely reuse TM
  0791 61BA D1B4  RLE2V0  MOVB  *TMP0+,TMP2           ; Get control byte into 
  0792 61BC 0607          DEC   TMP3                  ; Update length
  0793 61BE 1314          JEQ   RLE2VZ                ; End of list
  0794 61C0 0A16          SLA   TMP2,1                ; Check bit 0 of control
  0795 61C2 1808          JOC   RLE2V2                ; Yes, next byte is comp
  0796            *-----------------------------------------------------------
  0797            *    Dump uncompressed bytes
  0798            *-----------------------------------------------------------
  0799 61C4 C820  RLE2V1  MOV   @RLEDAT,@MCLOOP       ; Setup machine code (MO
       61C6 61EE 
       61C8 8320 
  0800 61CA 0996          SRL   TMP2,9                ; Use control byte as co
  0801 61CC 61C6          S     TMP2,TMP3             ; Update length        
  0802 61CE 06A0          BL    @MCLOOP               ; Write data to VDP
       61D0 8320 

