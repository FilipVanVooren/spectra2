  0395            * ; VDP#0 Control bits
  0396            * ;      bit 6=0: M3 | Graphics 1 mode
  0397            * ;      bit 7=0: Disable external VDP input
  0398            * ; VDP#1 Control bits
  0399            * ;      bit 0=1: 16K selection
  0400            * ;      bit 1=1: Enable display
  0401            * ;      bit 2=1: Enable VDP interrupt
  0402            * ;      bit 3=0: M1 \ Graphics 1 mode
  0403            * ;      bit 4=0: M2 /
  0404            * ;      bit 5=0: reserved
  0405            * ;      bit 6=1: 16x16 sprites
  0406            * ;      bit 7=0: Sprite magnification (1x)
  0407            * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >4
  0408            * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >0
  0409            * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >8
  0410            * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >0
  0411            * ; VDP#6 SPT (Sprite pattern table)     at >1000  (>02 * >8
  0412            * ; VDP#7 Set screen background color
  0413            ************************************************************
  0414            * Textmode (40 columns)
  0415            *-----------------------------------------------------------
  0416 6062   00  TXTMOD  BYTE  >00,>F2,>00,>0E,>01,>06,>00,SPFCLR,0,40
       6063   F2 
       6064   00 
       6065   0E 
       6066   01 
       6067   06 
       6068   00 
       6069   01 
       606A   00 
       606B   28 
  0417            * ; VDP#0 Control bits
  0418            * ;      bit 6=0: M3 | Graphics 1 mode
  0419            * ;      bit 7=0: Disable external VDP input
  0420            * ; VDP#1 Control bits
  0421            * ;      bit 0=1: 16K selection
  0422            * ;      bit 1=1: Enable display
  0423            * ;      bit 2=1: Enable VDP interrupt
  0424            * ;      bit 3=1: M1 \ TEXT MODE
  0425            * ;      bit 4=0: M2 /
  0426            * ;      bit 5=0: reserved
  0427            * ;      bit 6=1: 16x16 sprites
  0428            * ;      bit 7=0: Sprite magnification (1x)
  0429            * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >4
  0430            * ; VDP#3 PCT (Pattern color table)      at >0380  (>0E * >0
  0431            * ; VDP#4 PDT (Pattern descriptor table) at >0800  (>01 * >8
  0432            * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >0
  0433            * ; VDP#6 SPT (Sprite pattern table)     at >0000  (>00 * >8
  0434            * ; VDP#7 Set foreground/background color
  0435            ************************************************************
