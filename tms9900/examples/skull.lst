  0065            * >8300 - >8341     Scratchpad memory layout
  0066            ********@*****@*********************@***********************
  0067      8300  WS1     EQU   >8300                 ; 32 - Primary workspace
  0068      8320  MCLOOP  EQU   >8320                 ; 08 - Machine code for 
  0069      8328  WBASE   EQU   >8328                 ; 02 - PNT base address
  0070      832A  WYX     EQU   >832A                 ; 02 - Cursor YX positio
  0071      832C  WTITAB  EQU   >832C                 ; 02 - Timers: Address o
  0072      832E  WTIUSR  EQU   >832E                 ; 02 - Timers: Address o
  0073      8330  WTITMP  EQU   >8330                 ; 02 - Timers: Internal 
  0074      8332  WVRTKB  EQU   >8332                 ; 02 - Virtual keyboard 
  0075      8334  WSDLST  EQU   >8334                 ; 02 - Sound player: Tun
  0076      8336  WSDTMP  EQU   >8336                 ; 02 - Sound player: Tem
  0077      8338  WSPEAK  EQU   >8338                 ; 02 - Speech player: Ad
  0078      833A  WCOLMN  EQU   >833A                 ; 02 - Screen size, colu
  0079      833C  WAUX1   EQU   >833C                 ; 02 - Temporary storage
  0080      833E  WAUX2   EQU   >833E                 ; 02 - Temporary storage
  0081      8340  WAUX3   EQU   >8340                 ; 02 - Temporary storage
  0082            ************************************************************
  0083      832A  BY      EQU   WYX                   ;      Cursor Y position
  0084      832B  BX      EQU   WYX+1                 ;      Cursor X position
  0085      8322  MCSPRD  EQU   MCLOOP+2              ;      Speech read routi
  0086            ************************************************************
  0087            * Register usage
  0088            * R0-R3   General purpose registers
  0089            * R4-R8   Temporary registers
  0090            * R9      Stack pointer
  0091            * R10     Highest slot in use + Timer counter
  0092            * R11     Subroutine return address
  0093            * R12     Configuration register
  0094            * R13     Copy of VDP status byte and counter for sound play
  0095            * R14     Copy of VDP register #0 and VDP register #1 bytes
  0096            * R15     VDP read/write address
  0097            ************************************************************
  0098            * Workspace and register equates
  0099            ********@*****@*********************@***********************
